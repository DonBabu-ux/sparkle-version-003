<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sparkle | Discover Groups (Prototype)</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Prototype Styles -->
    <link rel="stylesheet" href="/css/groups-proto.css">
</head>
<body class="proto-body">
    
    <!-- Render Container -->
    <div id="protoBody">
        <!-- JS will populate this -->
        <div style="display:flex; align-items:center; justify-content:center; height:100vh; flex-direction:column; color:#ff2e88;">
            <i class="fas fa-circle-notch fa-spin fa-3x" style="margin-bottom:20px;"></i>
            <h2 style="font-weight:900;">Sparkle Groups Loading...</h2>
        </div>
    </div>

    <!-- ADMIN PANEL MODAL (Hidden by default) -->
    <div class="proto-modal" id="adminModal">
        <div class="glass-card p-modal-content">
            <div class="p-modal-inner">
                <div class="p-modal-sidebar">
                    <div class="m-tab active" data-tab="requests"><i class="fas fa-user-clock" style="margin-right:12px;"></i> Requests</div>
                    <div class="m-tab" data-tab="members"><i class="fas fa-users-cog" style="margin-right:12px;"></i> Members</div>
                    <div class="m-tab" data-tab="settings"><i class="fas fa-tools" style="margin-right:12px;"></i> Settings</div>
                    <div class="m-tab" data-tab="moderation"><i class="fas fa-shield-alt" style="margin-right:12px;"></i> Content</div>
                    <div style="margin-top:auto; padding:20px;">
                        <button class="btn-sparkle secondary close-modal" style="width:100%;"><i class="fas fa-times"></i> Close</button>
                    </div>
                </div>
                <div class="p-modal-body" id="adminModalBody">
                    <!-- Populated by JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="/js/groups-mock-data.js"></script>
    <script src="/js/groups-proto.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            GroupsProto.init();
        });
    </script>
</body>
</html>
