<%- include('../partials/head', { title: 'My Orders | Sparkle Mall' }) %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap');
    :root {
        --primary: #E1306C;
        --primary-light: #fff0f5;
        --secondary: #833AB4;
        --bg: #f5f5f7;
        --card: #ffffff;
        --border: #efefef;
        --radius: 22px;
        --gradient: linear-gradient(135deg,#f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%);
        --shadow: 0 8px 32px rgba(0,0,0,0.07);
    }

    * { box-sizing: border-box; }

    body {
        background: var(--bg);
        font-family: 'Outfit', sans-serif;
        padding-top: 80px;
        min-height: 100vh;
    }

    .container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    /* ── Header ── */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 32px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .page-title {
        font-size: 2.2rem;
        font-weight: 900;
        background: var(--gradient);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
        font-size: .85rem;
        color: #888;
        font-weight: 600;
        margin-top: 4px;
    }

    /* ── Tab Filters ── */
    .tab-row {
        display: flex;
        gap: 8px;
        margin-bottom: 28px;
        overflow-x: auto;
        scrollbar-width: none;
        padding-bottom: 4px;
    }

    .tab-btn {
        padding: 9px 22px;
        border-radius: 50px;
        font-weight: 800;
        font-size: .82rem;
        border: 1.5px solid var(--border);
        background: white;
        cursor: pointer;
        transition: .25s;
        white-space: nowrap;
        font-family: inherit;
    }

    .tab-btn.active, .tab-btn:hover {
        background: var(--gradient);
        color: white;
        border-color: transparent;
    }

    /* ── Order Cards ── */
    .order-card {
        background: var(--card);
        border-radius: var(--radius);
        padding: 24px;
        margin-bottom: 20px;
        border: 1.5px solid var(--border);
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 24px;
        transition: .3s;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

    .order-card::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
    }

    .order-card.status-pending::before   { background: #f59e0b; }
    .order-card.status-accepted::before  { background: #10b981; }
    .order-card.status-rejected::before  { background: #ef4444; }
    .order-card.status-cancelled::before { background: #6b7280; }
    .order-card.status-completed::before { background: var(--secondary); }
    .order-card.status-disputed::before  { background: #f97316; }

    .order-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(0,0,0,0.1);
    }

    .item-img {
        width: 140px; height: 140px;
        border-radius: 16px;
        object-fit: cover;
        background: linear-gradient(135deg,#fdf2f8,#f3e8ff);
    }

    .item-no-img {
        width: 140px; height: 140px;
        border-radius: 16px;
        background: linear-gradient(135deg,#fdf2f8,#f3e8ff);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 8px; color: #ccc;
        font-size: .72rem;
    }

    .order-body { display: flex; flex-direction: column; }

    .order-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
        gap: 12px;
    }

    .order-date {
        font-size: .72rem;
        color: #999;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 5px;
    }

    .item-title {
        font-weight: 800;
        font-size: 1.15rem;
        color: #1a1a2e;
        text-decoration: none;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .status-badge {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .8px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .badge-pending   { background:#fef3c7; color:#d97706; }
    .badge-accepted  { background:#d1fae5; color:#059669; }
    .badge-rejected  { background:#fee2e2; color:#dc2626; }
    .badge-cancelled { background:#f3f4f6; color:#6b7280; }
    .badge-completed { background:#ede9fe; color:#7c3aed; }
    .badge-disputed  { background:#ffedd5; color:#ea580c; }

    .other-user {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 14px;
    }

    .other-avatar {
        width: 30px; height: 30px;
        border-radius: 50%; object-fit: cover;
    }

    .other-label { font-size: .78rem; color: #888; font-weight: 600; }
    .other-name  { font-weight: 800; font-size: .88rem; color: #333; }

    .price-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
        padding-top: 14px;
        border-top: 1px solid #f5f5f5;
        flex-wrap: wrap;
        gap: 12px;
    }

    .price-tag {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary);
    }

    .price-currency { font-size: .85rem; font-weight: 700; opacity: .65; }

    .action-row { display: flex; gap: 10px; flex-wrap: wrap; }

    .btn {
        padding: 10px 20px;
        border-radius: 13px;
        font-weight: 800;
        font-size: .82rem;
        border: none;
        cursor: pointer;
        transition: .25s;
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 7px;
        font-family: inherit;
        white-space: nowrap;
    }

    .btn-primary   { background: var(--gradient); color: white; box-shadow: 0 5px 16px rgba(225,48,108,.2); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 9px 24px rgba(225,48,108,.3); }
    .btn-secondary { background: #ede9fe; color: #7c3aed; }
    .btn-secondary:hover { background: #ddd6fe; }
    .btn-danger    { background: #fee2e2; color: #dc2626; }
    .btn-danger:hover    { background: #fecaca; }
    .btn-ghost     { background: white; border: 1.5px solid var(--border); color: #555; }
    .btn-ghost:hover     { border-color: var(--primary); color: var(--primary); }
    .btn-success   { background: #d1fae5; color: #059669; }
    .btn-success:hover   { background: #a7f3d0; }

    /* ── Meetup Status ── */
    .meetup-bar {
        background: #fffbeb;
        border: 1.5px solid #fde68a;
        border-radius: 13px;
        padding: 12px 16px;
        font-size: .82rem;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .meetup-checks { display: flex; gap: 10px; font-weight: 700; }
    .check-yes { color: #059669; }
    .check-no  { color: #d97706; }

    /* ── Role Tabs ── */
    .role-tag {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: .7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .8px;
        padding: 3px 10px;
        border-radius: 50px;
    }

    .role-buyer  { background: #dbeafe; color: #2563eb; }
    .role-seller { background: #fce7f3; color: #be185d; }

    /* ── Empty State ── */
    .empty-state {
        text-align: center;
        padding: 100px 20px;
    }

    /* ── OS-level Live Indicator ── */
    .live-dot {
        display: inline-block;
        width: 8px; height: 8px;
        background: #10b981;
        border-radius: 50%;
        margin-left: 6px;
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%   { box-shadow: 0 0 0 0 rgba(16,185,129,.5); }
        70%  { box-shadow: 0 0 0 8px rgba(16,185,129,0); }
        100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); }
    }

    /* ── Toast ── */
    #toast {
        position: fixed; bottom: 28px; left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #1a1a2e; color: white;
        padding: 13px 30px; border-radius: 50px;
        font-weight: 800; z-index: 9999;
        opacity: 0; transition: all .35s cubic-bezier(.175,.885,.32,1.275);
        pointer-events: none;
    }
    #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @media(max-width:600px) {
        .order-card { grid-template-columns: 1fr; }
        .item-img, .item-no-img { display: none; }
        .page-title { font-size: 1.6rem; }
    }
</style>

<!-- Page State -->
<meta name="user-id" content="<%= user?.user_id || '' %>">

<div class="container">
    <div class="page-header">
        <div>
            <h1 class="page-title">My Orders <span class="live-dot" title="Live updates on"></span></h1>
            <div class="page-subtitle"><%= orders.length %> total orders</div>
        </div>
        <div style="display:flex;gap:10px;">
            <a href="/marketplace" class="btn btn-ghost"><i data-lucide="shopping-bag" style="width:15px;"></i> Browse Market</a>
            <a href="/marketplace/sell" class="btn btn-primary"><i data-lucide="plus" style="width:15px;"></i> Sell Item</a>
        </div>
    </div>

    <!-- Status Filter Tabs -->
    <div class="tab-row">
        <button class="tab-btn active" onclick="filterOrders('all', this)">All (<%= orders.length %>)</button>
        <button class="tab-btn" onclick="filterOrders('pending', this)">Pending</button>
        <button class="tab-btn" onclick="filterOrders('accepted', this)">Accepted</button>
        <button class="tab-btn" onclick="filterOrders('completed', this)">Completed</button>
        <button class="tab-btn" onclick="filterOrders('rejected', this)">Rejected</button>
        <button class="tab-btn" onclick="filterOrders('cancelled', this)">Cancelled</button>
        <button class="tab-btn" onclick="filterOrders('disputed', this)">Disputed</button>
    </div>

    <div id="ordersContainer">
        <% if (orders && orders.length > 0) { %>
            <% orders.forEach(order => { %>
                <%
                    const isBuyer  = user && order.buyer_id  === user.user_id;
                    const isSeller = user && order.seller_id === user.user_id;
                    const otherName   = isBuyer ? order.seller_username : order.buyer_username;
                    const otherAvatar = isBuyer ? order.seller_avatar   : order.buyer_avatar;
                    const priceKes    = parseFloat(order.price_at_time || order.price || 0).toLocaleString('en-KE');
                    const badgeClass  = `badge-${order.status}`;
                    const statusEmoji = {
                        pending: '⏳', accepted: '✅', rejected: '❌',
                        cancelled: '🚫', completed: '🎉', disputed: '⚠️'
                    }[order.status] || '';
                %>
                <div class="order-card status-<%= order.status %>"
                     id="order-<%= order.order_id %>"
                     data-status="<%= order.status %>">

                    <!-- Item Image -->
                    <% if (order.image_url) { %>
                        <img src="<%= order.image_url %>" class="item-img"
                             alt="<%= order.listing_title %>"
                             onerror="this.classList.remove('item-img');this.outerHTML='<div class=\'item-no-img\'><i data-lucide=\'image\' style=\'width:36px;height:36px;\'></i></div>'">
                    <% } else { %>
                        <div class="item-no-img">
                            <i data-lucide="image" style="width:36px;height:36px;"></i>
                            <span>No image</span>
                        </div>
                    <% } %>

                    <div class="order-body">
                        <div class="order-top">
                            <div>
                                <div class="order-date">
                                    <%= new Date(order.created_at).toLocaleDateString('en-KE', { day:'numeric', month:'short', year:'numeric' }) %>
                                    &nbsp;•&nbsp;
                                    <span class="role-tag <%= isBuyer ? 'role-buyer' : 'role-seller' %>">
                                        <%= isBuyer ? '🛒 Buyer' : '🏪 Seller' %>
                                    </span>
                                </div>
                                <div class="item-title"><%= order.listing_title %></div>
                            </div>
                            <span class="status-badge <%= badgeClass %>">
                                <%= statusEmoji %> <%= order.status %>
                            </span>
                        </div>

                        <!-- Other party -->
                        <div class="other-user">
                            <img src="<%= otherAvatar || '/images/default-avatar.png' %>"
                                 class="other-avatar"
                                 onerror="this.src='/images/default-avatar.png'"
                                 alt="<%= otherName %>">
                            <div>
                                <div class="other-label"><%= isBuyer ? 'Seller' : 'Buyer' %></div>
                                <div class="other-name"><%= otherName || 'Unknown' %></div>
                            </div>
                        </div>

                        <!-- Meetup confirmation bar for accepted orders -->
                        <% if (order.status === 'accepted') { %>
                        <div class="meetup-bar">
                            <span>📍 Meetup Confirmation</span>
                            <div class="meetup-checks">
                                <span class="<%= order.meetup_confirmed_by_buyer  ? 'check-yes' : 'check-no' %>">
                                    Buyer: <%= order.meetup_confirmed_by_buyer  ? '✅' : '⏳' %>
                                </span>
                                <span class="<%= order.meetup_confirmed_by_seller ? 'check-yes' : 'check-no' %>">
                                    Seller: <%= order.meetup_confirmed_by_seller ? '✅' : '⏳' %>
                                </span>
                            </div>
                        </div>
                        <% } %>

                        <!-- Price & Actions -->
                        <div class="price-row">
                            <div class="price-tag">
                                <span class="price-currency">KES </span><%= priceKes %>
                            </div>
                            <div class="action-row">
                                <!-- Chat button always available -->
                                <a href="/messages?chat_with=<%= isBuyer ? order.seller_id : order.buyer_id %>&order=<%= order.order_id %>"
                                   class="btn btn-ghost">
                                    <i data-lucide="message-circle" style="width:14px;"></i> Chat
                                </a>

                                <!-- Seller Actions for pending orders -->
                                <% if (isSeller && order.status === 'pending') { %>
                                    <button class="btn btn-success"
                                            onclick="updateStatus('<%= order.order_id %>', 'accepted', this)">
                                        <i data-lucide="check-circle" style="width:14px;"></i> Accept
                                    </button>
                                    <button class="btn btn-danger"
                                            onclick="updateStatus('<%= order.order_id %>', 'rejected', this)">
                                        <i data-lucide="x-circle" style="width:14px;"></i> Reject
                                    </button>
                                <% } %>

                                <!-- Confirm Meetup for accepted orders -->
                                <% if (order.status === 'accepted') { %>
                                    <%
                                        const meConfirmed = isBuyer
                                            ? order.meetup_confirmed_by_buyer
                                            : order.meetup_confirmed_by_seller;
                                    %>
                                    <% if (!meConfirmed) { %>
                                    <button class="btn btn-secondary"
                                            onclick="confirmMeetup('<%= order.order_id %>', this)">
                                        <i data-lucide="map-pin" style="width:14px;"></i> Confirm Meetup
                                    </button>
                                    <% } %>

                                    <!-- Both confirmed → seller can complete -->
                                    <% if (isSeller && order.meetup_confirmed_by_buyer && order.meetup_confirmed_by_seller) { %>
                                    <button class="btn btn-primary"
                                            onclick="updateStatus('<%= order.order_id %>', 'completed', this)">
                                        <i data-lucide="package-check" style="width:14px;"></i> Mark Complete
                                    </button>
                                    <% } %>
                                <% } %>

                                <!-- Cancel (pending or accepted) -->
                                <% if (['pending','accepted'].includes(order.status)) { %>
                                    <button class="btn btn-danger"
                                            onclick="cancelOrder('<%= order.order_id %>', this)">
                                        <i data-lucide="x" style="width:14px;"></i> Cancel
                                    </button>
                                <% } %>

                                <!-- Review after completion (buyer) -->
                                <% if (order.status === 'completed' && isBuyer) { %>
                                    <button class="btn btn-secondary"
                                            onclick="openReviewModal('<%= order.order_id %>','<%= order.seller_id %>')">
                                        <i data-lucide="star" style="width:14px;"></i> Leave Review
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <i data-lucide="package-search" style="width:80px;height:80px;color:#ddd;display:block;margin:0 auto 20px;"></i>
                <h2 style="font-weight:800;margin-bottom:10px;">No orders yet</h2>
                <p style="color:#888;margin-bottom:24px;">Start shopping on the marketplace!</p>
                <a href="/marketplace" class="btn btn-primary" style="display:inline-flex;padding:14px 36px;">
                    <i data-lucide="shopping-bag" style="width:16px;"></i> Browse Market
                </a>
            </div>
        <% } %>
    </div>
</div>

<!-- Toast -->
<div id="toast"></div>

<%- include('../partials/scripts') %>
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-database-compat.js"></script>

<script>
    lucide.createIcons();

    const CURRENT_USER_ID = document.querySelector('meta[name=user-id]')?.content || '';

    // ── Firebase Init ─────────────────────────────────────────────────────────
    const firebaseConfig = {
        apiKey: "AIzaSyDKKlpoJ4PgejlKFL-2LEhpHHWnHRpZoLM",
        authDomain: "sparkleapp-10f62.firebaseapp.com",
        databaseURL: "https://sparkleapp-10f62-default-rtdb.firebaseio.com",
        projectId: "sparkleapp-10f62"
    };
    if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
    const rtdb = firebase.database();

    // ── Live order status updates ─────────────────────────────────────────────
    document.querySelectorAll('.order-card').forEach(card => {
        const orderId = card.id.replace('order-', '');
        if (!orderId) return;

        rtdb.ref(`marketplace/orders/${orderId}`).on('value', snap => {
            const data = snap.val();
            if (!data || !data.status) return;

            const badge = card.querySelector('.status-badge');
            const statusEmoji = { pending:'⏳',accepted:'✅',rejected:'❌',cancelled:'🚫',completed:'🎉',disputed:'⚠️' };
            if (badge) {
                badge.textContent = (statusEmoji[data.status] || '') + ' ' + data.status;
                badge.className = `status-badge badge-${data.status}`;
            }

            card.className = `order-card status-${data.status}`;
            card.dataset.status = data.status;

            if (data.status === 'accepted')  showToast('✅ Order accepted by seller!', 'success');
            if (data.status === 'rejected')  showToast('❌ Order was rejected.', 'error');
            if (data.status === 'completed') showToast('🎉 Order completed!', 'success');
        });
    });

    // ── Toast ─────────────────────────────────────────────────────────────────
    function showToast(msg, type = 'default') {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.style.background = type === 'error' ? '#dc2626' : type === 'success' ? '#059669' : '#1a1a2e';
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3500);
    }

    // ── Tab Filter ────────────────────────────────────────────────────────────
    function filterOrders(status, btn) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        document.querySelectorAll('.order-card').forEach(card => {
            card.style.display = (status === 'all' || card.dataset.status === status) ? '' : 'none';
        });
    }

    // ── Update Status ─────────────────────────────────────────────────────────
    async function updateStatus(orderId, newStatus, btn) {
        btn.disabled = true;
        const orig = btn.innerHTML;
        btn.innerHTML = '⏳ Updating…';

        try {
            const res = await fetch(`/api/marketplace/orders/${orderId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
            const data = await res.json();

            if (data.success) {
                showToast(`Order ${newStatus}!`, 'success');
                // Firebase will auto-update UI; also do a hard refresh after 2s
                setTimeout(() => location.reload(), 2000);
            } else {
                showToast(data.message || 'Update failed', 'error');
                btn.disabled = false;
                btn.innerHTML = orig;
            }
        } catch(e) {
            showToast('Request failed', 'error');
            btn.disabled = false;
            btn.innerHTML = orig;
        }
    }

    // ── Cancel with reason ────────────────────────────────────────────────────
    async function cancelOrder(orderId, btn) {
        const reason = prompt('Reason for cancellation (optional):');
        if (reason === null) return; // user pressed Cancel on prompt

        await updateStatusWithReason(orderId, 'cancelled', reason, btn);
    }

    async function updateStatusWithReason(orderId, status, reason, btn) {
        btn.disabled = true;
        const orig = btn.innerHTML;
        btn.innerHTML = '⏳…';

        try {
            const res = await fetch(`/api/marketplace/orders/${orderId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status, reason })
            });
            const data = await res.json();

            if (data.success) {
                showToast(`Order ${status}`, 'success');
                setTimeout(() => location.reload(), 2000);
            } else {
                showToast(data.message || 'Failed', 'error');
                btn.disabled = false;
                btn.innerHTML = orig;
            }
        } catch(e) {
            showToast('Request failed', 'error');
            btn.disabled = false;
            btn.innerHTML = orig;
        }
    }

    // ── Confirm Meetup ────────────────────────────────────────────────────────
    async function confirmMeetup(orderId, btn) {
        btn.disabled = true;
        const orig = btn.innerHTML;
        btn.innerHTML = '⏳ Confirming…';

        try {
            const res = await fetch(`/api/marketplace/orders/${orderId}/confirm-meetup`, {
                method: 'POST'
            });
            const data = await res.json();

            if (data.success) {
                showToast(data.bothConfirmed
                    ? '🎉 Both confirmed! You can now complete the order.'
                    : '✅ Meetup confirmed! Waiting for the other party.', 'success');
                setTimeout(() => location.reload(), 2000);
            } else {
                showToast(data.message || 'Failed to confirm', 'error');
                btn.disabled = false;
                btn.innerHTML = orig;
            }
        } catch(e) {
            showToast('Request failed', 'error');
            btn.disabled = false;
            btn.innerHTML = orig;
        }
    }

    // ── Review Modal (placeholder – links to review route) ────────────────────
    function openReviewModal(orderId, revieweeId) {
        const rating = prompt('Rate the seller (1-5):');
        if (!rating || isNaN(rating) || rating < 1 || rating > 5) return;
        const comment = prompt('Leave a comment (optional):') || '';

        fetch('/api/marketplace/users/' + revieweeId + '/review', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ listing_id: null, reviewee_id: revieweeId, rating: parseInt(rating), comment, transaction_type: 'buyer' })
        }).then(r => r.json()).then(d => {
            if (d.success) showToast('⭐ Review submitted!', 'success');
            else showToast(d.message || 'Review failed', 'error');
        });
    }
</script>
