        if (picker) picker.style.display = 'none';
        const modal = document.getElementById('momentModal');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
    };

    window.openAfterglowModal = function() {
        const picker = document.getElementById('createPickerModal');
        if (picker) picker.style.display = 'none';
        const modal = document.getElementById('afterglowModal');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            if (window.initAfterglowPhase1) window.initAfterglowPhase1();
