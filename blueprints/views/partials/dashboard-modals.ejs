<!-- Create Event Modal -->
<div class="modal premium-modal" id="eventModal" style="display:none;">
    <div class="modal-content premium-modal-content">
        <div class="modal-header premium-modal-header">
            <div class="modal-title premium-modal-title">
                <i class="fas fa-calendar-plus text-primary" style="color: #ff5722 !important;"></i> Create Campus Event
            </div>
            <button class="close-modal premium-close-btn" id="closeEventModal">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body premium-modal-body">
            <div class="post-input-section">
                <label class="option-label">Event Title</label>
                <input type="text" class="post-input" id="eventTitle" placeholder="Give your event a name..."
                    style="width: 100%; margin-bottom: 15px; padding: 12px; border: 1px solid #e2e8f0; border-radius: 12px; font-weight: 600;">
                
                <label class="option-label">Description</label>
                <textarea class="post-textarea" id="eventDesc" rows="3" placeholder="Tell people what's happening..."></textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
                <div class="option-group">
                    <label class="option-label"><i class="fas fa-clock"></i> Date & Time</label>
                    <input type="datetime-local" id="eventStart"
                        style="width:100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <div class="option-group">
                    <label class="option-label"><i class="fas fa-map-marker-alt"></i> Location</label>
                    <input type="text" id="eventLocation" placeholder="Where is it?"
                        style="width:100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
            </div>

            <div class="option-group" style="margin-bottom: 20px;">
                <label class="option-label"><i class="fas fa-users"></i> Capacity (Optional)</label>
                <input type="number" id="eventCapacity" placeholder="Unlimited" min="0"
                    style="width:100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                <p style="font-size: 11px; color: #94a3b8; margin-top: 4px;">Leave empty or 0 for unlimited attendees</p>
            </div>

            <button class="btn-premium-submit" id="submitEventBtn"
                style="background: linear-gradient(135deg, #ff5722, #f44336); border: none; width: 100%; padding: 16px; border-radius: 14px; color: white; font-weight: 800; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: all 0.3s ease;">
                <span>Publish Event</span>
                <i class="fas fa-calendar-check"></i>
            </button>
        </div>
    </div>
</div>

<script>
    // Improved Event Modal Logic
    document.getElementById('closeEventModal')?.addEventListener('click', () => {
        document.getElementById('eventModal').style.display = 'none';
        document.body.style.overflow = 'auto'; // Re-enable scroll
    });

    document.getElementById('submitEventBtn')?.addEventListener('click', async () => {
        const titleInput = document.getElementById('eventTitle');
        const descInput = document.getElementById('eventDesc');
        const startInput = document.getElementById('eventStart');
        const locInput = document.getElementById('eventLocation');
        const capInput = document.getElementById('eventCapacity');
        const submitBtn = document.getElementById('submitEventBtn');

        const title = titleInput.value.trim();
        const description = descInput.value.trim();
        const start_time = startInput.value;
        const location = locInput.value.trim();
        const max_attendees = parseInt(capInput.value) || 0;

        if (!title) {
            titleInput.focus();
            if(window.showNotification) showNotification('Please enter an event title', 'error');
            else alert('Please enter an event title');
            return;
        }
        if (!start_time) {
            startInput.focus();
            if(window.showNotification) showNotification('Please select a start time', 'error');
            else alert('Please select a start time');
            return;
        }

        const originalBtnContent = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span>Creating Event...</span> <i class="fas fa-spinner fa-spin"></i>';

        try {
            // Get user from global state or localStorage if available
            const userData = typeof window.currentUser !== "undefined" ? window.currentUser : JSON.parse(localStorage.getItem('sparkleUser') || '{}');
            
            await DashboardAPI.createEvent({
                title, 
                description, 
                start_time, 
                location,
                max_attendees,
                campus: userData.campus || "Main Campus",
                is_public: true,
                event_type: 'meetup' 
            });
            
            if(window.showNotification) showNotification('✨ Sparkle Event Published!', 'success');
            else alert('✨ Sparkle Event Published!');
            
            document.getElementById('eventModal').style.display = 'none';
            document.body.style.overflow = 'auto';
            
            // Reload or update UI
            setTimeout(() => window.location.reload(), 1000);
        } catch (e) {
            if(window.showNotification) showNotification('Error creating event: ' + e.message, 'error');
            else alert('Error creating event: ' + e.message);
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnContent;
        }
    });

    // Global opener - Renamed to appShowEventModal to prevent recursion with any page-specific openEventModal
    window.appShowEventModal = () => {
        const picker = document.getElementById('createPickerModal');
        if (picker) picker.style.display = 'none';
        const modal = document.getElementById('eventModal');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
    };
    
    // Maintain alias for compatibility but ensure it doesn't call itself
    window.openEventModal = window.appShowEventModal;
</script>

<!-- Create Poll Modal -->
<div class="modal premium-modal" id="createPollModal">
    <div class="modal-content premium-modal-content">
        <div class="modal-header premium-modal-header">
            <div class="modal-title premium-modal-title">
                <i class="fas fa-poll text-primary" style="color: #9c27b0 !important;"></i> Create New Poll
            </div>
            <button class="close-modal premium-close-btn" id="closePollModal">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body premium-modal-body">
            <div class="post-input-section">
                <input type="text" class="post-input" id="pollQuestion" placeholder="Ask a question..."
                    style="width: 100%; margin-bottom: 15px; padding: 12px; border: 1px solid #ddd; border-radius: 12px; font-weight: 600;">
            </div>

            <div id="pollOptionsContainer">
                <div class="poll-option-input" style="margin-bottom: 10px;">
                    <input type="text" class="post-input option-input" placeholder="Option 1"
                        style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px;">
                </div>
                <div class="poll-option-input" style="margin-bottom: 10px;">
                    <input type="text" class="post-input option-input" placeholder="Option 2"
                        style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px;">
                </div>
            </div>

            <button class="btn btn-outline-primary btn-sm" onclick="addPollOption()" style="margin-bottom: 20px;">
                <i class="fas fa-plus"></i> Add Option
            </button>

            <div style="margin-bottom: 20px;">
                <label class="switch" style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="pollAnonymous">
                    <span class="slider round"
                        style="position: relative; display: inline-block; width: 40px; height: 20px;"></span>
                    <span style="font-size: 14px; color: var(--text-secondary);">Post Anonymously</span>
                </label>
            </div>

            <button class="btn-premium-submit" id="submitPollBtn"
                style="background: linear-gradient(135deg, #9c27b0, #673ab7);">
                <span>Launch Poll</span>
                <i class="fas fa-rocket"></i>
            </button>
        </div>
    </div>
</div>

<script>
    // Poll Modal Logic
    document.getElementById('closePollModal')?.addEventListener('click', () => {
        document.getElementById('createPollModal').style.display = 'none';
    });

    window.openCreatePollModal = () => {
        document.getElementById('createPollModal').style.display = 'flex';
    };

    window.addPollOption = () => {
        const container = document.getElementById('pollOptionsContainer');
        const count = container.children.length + 1;
        if (count > 5) return alert('Max 5 options allowed');

        const div = document.createElement('div');
        div.className = 'poll-option-input';
        div.style.marginBottom = '10px';
        div.innerHTML = `<input type="text" class="post-input option-input" placeholder="Option ${count}" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px;">`;
        container.appendChild(div);
    };

    document.getElementById('submitPollBtn')?.addEventListener('click', async () => {
        const question = document.getElementById('pollQuestion').value;
        const optionInputs = document.querySelectorAll('.option-input');
        const options = Array.from(optionInputs).map(input => input.value).filter(val => val.trim() !== '');
        const is_anonymous = document.getElementById('pollAnonymous').checked;

        if (!question || options.length < 2) return alert('Question and at least 2 options required');

        try {
            await DashboardAPI.createPoll({
                question, options,
                campus: typeof window.currentUser !== "undefined" && window.currentUser.campus ? window.currentUser.campus : "main",
                is_anonymous
            });
            alert('Poll created!');
            window.location.reload();
        } catch (e) {
            alert('Error creating poll: ' + e.message);
        }
    });
</script>

