<!-- Create AfterGlow Modal - WhatsApp Style Fullscreen -->
<div id="afterglowModal" style="display:none; position:fixed; inset:0; z-index:10000; background:#000; flex-direction:column;">

    <!-- Phase 1: Media Picker -->
    <div id="agPickerPhase" style="display:flex; flex-direction:column; height:100%; background:#111;">
        <!-- Header -->
        <div style="display:flex; align-items:center; gap:16px; padding: max(20px, env(safe-area-inset-top)) 16px 16px; background:#111;">
            <button onclick="closeAfterglowModal()" style="background:none;border:none;color:white;font-size:22px;cursor:pointer;width:40px;height:40px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:background .2s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='none'">
                <i class="fas fa-times"></i>
            </button>
            <div style="flex:1;">
                <div style="color:white;font-weight:800;font-size:20px;">Create AfterGlow</div>
                <div style="color:rgba(255,255,255,0.5);font-size:12px;">Vanishes in 24 hours ✨</div>
            </div>
        </div>

        <!-- Media Options -->
        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:24px; padding:30px;">
            <!-- Camera/Photo upload -->
            <div onclick="document.getElementById('agMediaInput').click()" style="width:100%;max-width:340px;background:linear-gradient(135deg,#9c27b0,#e91e63);border-radius:24px;padding:36px 20px;text-align:center;cursor:pointer;transition:transform .2s,box-shadow .2s;box-shadow:0 8px 30px rgba(156,39,176,0.35);" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 14px 40px rgba(156,39,176,0.5)'" onmouseout="this.style.transform='';this.style.boxShadow='0 8px 30px rgba(156,39,176,0.35)'">
                <i class="fas fa-camera" style="font-size:42px;color:white;margin-bottom:14px;display:block;"></i>
                <div style="color:white;font-weight:800;font-size:18px;">Photo / Video</div>
                <div style="color:rgba(255,255,255,0.7);font-size:13px;margin-top:5px;">Tap to pick from your gallery</div>
            </div>
            <!-- Text-only story -->
            <div onclick="openAgTextOnly()" style="width:100%;max-width:340px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:24px;padding:22px 20px;text-align:center;cursor:pointer;transition:background .2s;" onmouseover="this.style.background='rgba(255,255,255,0.12)'" onmouseout="this.style.background='rgba(255,255,255,0.07)'">
                <i class="fas fa-font" style="font-size:28px;color:rgba(255,255,255,0.8);margin-bottom:10px;display:block;"></i>
                <div style="color:white;font-weight:700;font-size:16px;">Text Story</div>
                <div style="color:rgba(255,255,255,0.5);font-size:12px;margin-top:4px;">Share words, no photo needed</div>
            </div>
            <input type="file" id="agMediaInput" accept="image/*,video/*" style="display:none;" onchange="handleAgMediaSelected(this)">
        </div>
    </div>

    <!-- Phase 2: Preview + Caption -->
    <div id="agPreviewPhase" style="display:none; flex-direction:column; height:100%; position:relative;">
        <!-- Media Preview Background -->
        <div id="agMediaBg" style="position:absolute;inset:0;z-index:1;">
            <img id="agPreviewImg" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;">
            <video id="agPreviewVideo" src="" style="width:100%;height:100%;object-fit:cover;display:none;" autoplay muted loop playsinline></video>
            <!-- Text-only bg -->
            <div id="agTextBg" style="display:none;width:100%;height:100%;background:linear-gradient(135deg,#6366f1,#a855f7,#ec4899);"></div>
        </div>

        <!-- Dark overlay for text readability -->
        <div style="position:absolute;inset:0;z-index:2;background:linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, transparent 25%, transparent 70%, rgba(0,0,0,0.7) 100%);pointer-events:none;"></div>

        <!-- Top bar -->
        <div style="position:absolute;top:0;left:0;right:0;z-index:10;display:flex;align-items:center;gap:12px;padding:max(20px,env(safe-area-inset-top)) 16px 16px;">
            <button onclick="backToAgPicker()" style="background:rgba(0,0,0,0.4);backdrop-filter:blur(10px);border:none;color:white;width:40px;height:40px;border-radius:50%;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-arrow-left"></i>
            </button>
            <div style="flex:1;color:white;font-weight:700;font-size:16px;text-shadow:0 1px 3px rgba(0,0,0,0.5);">Preview</div>
        </div>

        <!-- Center big text for text-only stories -->
        <div id="agTextOnlyDisplay" style="display:none;position:absolute;inset:0;z-index:5;display:none;align-items:center;justify-content:center;padding:40px;">
            <div id="agTextOnlyContent" style="color:white;font-size:28px;font-weight:800;text-align:center;text-shadow:0 2px 8px rgba(0,0,0,0.4);word-break:break-word;line-height:1.4;"></div>
        </div>

        <!-- Bottom: Caption + Send -->
        <div style="position:absolute;bottom:0;left:0;right:0;z-index:10;padding:16px 16px max(24px,env(safe-area-inset-bottom));">
            <!-- Caption input -->
            <div style="background:rgba(0,0,0,0.45);backdrop-filter:blur(16px);border-radius:28px;display:flex;align-items:flex-end;gap:12px;padding:10px 14px;margin-bottom:12px;border:1px solid rgba(255,255,255,0.15);">
                <i class="fas fa-smile" style="color:rgba(255,255,255,0.7);font-size:20px;padding-bottom:4px;cursor:pointer;"></i>
                <textarea id="agCaptionInput" placeholder="Add a caption..." rows="1"
                    style="flex:1;background:none;border:none;outline:none;color:white;font-size:16px;font-family:inherit;resize:none;max-height:100px;overflow-y:auto;line-height:1.4;padding:4px 0;"
                    oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px';"
                    onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();submitAfterglow();}"></textarea>
                <i class="fas fa-at" style="color:rgba(255,255,255,0.7);font-size:18px;padding-bottom:4px;cursor:pointer;"></i>
            </div>

            <!-- Send row -->
            <div style="display:flex;align-items:center;gap:10px;">
                <div style="flex:1;background:rgba(255,255,255,0.1);backdrop-filter:blur(10px);border-radius:28px;padding:14px 18px;color:white;font-size:14px;font-weight:600;border:1px solid rgba(255,255,255,0.15);cursor:pointer;" onclick="submitAfterglow()">
                    <i class="fas fa-history" style="margin-right:8px;color:#a855f7;"></i>My AfterGlow
                </div>
                <button onclick="submitAfterglow()" id="agSendBtn" style="width:54px;height:54px;border-radius:50%;background:linear-gradient(135deg,#9c27b0,#e91e63);border:none;color:white;font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 15px rgba(156,39,176,0.4);transition:transform .2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform=''">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function openAfterglowModal() {
    const modal = document.getElementById('afterglowModal');
    modal.style.display = 'flex';
    document.getElementById('agPickerPhase').style.display = 'flex';
    document.getElementById('agPreviewPhase').style.display = 'none';
    document.body.style.overflow = 'hidden';
    // Reset
    document.getElementById('agCaptionInput').value = '';
    document.getElementById('agMediaInput').value = '';
    document.getElementById('agPreviewImg').style.display = 'none';
    document.getElementById('agPreviewVideo').style.display = 'none';
    document.getElementById('agTextBg').style.display = 'none';
    document.getElementById('agTextOnlyDisplay').style.display = 'none';
}
window.openAfterglowModal = openAfterglowModal;

function closeAfterglowModal() {
    document.getElementById('afterglowModal').style.display = 'none';
    document.body.style.overflow = '';
}

function backToAgPicker() {
    document.getElementById('agPickerPhase').style.display = 'flex';
    document.getElementById('agPreviewPhase').style.display = 'none';
}

function handleAgMediaSelected(input) {
    const file = input.files[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    const isVideo = file.type.startsWith('video/');
    const img = document.getElementById('agPreviewImg');
    const vid = document.getElementById('agPreviewVideo');
    img.style.display = isVideo ? 'none' : 'block';
    vid.style.display = isVideo ? 'block' : 'none';
    document.getElementById('agTextBg').style.display = 'none';
    if (isVideo) vid.src = url; else img.src = url;
    document.getElementById('agPickerPhase').style.display = 'none';
    document.getElementById('agPreviewPhase').style.display = 'flex';
}

function openAgTextOnly() {
    document.getElementById('agPreviewImg').style.display = 'none';
    document.getElementById('agPreviewVideo').style.display = 'none';
    document.getElementById('agTextBg').style.display = 'block';
    document.getElementById('agTextOnlyDisplay').style.display = 'flex';
    document.getElementById('agMediaInput').value = '';
    document.getElementById('agPickerPhase').style.display = 'none';
    document.getElementById('agPreviewPhase').style.display = 'flex';
    // Mirror caption to center text display
    const captionInput = document.getElementById('agCaptionInput');
    captionInput.placeholder = 'Type your story...';
    captionInput.addEventListener('input', function() {
        document.getElementById('agTextOnlyContent').textContent = this.value;
    }, { once: false });
    setTimeout(() => captionInput.focus(), 100);
}

async function submitAfterglow() {
    const caption = document.getElementById('agCaptionInput').value.trim();
    const btn = document.getElementById('agSendBtn');
    const file = document.getElementById('agMediaInput').files[0];

    if (!caption && !file) {
        document.getElementById('agCaptionInput').focus();
        return;
    }

    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    btn.disabled = true;

    try {
        const formData = new FormData();
        if (caption) formData.append('content', caption);
        if (file) formData.append('media', file);

        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
        const response = await fetch('/api/stories', {
            method: 'POST',
            headers: csrfToken ? { 'x-csrf-token': csrfToken } : {},
            body: formData
        });

        if (response.ok) {
            closeAfterglowModal();
            // Show a brief success toast
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:100px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#9c27b0,#e91e63);color:white;padding:14px 24px;border-radius:30px;font-weight:700;font-size:15px;z-index:99999;box-shadow:0 8px 20px rgba(156,39,176,0.4);animation:fadeIn .3s ease;';
            toast.innerHTML = '<i class="fas fa-bolt" style="margin-right:8px;"></i>AfterGlow Shared!';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
            // Reload stories if on dashboard
            if (typeof loadAfterglowStories === 'function') loadAfterglowStories();
        } else {
            const err = await response.json();
            alert(err.error || 'Failed to share AfterGlow. Please try again.');
        }
    } catch (e) {
        console.error(e);
        alert('Network error. Please check your connection.');
    } finally {
        btn.innerHTML = '<i class="fas fa-paper-plane"></i>';
        btn.disabled = false;
    }
}
</script>

