<%- include('partials/head', { title: 'Support Center' }) %>
<link rel="stylesheet" href="/css/support.css">

<body class="proto-body">
    <%- include('partials/sidebar') %>

    <div id="mainContent">
        <div class="support-container">
            <!-- Header Section -->
            <div class="support-header">
                <h1>Support Center</h1>
                <p>How can we help you today?</p>
                <div class="search-container">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" id="helpSearch" class="search-bar-glass" placeholder="Search help topics..." />
                </div>
            </div>

            <!-- Quick Help Cards -->
            <div class="support-grid">
                <div class="support-card">
                    <i class="fas fa-user-circle card-icon text-sparkle-pink"></i>
                    <h3>Account Issues</h3>
                    <p>Login, password, and profile settings.</p>
                </div>
                <div class="support-card">
                    <i class="fas fa-users card-icon text-sparkle-purple"></i>
                    <h3>Groups & Communities</h3>
                    <p>Creating, managing, or joining groups.</p>
                </div>
                <div class="support-card">
                    <i class="fas fa-camera retro-icon text-sparkle-pink"></i>
                    <h3>Posting & Media</h3>
                    <p>Issues with uploading images or posting.</p>
                </div>
                <div class="support-card">
                    <i class="fas fa-shield-alt card-icon text-sparkle-purple"></i>
                    <h3>Privacy & Security</h3>
                    <p>Manage who sees your content.</p>
                </div>
                <div class="support-card">
                    <i class="fas fa-bell card-icon text-sparkle-pink"></i>
                    <h3>Notifications</h3>
                    <p>Manage your alerts and mobile push settings.</p>
                </div>
                <div class="support-card">
                    <i class="fas fa-exclamation-triangle card-icon text-sparkle-purple"></i>
                    <h3>Report a Problem</h3>
                    <p>Report bugs or abusive behavior.</p>
                </div>
            </div>

            <!-- FAQ Section -->
            <div class="faq-section">
                <h2>Frequently Asked Questions</h2>
                <div class="faq-list">
                    <details class="faq-item">
                        <summary>How do I create a group?</summary>
                        <p>Go to the Groups page from the sidebar, click on "Create Group", fill in the details like community name and category, and hit submit.</p>
                    </details>
                    <details class="faq-item">
                        <summary>Why can't I post in a group?</summary>
                        <p>If you are a regular member, the group administrator may have disabled posts for non-admins in the community settings.</p>
                    </details>
                    <details class="faq-item">
                        <summary>How do I change my profile picture?</summary>
                        <p>Go to your profile page, hover over your current avatar, and click the camera icon to upload a new one.</p>
                    </details>
                    <details class="faq-item">
                        <summary>How do I report a user?</summary>
                        <p>Navigate to the user's profile, click the three-dot menu icon, and select "Report User". Follow the prompts to provide details.</p>
                    </details>
                    <details class="faq-item">
                        <summary>Why is my media not uploading?</summary>
                        <p>Ensure your file is a common format (JPEG, PNG, MP4) and under the maximum size limit of 10MB.</p>
                    </details>
                </div>
            </div>

            <div class="support-bottom-grid">
                <!-- System Status -->
                <div class="system-status">
                    <h2>System Status</h2>
                    <div class="status-box">
                        <div class="status-item">
                            <span><i class="fas fa-server"></i> API Services</span>
                            <span class="status-badge ok">Operational <i class="fas fa-check-circle"></i></span>
                        </div>
                        <div class="status-item">
                            <span><i class="fas fa-cloud-upload-alt"></i> Media Uploads</span>
                            <span class="status-badge ok">Operational <i class="fas fa-check-circle"></i></span>
                        </div>
                        <div class="status-item">
                            <span><i class="fas fa-comments"></i> Messaging</span>
                            <span class="status-badge ok">Operational <i class="fas fa-check-circle"></i></span>
                        </div>
                    </div>
                </div>

                <!-- Contact Support Form -->
                <div class="support-form-container glass-card">
                    <h2>Contact Support</h2>
                    <p>Couldn't find what you need? Send us a message.</p>
                    <form id="supportForm">
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" name="name" class="glass-input" placeholder="Your name" required />
                        </div>
                        <div class="form-group">
                            <label>Email Address</label>
                            <input type="email" name="email" class="glass-input" placeholder="Your email" required value="<%= user ? user.email : '' %>" />
                        </div>
                        <div class="form-group">
                            <label>Issue Type</label>
                            <select name="type" class="glass-input" required>
                                <option value="" disabled selected>Select an issue type...</option>
                                <option value="Account">Account Issues</option>
                                <option value="Billing">Billing & Payments</option>
                                <option value="Bug">Bug Report</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Message</label>
                            <textarea name="message" class="glass-input" placeholder="Describe your issue in detail" required></textarea>
                        </div>
                        <button type="submit" class="btn-sparkle" id="submitSupportBtn">Submit Request</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        document.getElementById("supportForm").addEventListener("submit", async (e) => {
            e.preventDefault();
            
            const btn = document.getElementById("submitSupportBtn");
            const originalText = btn.textContent;
            btn.textContent = "Submitting...";
            btn.disabled = true;

            const formData = new FormData(e.target);
            const payload = Object.fromEntries(formData);
            
            try {
                const res = await fetch("/api/support", {
                    method: "POST",
                    body: JSON.stringify(payload),
                    headers: {
                        "Content-Type": "application/json"
                    }
                });
                
                const data = await res.json();
                
                if (data.success) {
                    alert("Support request sent successfully! We will get back to you soon.");
                    e.target.reset();
                } else {
                    alert("Error: " + (data.error || "Failed to submit request"));
                }
            } catch (err) {
                console.error(err);
                alert("A network error occurred.");
            } finally {
                btn.textContent = originalText;
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>
