<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Sparkle Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: #f0f2f5; color: #1a1a1a; }
        .admin-layout { display: flex; min-height: 100vh; }
        .admin-main { flex: 1; overflow-y: auto; }
        .admin-content { padding: 30px; max-width: 1400px; margin: 0 auto; }
        
        h1 { font-size: 28px; font-weight: 800; margin-bottom: 24px; letter-spacing: -0.5px; }
        
        .card { background: #fff; border-radius: 14px; box-shadow: 0 2px 8px rgba(0, 0, 0, .04); margin-bottom: 24px; overflow: hidden; }
        .card-header { padding: 18px 22px; border-bottom: 1px solid #f0f0f0; font-size: 17px; font-weight: 700; display: flex; justify-content: space-between; align-items: center; }
        
        table { width: 100%; border-collapse: collapse; }
        th { padding: 12px 18px; text-align: left; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; color: #888; background: #fafafa; }
        td { padding: 14px 18px; border-top: 1px solid #f5f5f5; font-size: 14px; }
        
        .avatar-sm { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; margin-right: 12px; vertical-align: middle; }
        
        .btn { padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
        .btn-primary { background: #0066ff; color: #fff; }
        .btn-primary:hover { background: #0052cc; }
        .btn-success { background: #22c55e; color: #fff; }
        .btn-success:hover { background: #16a34a; }
        .btn-danger { background: #ef4444; color: #fff; }
        .btn-danger:hover { background: #dc2626; }
        
        .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
        .badge-pending { background: #fef3c7; color: #d97706; }
        
        .id-preview { width: 120px; height: 80px; border-radius: 6px; object-fit: cover; border: 1px solid #eee; cursor: pointer; transition: transform 0.2s; }
        .id-preview:hover { transform: scale(1.05); }

        /* Modal Styles */
        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); align-items: center; justify-content: center; padding: 20px; }
        .modal-content { background: #fff; border-radius: 16px; width: 100%; max-width: 600px; overflow: hidden; position: relative; }
        .modal-header { padding: 20px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; }
        .modal-body { padding: 20px; }
        .modal-footer { padding: 15px 20px; border-top: 1px solid #f0f0f0; background: #fafafa; display: flex; justify-content: flex-end; gap: 10px; }
        
        textarea { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; resize: vertical; min-height: 100px; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="admin-layout">
        <%- include('../partials/admin-sidebar') %>

        <div class="admin-main">
            <div class="admin-content">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                    <h1>✅ Verification Requests</h1>
                    <div style="color: #666; font-size: 14px;">
                        Showing <%= requests.length %> pending requests
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">Pending Verifications</div>
                    <% if (requests.length === 0) { %>
                        <div style="padding: 60px; text-align: center;">
                            <i class="fas fa-check-double" style="font-size: 48px; color: #e0e0e0; margin-bottom: 16px; display: block;"></i>
                            <h3 style="color: #666;">All caught up!</h3>
                            <p style="color: #999; font-size: 14px;">There are no pending verification requests at the moment.</p>
                        </div>
                    <% } else { %>
                        <table>
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Email</th>
                                    <th>Submitted</th>
                                    <th>ID Document</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% requests.forEach(req => { %>
                                    <tr>
                                        <td>
                                            <div style="display: flex; align-items: center;">
                                                <img src="<%= req.avatar_url || '/uploads/avatars/default.png' %>" class="avatar-sm">
                                                <div>
                                                    <div style="font-weight: 700;"><%= req.user_name %></div>
                                                    <div style="font-size: 12px; color: #888;">@<%= req.username %></div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><%= req.email %></td>
                                        <td><%= new Date(req.created_at).toLocaleDateString() %></td>
                                        <td>
                                            <% if (req.id_document_url) { %>
                                                <img src="<%= req.id_document_url %>" class="id-preview" onclick="viewImage('<%= req.id_document_url %>')">
                                            <% } else { %>
                                                <span style="color: #999; font-style: italic;">No document</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 8px;">
                                                <button class="btn btn-success" onclick="openReviewModal('<%= req.request_id %>', 'approved')">
                                                    <i class="fas fa-check"></i> Approve
                                                </button>
                                                <button class="btn btn-danger" onclick="openReviewModal('<%= req.request_id %>', 'rejected')">
                                                    <i class="fas fa-times"></i> Reject
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Review Modal -->
    <div id="reviewModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalTitle">Review Request</h3>
                <button onclick="closeModal()" style="background: none; border: none; font-size: 20px; cursor: pointer; color: #999;">&times;</button>
            </div>
            <div class="modal-body">
                <p id="modalDescription">Add notes for this verification decision:</p>
                <textarea id="reviewNotes" placeholder="e.g., ID matches profile information..."></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal()" style="background: #eee;">Cancel</button>
                <button id="submitBtn" class="btn">Confirm Action</button>
            </div>
        </div>
    </div>

    <!-- Image Modal -->
    <div id="imageModal" class="modal" onclick="closeImageModal()">
        <img id="fullImage" style="max-width: 90%; max-height: 90%; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
    </div>

    <script>
        let currentRequestId = null;
        let currentStatus = null;

        function openReviewModal(requestId, status) {
            currentRequestId = requestId;
            currentStatus = status;
            
            const modal = document.getElementById('reviewModal');
            const title = document.getElementById('modalTitle');
            const submitBtn = document.getElementById('submitBtn');
            const notes = document.getElementById('reviewNotes');
            
            notes.value = '';
            title.innerText = status === 'approved' ? 'Approve Verification' : 'Reject Verification';
            submitBtn.className = status === 'approved' ? 'btn btn-success' : 'btn btn-danger';
            submitBtn.innerText = status === 'approved' ? 'Approve & Verify' : 'Reject Request';
            
            submitBtn.onclick = submitReview;
            modal.style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('reviewModal').style.display = 'none';
        }

        function viewImage(url) {
            const modal = document.getElementById('imageModal');
            const img = document.getElementById('fullImage');
            img.src = url;
            modal.style.display = 'flex';
        }

        function closeImageModal() {
            document.getElementById('imageModal').style.display = 'none';
        }

        async function submitReview() {
            const notes = document.getElementById('reviewNotes').value;
            const submitBtn = document.getElementById('submitBtn');
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
            
            try {
                const response = await fetch(`/admin/verifications/${currentRequestId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: currentStatus, notes })
                });
                
                const result = await response.json();
                
                if (result.status === 'success') {
                    window.location.reload();
                } else {
                    alert('Error: ' + (result.error || 'Failed to process request'));
                    submitBtn.disabled = false;
                    submitBtn.innerText = 'Confirm Action';
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An unexpected error occurred');
                submitBtn.disabled = false;
                submitBtn.innerText = 'Confirm Action';
            }
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('reviewModal');
            if (event.target == modal) closeModal();
        }
    </script>
</body>
</html>
