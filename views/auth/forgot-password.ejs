<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | Sparkle</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800;900&display=swap');
        body {
            font-family: 'Nunito Sans', sans-serif;
            background-color: #fce7f3;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
    <div class="max-w-[420px] w-full bg-white p-8 rounded-3xl shadow-2xl space-y-8 text-center animate-fade-in border border-white/50">
        
        <!-- Icon & Header -->
        <div class="space-y-4">
            <div class="w-24 h-24 bg-pink-50 rounded-[40px] flex items-center justify-center text-pink-500 mx-auto shadow-inner border-2 border-pink-100">
                <i class="fas fa-lock-open text-4xl"></i>
            </div>
            <h1 class="text-4xl font-black text-pink-900 italic tracking-tighter uppercase">Trouble Logging In?</h1>
            <p class="text-pink-400 text-xs font-bold uppercase tracking-[0.2em] px-4">
                Enter your email or username and we'll send you a pulse to get back into your account.
            </p>
        </div>

        <div id="forgot-message" class="hidden p-4 rounded-xl text-sm font-bold border-2"></div>

        <!-- Form -->
        <form id="forgotForm" class="space-y-4">
            <input type="text" id="target-identity" 
                class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-200 transition-all font-bold text-pink-900 placeholder:text-pink-300"
                placeholder="Email, Phone or Username" required>
            
            <button type="submit" id="submit-btn"
                class="w-full p-4 bg-pink-600 hover:bg-pink-700 text-white rounded-xl font-black text-lg transition-all active:scale-95 shadow-xl shadow-pink-100 uppercase tracking-widest">
                Send Reset Link
            </button>
        </form>

        <div class="relative py-4">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-pink-50"></div></div>
            <div class="relative flex justify-center text-xs uppercase"><span class="bg-white px-4 text-pink-200 font-black tracking-widest">OR</span></div>
        </div>

        <a href="/signup" class="block text-pink-900 hover:text-pink-600 font-black text-sm uppercase tracking-widest transition-colors">
            Create New Account
        </a>

        <div class="pt-8">
            <a href="/login" class="inline-block w-full p-4 bg-pink-50 text-pink-600 rounded-xl font-black transition-all hover:bg-pink-100 active:scale-95">
                Back to Login
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        document.getElementById('forgotForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const identity = document.getElementById('target-identity').value;
            const btn = document.getElementById('submit-btn');
            const msg = document.getElementById('forgot-message');

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> SENDING...';

            try {
                const res = await axios.post('/api/v1/auth/forgot-password', { email: identity });
                msg.textContent = 'Reset link sent! Check your email. ❤️';
                msg.className = 'p-4 rounded-xl text-sm font-bold border-2 bg-emerald-50 border-emerald-100 text-emerald-500 block';
                msg.classList.remove('hidden');
                btn.textContent = 'RESENT';
            } catch (err) {
                msg.textContent = err.response?.data?.message || 'Something went wrong. Try again.';
                msg.className = 'p-4 rounded-xl text-sm font-bold border-2 bg-rose-50 border-rose-100 text-rose-500 block';
                msg.classList.remove('hidden');
                btn.disabled = false;
                btn.textContent = 'SEND RESET LINK';
            }
        });
    </script>

    <style>
        .animate-fade-in {
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</body>
</html>
