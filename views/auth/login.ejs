<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log In | Sparkle</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800;900&display=swap');
        body {
            font-family: 'Nunito Sans', sans-serif;
            background-color: #fce7f3;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 md:p-8">
    <div class="max-w-6xl w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
        
        <!-- Left: Branding (Facebook Style) -->
        <div class="text-center lg:text-left space-y-6 animate-fade-in">
            <h1 class="text-6xl lg:text-7xl font-black text-pink-600 tracking-tighter italic uppercase border-b-8 border-pink-400 inline-block">SPARKLE</h1>
            <p class="text-2xl lg:text-4xl font-bold text-pink-900 leading-tight max-w-lg mt-4">
                Sparkle helps you connect and share with the people in your life.
            </p>
            <div class="hidden lg:flex flex-col gap-6 mt-12">
                <div class="flex items-center gap-5 text-pink-800 font-bold text-lg">
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-pink-500 shadow-lg">
                        <i class="fas fa-heart"></i>
                    </div>
                    <span>Share your pink moments and glow together.</span>
                </div>
                <div class="flex items-center gap-5 text-pink-800 font-bold text-lg">
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-pink-500 shadow-lg">
                        <i class="fas fa-users"></i>
                    </div>
                    <span>Build lasting friendships across campus.</span>
                </div>
            </div>
        </div>

        <!-- Right: Login Card -->
        <div class="w-full max-w-[420px] mx-auto lg:mx-0">
            <div class="bg-white p-8 rounded-2xl shadow-2xl border border-white/50 space-y-6">
                <!-- Message Box -->
                <div id="login-message" class="hidden p-3 rounded-xl text-center font-bold text-sm border-2 animate-fade-in"></div>

                <form id="loginForm" class="space-y-4">
                    <input type="text" id="login-email" 
                        class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-200 transition-all font-bold text-pink-900 placeholder:text-pink-300"
                        placeholder="Email or username" required>
                    
                    <input type="password" id="login-password" 
                        class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-200 transition-all font-bold text-pink-900 placeholder:text-pink-300"
                        placeholder="Password" required>
                    
                    <button type="submit" id="login-submit"
                        class="w-full p-4 bg-pink-600 hover:bg-pink-700 text-white rounded-xl font-black text-xl transition-all active:scale-95 shadow-xl shadow-pink-200 uppercase tracking-widest">
                        Log In
                    </button>

                    <div class="text-center">
                        <a href="/forgot-password" class="text-pink-600 hover:underline text-sm font-bold tracking-tight">Forgotten password?</a>
                    </div>

                    <div class="border-t border-pink-100 my-8"></div>

                    <div class="text-center pt-2">
                        <a href="/signup" 
                            class="inline-block px-10 py-5 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl font-black text-lg transition-all active:scale-95 shadow-xl shadow-emerald-100 uppercase tracking-widest">
                            Create New Account
                        </a>
                    </div>
                </form>

                <!-- 2FA Section (Hidden by default) -->
                <div id="twofaSection" class="hidden space-y-8 text-center animate-fade-in">
                    <div class="w-24 h-24 bg-pink-100 rounded-[32px] flex items-center justify-center text-pink-600 mx-auto shadow-inner">
                        <i class="fas fa-shield-halved text-4xl"></i>
                    </div>
                    <div>
                        <h3 class="text-3xl font-black text-pink-900 uppercase italic tracking-tighter">Pink Guard</h3>
                        <p class="text-pink-400 text-xs font-black uppercase tracking-[0.2em] mt-2 px-6">
                            Security Pulse. Enter the 6-digit PIN for <span id="twofaEmail" class="text-pink-600"></span>
                        </p>
                    </div>
                    
                    <div class="flex justify-center gap-2" id="pinContainer">
                        <input type="text" maxlength="1" class="pin-input w-11 h-16 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all shadow-sm">
                        <input type="text" maxlength="1" class="pin-input w-11 h-16 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all shadow-sm">
                        <input type="text" maxlength="1" class="pin-input w-11 h-16 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all shadow-sm">
                        <input type="text" maxlength="1" class="pin-input w-11 h-16 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all shadow-sm">
                        <input type="text" maxlength="1" class="pin-input w-11 h-16 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all shadow-sm">
                        <input type="text" maxlength="1" class="pin-input w-11 h-16 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all shadow-sm">
                    </div>

                    <button type="button" id="verifyPinBtn"
                        class="w-full p-5 bg-pink-600 text-white rounded-xl font-black text-lg transition-all active:scale-95 shadow-xl shadow-pink-100 uppercase tracking-widest">
                        Confirm Pulse
                    </button>

                    <button id="backToLogin" class="text-pink-300 hover:text-pink-600 font-black text-[10px] uppercase tracking-[0.3em] mt-4">
                        Nevermind
                    </button>
                </div>
            </div>
            
            <p class="text-center mt-12 text-pink-900 font-bold text-sm">
                <span class="text-pink-600 hover:underline cursor-pointer">Create a Page</span> for a celebrity, brand or business.
            </p>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const loginForm = document.getElementById('loginForm');
            const twofaSection = document.getElementById('twofaSection');
            const loginMessage = document.getElementById('login-message');

            const showMessage = (msg, type) => {
                loginMessage.textContent = msg;
                loginMessage.className = `p-4 rounded-xl text-sm font-bold text-center border-2 mb-6 block animate-fade-in ${type === 'error' ? 'bg-rose-50 border-rose-100 text-rose-500' : 'bg-emerald-50 border-emerald-100 text-emerald-500'}`;
                loginMessage.classList.remove('hidden');
            };

            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const username = document.getElementById('login-email').value;
                const password = document.getElementById('login-password').value;
                const btn = document.getElementById('login-submit');

                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> LOGGING IN...';

                try {
                    const res = await axios.post('/api/v1/auth/login', { username, password });
                    const data = res.data;
                    
                    if (data.status === 'twofa_required' || data.status === 'requires_2fa') {
                        window.twofaUserId = data.userId || data.id;
                        loginForm.classList.add('hidden');
                        document.getElementById('twofaEmail').textContent = data.email || 'your device';
                        twofaSection.classList.remove('hidden');
                        return;
                    }

                    if (data.status === 'success' || data.token) {
                        // Store in local storage
                        localStorage.setItem('sparkleToken', data.token);
                        localStorage.setItem('sparkleUser', JSON.stringify(data.user));
                        
                        showMessage('Welcome back! ❤️', 'success');
                        setTimeout(() => window.location.href = '/dashboard', 1000);
                    } else {
                        throw new Error(data.message || 'Login failed');
                    }
                } catch (err) {
                    showMessage(err.response?.data?.message || err.message, 'error');
                    btn.disabled = false;
                    btn.textContent = 'LOG IN';
                }
            });

            // PIN logic
            const pins = document.querySelectorAll('.pin-input');
            pins.forEach((p, idx) => {
                p.addEventListener('input', () => {
                    p.value = p.value.replace(/[^0-9]/g, '');
                    if (p.value && idx < pins.length - 1) pins[idx+1].focus();
                });
                p.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !p.value && idx > 0) pins[idx-1].focus();
                });
            });

            document.getElementById('verifyPinBtn').addEventListener('click', async () => {
                const pin = Array.from(pins).map(p => p.value).join('');
                if (pin.length < 6) return alert('Enter full PIN');
                
                const btn = document.getElementById('verifyPinBtn');
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> VERIFYING...';

                try {
                    const res = await axios.post('/api/v1/auth/2fa/verify', { 
                        userId: window.twofaUserId, 
                        pin: pin 
                    });
                    const data = res.data;
                    
                    localStorage.setItem('sparkleToken', data.token);
                    localStorage.setItem('sparkleUser', JSON.stringify(data.user));
                    window.location.href = '/dashboard';
                } catch (err) {
                    alert(err.response?.data?.message || err.message);
                    btn.disabled = false;
                    btn.textContent = 'CONFIRM PULSE';
                    pins.forEach(p => p.value = '');
                    pins[0].focus();
                }
            });

            document.getElementById('backToLogin').addEventListener('click', () => {
                twofaSection.classList.add('hidden');
                loginForm.classList.remove('hidden');
                document.getElementById('login-submit').disabled = false;
                document.getElementById('login-submit').textContent = 'LOG IN';
            });
        });
    </script>
    
    <style>
        .animate-fade-in {
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</body>
</html>