<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up | Sparkle</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800;900&display=swap');
        body {
            font-family: 'Nunito Sans', sans-serif;
            background-color: #fce7f3;
        }
        .step-active { @apply bg-pink-600 text-white border-pink-600; }
        .step-completed { @apply bg-emerald-500 text-white border-emerald-500; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 md:p-8">
    <div class="max-w-6xl w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
        
        <!-- Left: Branding -->
        <div class="text-center lg:text-left space-y-6 animate-fade-in">
            <h1 class="text-6xl lg:text-7xl font-black text-pink-600 tracking-tighter italic uppercase border-b-8 border-pink-400 inline-block cursor-pointer" onclick="window.location.href='/'">SPARKLE</h1>
            <p class="text-2xl lg:text-4xl font-bold text-pink-900 leading-tight max-w-lg mt-4">
                Join Sparkle to find your friends and glow together in the campus network.
            </p>
            <div class="hidden lg:flex flex-col gap-6 mt-12">
                <div class="flex items-center gap-5 text-pink-800 font-bold text-lg">
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-pink-500 shadow-lg">
                        <i class="fas fa-camera-retro"></i>
                    </div>
                    <span>Share your pink moments with specific campus groups.</span>
                </div>
                <div class="flex items-center gap-5 text-pink-800 font-bold text-lg">
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-pink-500 shadow-lg">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <span>Discover new spots and lovely friendships daily.</span>
                </div>
            </div>
        </div>

        <!-- Right: Signup Multi-Step Card -->
        <div class="w-full max-w-[480px] mx-auto lg:mx-0">
            <div class="bg-white p-8 rounded-2xl shadow-2xl border border-white/50 space-y-8 min-h-[520px] flex flex-col justify-center">
                
                <!-- Progress Header -->
                <div class="flex items-center justify-center gap-3" id="progress-bar">
                    <div class="w-8 h-8 rounded-full border-2 border-pink-100 flex items-center justify-center text-xs font-black step-node active" data-step="1">1</div>
                    <div class="w-8 h-1 bg-pink-50 step-line" data-line="1"></div>
                    <div class="w-8 h-8 rounded-full border-2 border-pink-100 flex items-center justify-center text-xs font-black step-node" data-step="2">2</div>
                    <div class="w-8 h-1 bg-pink-50 step-line" data-line="2"></div>
                    <div class="w-8 h-8 rounded-full border-2 border-pink-100 flex items-center justify-center text-xs font-black step-node" data-step="3">3</div>
                </div>

                <div id="signup-message" class="hidden p-4 rounded-xl text-center font-bold text-sm border-2 animate-fade-in"></div>

                <!-- Panels -->
                <div class="relative overflow-visible" id="panels-container">
                    
                    <!-- Step 1: Basics -->
                    <div class="step-panel space-y-4" id="panel-1">
                        <div class="text-center pb-4">
                            <h2 class="text-3xl font-black text-pink-900 italic tracking-tighter uppercase">Start Your Glow</h2>
                            <p class="text-pink-400 text-xs font-bold uppercase tracking-widest mt-1">First, the essential details.</p>
                        </div>
                        <input type="text" id="reg-name" class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-100 font-bold text-pink-950 placeholder:text-pink-300" placeholder="Display Name">
                        <input type="text" id="reg-username" class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-100 font-bold text-pink-950 placeholder:text-pink-300" placeholder="Username">
                        <input type="email" id="reg-email" class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-100 font-bold text-pink-950 placeholder:text-pink-300" placeholder="Email Address">
                        <button onclick="nav(2)" class="w-full p-4 bg-pink-600 text-white rounded-xl font-black text-lg transition-all active:scale-95 shadow-xl shadow-pink-100 uppercase tracking-widest mt-4">Continue</button>
                    </div>

                    <!-- Step 2: Security & Profile -->
                    <div class="step-panel hidden space-y-4" id="panel-2">
                        <div class="text-center pb-4">
                            <h2 class="text-3xl font-black text-pink-900 italic tracking-tighter uppercase">Secure Pulse</h2>
                            <p class="text-pink-400 text-xs font-bold uppercase tracking-widest mt-1">Password and verification bits.</p>
                        </div>
                        <input type="password" id="reg-pass" class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-100 font-bold text-pink-950 placeholder:text-pink-300" placeholder="Create Secret Key">
                        <input type="tel" id="reg-phone" class="w-full p-4 bg-pink-50 border-2 border-pink-100 rounded-xl focus:outline-none focus:ring-4 focus:ring-pink-100 font-bold text-pink-950 placeholder:text-pink-300" placeholder="Phone Number (+254...)">
                        <div class="flex gap-4">
                            <button onclick="nav(1)" class="flex-1 p-4 bg-white border-2 border-pink-100 text-pink-300 rounded-xl font-black text-lg transition-all active:scale-95 uppercase tracking-widest">Back</button>
                            <button onclick="nav(3)" class="flex-[2] p-4 bg-pink-600 text-white rounded-xl font-black text-lg transition-all active:scale-95 shadow-xl shadow-pink-100 uppercase tracking-widest">Almost There</button>
                        </div>
                    </div>

                    <!-- Step 3: Verification -->
                    <div class="step-panel hidden space-y-6 text-center" id="panel-3">
                        <div class="w-24 h-24 bg-pink-50 rounded-[32px] flex items-center justify-center text-pink-400 mx-auto shadow-inner border border-pink-100">
                            <i class="fas fa-shield-heart text-4xl"></i>
                        </div>
                        <h2 class="text-3xl font-black text-pink-900 italic tracking-tighter uppercase">One Last Check</h2>
                        <p class="text-pink-400 text-xs font-black uppercase tracking-widest">Enter the 6-digit code sent to your phone.</p>
                        <div class="flex justify-center gap-2">
                            <input type="text" maxlength="1" class="v-pin w-11 h-14 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all">
                            <input type="text" maxlength="1" class="v-pin w-11 h-14 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all">
                            <input type="text" maxlength="1" class="v-pin w-11 h-14 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all">
                            <input type="text" maxlength="1" class="v-pin w-11 h-14 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all">
                            <input type="text" maxlength="1" class="v-pin w-11 h-14 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all">
                            <input type="text" maxlength="1" class="v-pin w-11 h-14 bg-pink-50 border-2 border-pink-100 rounded-xl text-center text-2xl font-black text-pink-600 focus:border-pink-400 outline-none transition-all">
                        </div>
                        <button id="final-btn" class="w-full p-5 bg-emerald-500 text-white rounded-xl font-black text-lg transition-all active:scale-95 shadow-xl shadow-emerald-100 uppercase tracking-widest">Finalize Glow</button>
                        <button onclick="nav(2)" class="text-pink-200 hover:text-pink-400 font-black text-[10px] uppercase tracking-widest">Wait, go back</button>
                    </div>

                </div>

                <div class="border-t border-pink-50 pt-6 text-center">
                    <p class="text-pink-300 font-bold text-sm">Already sparkling? <a href="/login" class="text-pink-600 hover:underline">Log In</a></p>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        let currentStep = 1;
        const totalSteps = 3;

        function nav(step) {
            if (step < 1 || step > totalSteps) return;
            
            // Validate step 1 before going to 2
            if (step === 2 && currentStep === 1) {
                const name = document.getElementById('reg-name').value;
                const user = document.getElementById('reg-username').value;
                const email = document.getElementById('reg-email').value;
                if (!name || !user || !email) return alert('Please fill in base details');
            }

            document.querySelectorAll('.step-panel').forEach(p => p.classList.add('hidden'));
            document.getElementById(`panel-${step}`).classList.remove('hidden');
            
            // Update progress bar
            document.querySelectorAll('.step-node').forEach((n, idx) => {
                const sIdx = idx + 1;
                n.classList.remove('bg-pink-600', 'text-white', 'border-pink-600', 'bg-emerald-500', 'border-emerald-500');
                if (sIdx === step) n.classList.add('bg-pink-600', 'text-white', 'border-pink-600');
                else if (sIdx < step) n.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500');
            });
            
            currentStep = step;
        }

        // Finalize logic
        document.getElementById('final-btn').addEventListener('click', async () => {
            const pin = Array.from(document.querySelectorAll('.v-pin')).map(p => p.value).join('');
            if (pin.length < 6) return alert('Enter full verification pin');

            const btn = document.getElementById('final-btn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> GLOWING UP...';

            try {
                const payload = {
                    name: document.getElementById('reg-name').value,
                    username: document.getElementById('reg-username').value,
                    email: document.getElementById('reg-email').value,
                    password: document.getElementById('reg-pass').value,
                    phone: document.getElementById('reg-phone').value,
                    otp: pin
                };
                
                const res = await axios.post('/api/v1/auth/signup', payload);
                if (res.data.status === 'success' || res.data.token) {
                    localStorage.setItem('sparkleToken', res.data.token);
                    localStorage.setItem('sparkleUser', JSON.stringify(res.data.user));
                    window.location.href = '/dashboard';
                }
            } catch (err) {
                alert(err.response?.data?.message || err.message);
                btn.disabled = false;
                btn.textContent = 'FINALIZE GLOW';
            }
        });

        // PIN behavior
        const pins = document.querySelectorAll('.v-pin');
        pins.forEach((p, idx) => {
            p.addEventListener('input', () => {
                p.value = p.value.replace(/[^0-9]/g, '');
                if (p.value && idx < pins.length - 1) pins[idx+1].focus();
            });
            p.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !p.value && idx > 0) pins[idx-1].focus();
            });
        });
    </script>

    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
</body>
</html>