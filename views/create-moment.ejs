<%- include('partials/head', { title: 'Sparkle - Create Moment' }) %>
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
    <style>
        :root {
            --bg-dark: #000;
            --accent-pink: #FF3D6D;
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.15);
            --text-primary: #fff;
            --text-secondary: #aaa;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            padding: 20px;
            padding-top: max(20px, env(safe-area-inset-top));
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 10;
        }

        .back-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 18px;
        }

        .header-title {
            font-size: 18px;
            font-weight: 700;
        }

        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        /* Preview Zone */
        .preview-container {
            width: 100%;
            aspect-ratio: 9/16;
            background: #111;
            border-radius: 20px;
            border: 2px dashed var(--glass-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .preview-container:active {
            transform: scale(0.98);
        }

        .preview-container.has-media {
            border-style: solid;
            border-color: var(--accent-pink);
        }

        .preview-icon {
            font-size: 40px;
            color: var(--accent-pink);
            margin-bottom: 15px;
        }

        .preview-text {
            color: var(--text-secondary);
            font-size: 14px;
            text-align: center;
        }

        #mediaPreview {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

        /* Form Controls */
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .label {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-left: 5px;
        }

        .caption-input {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 15px;
            padding: 15px;
            color: white;
            font-family: inherit;
            font-size: 16px;
            resize: none;
            width: 100%;
            min-height: 100px;
            outline: none;
            transition: border-color 0.3s;
        }

        .caption-input:focus {
            border-color: var(--accent-pink);
        }

        .category-select {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding-bottom: 5px;
            scrollbar-width: none;
        }

        .category-select::-webkit-scrollbar {
            display: none;
        }

        .cat-chip {
            padding: 10px 20px;
            border-radius: 25px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            white-space: nowrap;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .cat-chip.active {
            background: var(--accent-pink);
            border-color: var(--accent-pink);
        }

        /* Floating Button */
        .footer {
            padding: 20px;
            padding-bottom: max(20px, env(safe-area-inset-bottom));
        }

        .spark-btn {
            width: 100%;
            padding: 18px;
            border-radius: 30px;
            background: var(--accent-pink);
            color: white;
            border: none;
            font-size: 16px;
            font-weight: 800;
            letter-spacing: 0.5px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(255, 61, 109, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: transform 0.2s;
        }

        .spark-btn:active {
            transform: scale(0.96);
        }

        .spark-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        #fileInput {
            display: none;
        }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
            gap: 20px;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid var(--glass-border);
            border-top-color: var(--accent-pink);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>

    <div class="header">
        <a href="/moments" class="back-btn">
            <i class="fas fa-chevron-left"></i>
        </a>
        <div class="header-title">New Moment</div>
        <div style="width: 40px;"></div> <!-- Spacer -->
    </div>

    <form id="createMomentForm" class="main-content">
        <!-- Media Dropzone -->
        <div class="preview-container" id="dropzone" onclick="document.getElementById('fileInput').click()">
            <div id="emptyState">
                <div class="preview-icon"><i class="fas fa-cloud-upload-alt"></i></div>
                <div class="preview-text">Tap to upload video or photo<br><span style="font-size:12px;opacity:0.6;">MP4,
                        JPG, PNG up to 10MB</span></div>
            </div>
            <video id="mediaPreview" muted loop playsinline></video>
            <img id="imagePreview" style="display:none; width:100%; height:100%; object-fit:cover;">
            <input type="file" id="fileInput" name="media" accept="video/*,image/*">
        </div>

        <!-- Caption -->
        <div class="form-group">
            <span class="label">Caption</span>
            <textarea class="caption-input" id="caption" name="caption"
                placeholder="What's happening? Add #hashtags..."></textarea>
        </div>

        <!-- Category -->
        <div class="form-group">
            <span class="label">Category</span>
            <div class="category-select" id="categorySelect">
                <div class="cat-chip active" data-value="general">General</div>
                <div class="cat-chip" data-value="entertainment">Entertainment</div>
                <div class="cat-chip" data-value="sports">Sports</div>
                <div class="cat-chip" data-value="lifestyle">Lifestyle</div>
                <div class="cat-chip" data-value="music">Music</div>
                <div class="cat-chip" data-value="tech">Tech</div>
            </div>
            <input type="hidden" name="category" id="categoryInput" value="general">
        </div>
    </form>

    <div class="footer">
        <button type="button" class="spark-btn" id="submitBtn">
            <i class="fas fa-bolt"></i>
            SPARK MOMENT
        </button>
    </div>

    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner"></div>
        <div id="loadingText">Sparks are flying...</div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const fileInput = document.getElementById('fileInput');
            const dropzone = document.getElementById('dropzone');
            const videoPreview = document.getElementById('mediaPreview');
            const imagePreview = document.getElementById('imagePreview');
            const emptyState = document.getElementById('emptyState');
            const categoryChips = document.querySelectorAll('.cat-chip');
            const categoryInput = document.getElementById('categoryInput');
            const submitBtn = document.getElementById('submitBtn');
            const loadingOverlay = document.getElementById('loadingOverlay');

            // Handle file selection
            fileInput.onchange = (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const url = URL.createObjectURL(file);

                if (file.type.startsWith('video/')) {
                    videoPreview.src = url;
                    videoPreview.style.display = 'block';
                    imagePreview.style.display = 'none';
                    videoPreview.play();
                } else if (file.type.startsWith('image/')) {
                    imagePreview.src = url;
                    imagePreview.style.display = 'block';
                    videoPreview.style.display = 'none';
                    videoPreview.pause();
                }

                emptyState.style.display = 'none';
                dropzone.classList.add('has-media');
            };

            // Handle categories
            categoryChips.forEach(chip => {
                chip.onclick = () => {
                    categoryChips.forEach(c => c.classList.remove('active'));
                    chip.classList.add('active');
                    categoryInput.value = chip.dataset.value;
                };
            });

            // Submit logic
            submitBtn.onclick = async () => {
                const file = fileInput.files[0];
                if (!file) {
                    alert('Please select a video or image first!');
                    return;
                }

                loadingOverlay.style.display = 'flex';
                submitBtn.disabled = true;

                const formData = new FormData();
                formData.append('media', file);
                formData.append('caption', document.getElementById('caption').value);
                formData.append('category', categoryInput.value);

                try {
                    const response = await fetch('/api/moments', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'Authorization': 'Bearer ' + localStorage.getItem('sparkleToken')
                        }
                    });

                    const result = await response.json();
                    if (response.ok) {
                        window.location.href = '/moments';
                    } else {
                        throw new Error(result.error || 'Failed to create moment');
                    }
                } catch (err) {
                    alert(err.message);
                    loadingOverlay.style.display = 'none';
                    submitBtn.disabled = false;
                }
            };
        });
    </script>
    </body>

    </html>