    <script>
        // Lightbox state
        let currentLightboxImages = [];
        let currentLightboxIndex = 0;

        function openLightbox(listingId, index, event) {
            if (event) event.stopPropagation();
            const listing = listingsMap[listingId];
            if (!listing || !listing.media || listing.media.length === 0) {
                // Fallback to main image
                currentLightboxImages = [listing.image_url || '/images/default-listing.jpg'];
            } else {
                currentLightboxImages = listing.media.map(m => m.media_url);
            }
            
            currentLightboxIndex = index || 0;
            updateLightbox();
            document.getElementById('lightbox').style.display = 'flex';
            document.body.style.overflow = 'hidden'; // Prevent scroll
        }

        function closeLightbox() {
            document.getElementById('lightbox').style.display = 'none';
            document.body.style.overflow = '';
        }

        function changeLightboxImage(dir) {
            currentLightboxIndex = (currentLightboxIndex + dir + currentLightboxImages.length) % currentLightboxImages.length;
            updateLightbox();
        }

        function updateLightbox() {
            const img = document.getElementById('lightboxImage');
            const info = document.getElementById('lightboxInfo');
            img.src = currentLightboxImages[currentLightboxIndex];
            info.textContent = `Image ${currentLightboxIndex + 1} of ${currentLightboxImages.length}`;
        }

        // Touch support for swiping
        let touchStartX = 0;
        let touchEndX = 0;

        document.getElementById('lightbox').addEventListener('touchstart', e => {
            touchStartX = e.changedTouches[0].screenX;
        });

        document.getElementById('lightbox').addEventListener('touchend', e => {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipe();
        });

        function handleSwipe() {
            const threshold = 50;
            if (touchEndX < touchStartX - threshold) changeLightboxImage(1); // Swipe Left
            if (touchEndX > touchStartX + threshold) changeLightboxImage(-1); // Swipe Right
        }

        // Keyboard support
        document.addEventListener('keydown', (e) => {
            if (document.getElementById('lightbox').style.display === 'flex') {
                if (e.key === 'Escape') closeLightbox();
                if (e.key === 'ArrowLeft') changeLightboxImage(-1);
                if (e.key === 'ArrowRight') changeLightboxImage(1);
            }
        });
    </script>
    <!-- Wishlist Modal -->
    <div id="wishlistModal" class="modal-overlay" style="display: none;">
        <div class="modal-container wishlist-modal">
            <div class="modal-header">
                <h2><i class="bi bi-heart-fill" style="color: #ef4444;"></i> Saved Wishlist</h2>
                <div class="modal-header-actions">
                    <button class="marketplace-msg-btn" onclick="window.location.href='/messages?tab=marketplace'" title="Marketplace Messages">
                        <i class="bi bi-chat-dots-fill"></i>
                    </button>
                    <button class="close-modal" onclick="closeWishlist()">&times;</button>
                </div>
            </div>
            <div class="wishlist-body">
                <div id="wishlistItems" class="wishlist-grid">
                    <!-- Wishlist items will be loaded here -->
                </div>
            </div>
        </div>
    </div>

    <!-- Styles for Wishlist -->
    <style>
        .wishlist-modal { max-width: 600px; width: 90%; border-radius: 20px; overflow: hidden; }
        .wishlist-grid { display: grid; grid-template-columns: 1fr; gap: 12px; max-height: 70vh; overflow-y: auto; padding: 10px; }
        .wishlist-item { display: flex; align-items: center; gap: 15px; padding: 12px; background: #f8fafc; border-radius: 12px; cursor: pointer; transition: 0.2s; position: relative; }
        .wishlist-item:hover { background: #f1f5f9; transform: translateX(5px); }
        .wishlist-img { width: 70px; height: 70px; border-radius: 10px; object-fit: cover; }
        .wishlist-info h3 { margin: 0; font-size: 15px; font-weight: 700; color: #1e293b; }
        .wishlist-info p { margin: 4px 0 0; font-weight: 800; color: var(--primary); }
        .wishlist-remove-btn { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer; padding: 8px; border-radius: 50%; transition: 0.2s; }
        .wishlist-remove-btn:hover { background: #fee2e2; color: #ef4444; }
        .marketplace-msg-btn { background: #f1f5f9; border: none; width: 40px; height: 40px; border-radius: 12px; color: #6366f1; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; margin-right: 10px; transition: 0.2s; }
        .marketplace-msg-btn:hover { background: #6366f1; color: white; }
    </style>
    <div id="toast" class="toast"></div>
</body>
</html>