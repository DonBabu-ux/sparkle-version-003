        async function sendQuickMessage(listingId) {
            const listing = listingsMap[listingId];
            if (!listing) return;
            
            const text = "Is this still available?";
            
            // Show optimistic feedback
            showToast("Opening chat...");

            // Prepare rich card payload for chat
            const host = window.location.origin;
            const mktPayload = {
                title: listing.title,
                price: `KES ${new Intl.NumberFormat('en-KE').format(listing.price)}`,
                image: listing.image_url || (listing.media && listing.media[0]?.media_url) || '/images/default-listing.jpg',
                link: `${host}/marketplace/listings/${listingId}`,
                initialMessage: text
            };
            
            // Encode and navigate to chat
            const mktEncoded = btoa(encodeURIComponent(JSON.stringify(mktPayload)));
            window.location.href = `/messages/?user=${listing.seller_id}&mkt=${mktEncoded}&autoSend=true`;
        }

        function openMessenger(userId, listingId = null) {
            let url = `/messages/?user=${userId}`;
            if (listingId) url += `&listing=${listingId}`;
            window.location.href = url;
        }

        function startChat(listingId) {
            const listing = listingsMap[listingId];
            if (!listing) { window.location.href = '/messages'; return; }
            
            const host = window.location.origin;
            const mktPayload = {
                title: listing.title,
                price: `KES ${new Intl.NumberFormat('en-KE').format(listing.price)}`,
                image: listing.image_url || (listing.media && listing.media[0]?.media_url) || '/images/default-listing.jpg',
                link: `${host}/marketplace/listings/${listingId}`
            };
            
            // Base64-encode structured payload so chat page renders it as a rich product card
            const mktEncoded = btoa(encodeURIComponent(JSON.stringify(mktPayload)));
            window.location.href = `/messages/?user=${listing.seller_id}&mkt=${mktEncoded}`;
        }

        let selectedListingId = null;

        function showOptions(listingId) {
            selectedListingId = listingId;
            const listing = listingsMap[listingId];
            if (!listing) return;

            // Determine if current user is the owner
            const currentUserId = currentUser ? (currentUser.user_id || currentUser.id) : null;
            const isOwner = currentUserId && listing.seller_id === currentUserId;

            // Toggle visibility based on ownership
            document.getElementById('optionReport').style.display = isOwner ? 'none' : 'flex';
            document.getElementById('optionHide').style.display = isOwner ? 'none' : 'flex';
            
            document.getElementById('optionBoost').style.display = isOwner ? 'flex' : 'none';
            document.getElementById('optionSold').style.display = (isOwner && !listing.is_sold) ? 'flex' : 'none';
            document.getElementById('optionDelete').style.display = isOwner ? 'flex' : 'none';

            // Setup option handlers
            document.getElementById('optionViewProfile').onclick = () => {
                closeOptionsModal();
                window.location.href = `/marketplace/profile/${listing.seller_id}`;
            };

            document.getElementById('optionCopyLink').onclick = () => {
                closeOptionsModal();
                const link = `${window.location.origin}/marketplace/listings/${listingId}`;
                navigator.clipboard.writeText(link).then(() => {
                    showToast('Listing link copied!', 'success');
                });
            };

            document.getElementById('optionShare').onclick = () => {
                closeOptionsModal();
                shareListing(listingId);
            };

            document.getElementById('optionReport').onclick = () => {
                closeOptionsModal();
                openReportModal(listingId);
            };

            document.getElementById('optionEvents').onclick = () => {
                closeOptionsModal();
                window.location.href = `/events/?listing=${listingId}`;
            };

            document.getElementById('optionHide').onclick = () => {
                closeOptionsModal();
                hideListing(listingId);
            };

            // Seller Action Handlers
            document.getElementById('optionBoost').onclick = () => {
                closeOptionsModal();
                boostListing(listingId);
            };

            document.getElementById('optionSold').onclick = () => {
                closeOptionsModal();
                if (confirm('Are you sure you want to mark this item as sold?')) {
                    markAsSold(listingId);
                }
            };

            document.getElementById('optionDelete').onclick = () => {
                closeOptionsModal();
                if (confirm('Are you sure you want to delete this listing permanently? This action cannot be undone.')) {
                    deleteListing(listingId);
                }
            };

            document.getElementById('optionsModal').style.display = 'flex';
        }

        function closeOptionsModal() {
            document.getElementById('optionsModal').style.display = 'none';
        }

        // Close options modal when clicking outside
        window.addEventListener('click', (event) => {
            const modal = document.getElementById('optionsModal');
            if (event.target === modal) {
                closeOptionsModal();
            }
            // Also for other modals if they don't have it
            const reportModal = document.getElementById('reportModal');
            if (event.target === reportModal) {
                closeReportModal();
            }
        });

        function shareListing(listingId) {
            const listing = listingsMap[listingId];
            const title = listing ? listing.title : 'Check out this item on Sparkle!';
            const url = `${window.location.origin}/marketplace/listings/${listingId}`;

            if (navigator.share) {
                navigator.share({
                    title: title,
                    text: `KES ${new Intl.NumberFormat('en-KE').format(listing.price)} - ${title}`,
                    url: url
                }).catch(() => {});
            } else {
                // Fallback: Copy link
                navigator.clipboard.writeText(url).then(() => {
                    showToast('Link copied to clipboard!');
                });
            }
        }

        function openReportModal(listingId) {
            selectedListingId = listingId;
            document.getElementById('reportModal').style.display = 'flex';
            
            const reportReasons = document.querySelectorAll('.report-reason');
            reportReasons.forEach(btn => {
                btn.onclick = () => {
                    const reason = btn.dataset.reason;
                    submitReport(listingId, reason);
                };
            });
        }

        function closeReportModal() {
            document.getElementById('reportModal').style.display = 'none';
        }

        async function submitReport(listingId, reason) {
            try {
                const response = await fetch(`${API_BASE_URL}/listings/${listingId}/report`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        reason, 
                        _csrf: '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>' 
                    })
                });
                if (response.ok) {
                    showToast('Listing reported. Thank you for keeping Sparkle safe!', 'success');
                    closeReportModal();
                }
            } catch (err) {
                showToast('Failed to submit report');
            }
        }

        function hideListing(listingId) {
            const card = document.querySelector(`.product-card[onclick*="viewListing('${listingId}')"]`) || 
                         document.querySelector(`div[data-id="${listingId}"]`);
            if (card) {
                card.style.transition = 'opacity 0.3s, transform 0.3s';
                card.style.opacity = '0';
                card.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    card.remove();
                    showToast('Listing hidden from your view');
                }, 300);
            }
        }

        async function markAsSold(listingId) {
            try {
                const response = await fetch(`${API_BASE_URL}/listings/${listingId}/sold`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
                    }
                });
                const result = await response.json();
                if (result.success) {
                    showToast('Item marked as sold!', 'success');
                    // Update local map and visual
                    if (listingsMap[listingId]) listingsMap[listingId].is_sold = 1;
                    fetchListings(); // Refresh UI
                } else {
                    showToast(result.error || 'Failed to update item');
                }
            } catch (err) {
                showToast('Network error occurred');
            }
        }

        async function boostListing(listingId) {
            try {
                const response = await fetch(`${API_BASE_URL}/listings/${listingId}/boost`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
                    }
                });
                const result = await response.json();
                if (result.success) {
                    showToast('Listing boosted successfully! 🚀', 'success');
                    fetchTrending(); // Refresh trending section
                } else {
                    showToast(result.error || 'Failed to boost listing');
                }
            } catch (err) {
                showToast('Boost failed. Try again later.');
            }
        }

        async function deleteListing(listingId) {
            try {
                const response = await fetch(`${API_BASE_URL}/listings/${listingId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
                    }
                });
                const result = await response.json();
                if (result.success) {
                    showToast('Listing deleted successfully', 'success');
                    hideListing(listingId); // Remove from view
                } else {
                    showToast(result.error || 'Failed to delete listing');
                }
            } catch (err) {
                showToast('Deletion failed');
            }
        }

        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            if (!toast) {
                // Fallback to alert if toast element not found
                console.log('Toast:', message);
                return;
            }
            
            toast.textContent = message;
            toast.style.display = 'block';
            toast.style.animation = 'fadeIn 0.3s';
            toast.style.background = type === 'error' ? '#ef4444' : (type === 'success' ? '#10b981' : '#1e293b');
            
            setTimeout(() => {
                toast.style.display = 'none';
            }, 3000);
        }

        // Modal functions
        function openSellModal() {
            document.getElementById('sellModal').style.display = 'flex';
        }

        function closeSellModal() {
            document.getElementById('sellModal').style.display = 'none';
            document.getElementById('sellForm').reset();
