    <script>
        // API Configuration
        const API_BASE_URL = '/api/marketplace';
        let currentUser = null;
        let currentSort = 'newest';
        let currentView = 'grid';
        let currentFilters = {
            category: 'all',
            minPrice: null,
            maxPrice: null,
            condition: 'all',
            minRating: 0
        };
        // Registry so onclick handlers can look up listing data by ID safely
        const listingsMap = {};

        // Fetch current user
        async function fetchCurrentUser() {
            try {
                // Changed from /api/auth/me to /api/users/me
                const response = await fetch('/api/users/me', {
                    credentials: 'include'
                });
                if (response.ok) {
                    const data = await response.json();
                    currentUser = data.user || data;
                    updateUserAvatar();
                }
            } catch (error) {
                console.error('Error fetching user:', error);
            }
        }

        // Update user avatar
        function updateUserAvatar() {
            if (currentUser && currentUser.name) {
                const avatar = document.getElementById('userAvatar');
                if (currentUser.profile_picture) {
                    avatar.innerHTML = `<img src="${currentUser.profile_picture}" alt="Profile" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">`;
                } else {
                    avatar.innerHTML = `<i class="fas fa-user"></i>`;
                }
            }
        }

        // Fetch categories with counts
        async function fetchCategories() {
            try {
                const response = await fetch(`${API_BASE_URL}/categories?campus=all`, {
                    credentials: 'include'
                });
                
                if (!response.ok) throw new Error('Failed to fetch categories');
                
                const data = await response.json();
                renderCategories(data.categories);
            } catch (error) {
                console.error('Error fetching categories:', error);
                renderCategoriesError();
            }
        }

        // Render categories
        function renderCategories(categories) {
            const container = document.getElementById('categoriesList');
            
            const defaultCategory = {
                id: 'all',
                name: 'All Items',
                icon: 'fas fa-store',
                count: categories.reduce((sum, cat) => sum + cat.count, 0)
            };
            
            const allCategories = [defaultCategory, ...categories];
            
            container.innerHTML = allCategories.map(cat => `
                <div class="category-item ${currentFilters.category === cat.id ? 'active' : ''}" data-category="${cat.id}">
                    <div class="category-icon">
                        <i class="${getCategoryIcon(cat.id)}"></i>
                    </div>
                    <div class="category-name">${cat.name}</div>
                    <div class="category-count">${cat.count}</div>
                </div>
            `).join('');
            
            // Add click handlers
            document.querySelectorAll('.category-item').forEach(item => {
                item.addEventListener('click', () => {
                    const categoryId = item.dataset.category;
                    currentFilters.category = categoryId;
                    fetchListings();
                    
                    // Update active state
                    document.querySelectorAll('.category-item').forEach(c => c.classList.remove('active'));
                    item.classList.add('active');
                });
            });
        }

        function getCategoryIcon(categoryId) {
            const icons = {
                'all': 'fas fa-store',
                'electronics': 'fas fa-mobile-alt',
                'books': 'fas fa-book',
                'fashion': 'fas fa-tshirt',
                'dorm': 'fas fa-bed',
                'dorm_life': 'fas fa-bed',
                'services': 'fas fa-briefcase',
                'other': 'fas fa-gift'
            };
            return icons[categoryId] || 'fas fa-tag';
        }

        function renderCategoriesError() {
            const container = document.getElementById('categoriesList');
            container.innerHTML = `
                <div class="category-item" style="color: #ef4444;">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>Failed to load categories</span>
                </div>
            `;
        }

        // Fetch listings from backend
        async function fetchListings() {
            const container = document.getElementById('productsContainer');
            container.innerHTML = `
                <div class="loading-spinner">
                    <i class="fas fa-spinner"></i>
                </div>
            `;
            
            try {
                const params = new URLSearchParams();
                params.append('sort', currentSort);
                params.append('limit', '20');
                params.append('campus', 'all');
                
                if (currentFilters.category !== 'all') {
                    params.append('category', currentFilters.category);
                }
                if (currentFilters.minPrice) {
                    params.append('minPrice', currentFilters.minPrice);
                }
                if (currentFilters.maxPrice) {
                    params.append('maxPrice', currentFilters.maxPrice);
                }
                if (currentFilters.condition !== 'all') {
                    params.append('condition', currentFilters.condition);
                }
                if (currentFilters.minRating > 0) {
                    params.append('minRating', currentFilters.minRating);
                }
                
                const searchTerm = document.getElementById('searchInput').value;
                if (searchTerm) {
                    params.append('search', searchTerm);
                }
                
                const response = await fetch(`${API_BASE_URL}/listings?${params.toString()}`, {
                    credentials: 'include'
                });
                
                if (!response.ok) throw new Error('Failed to fetch listings');
                
                const data = await response.json();
                renderListings(data.listings || []);
                
            } catch (error) {
                console.error('Error fetching listings:', error);
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-triangle"></i>
                        <h3>Failed to load listings</h3>
                        <p>Please check your connection and try again</p>
                        <button class="btn-order" onclick="fetchListings()" style="margin-top: 1rem;">
                            <i class="fas fa-sync-alt"></i> Retry
                        </button>
                    </div>
                `;
            }
        }

        // Render listings
        function renderListings(listingsRaw) {
            const container = document.getElementById('productsContainer');
            
            if (!listingsRaw || listingsRaw.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-store-slash"></i>
                        <h3>No listings found</h3>
                        <p>Try adjusting your filters or be the first to post an item!</p>
                        <button class="btn-order" onclick="openSellModal()" style="margin-top: 1rem;">
                            <i class="fas fa-plus"></i> Sell Something
                        </button>
                    </div>
                `;
                return;
            }

            // Remove duplicate data
            const listings = [...new Map(listingsRaw.map(l => [l.listing_id, l])).values()];

            // Register listings in map for safe onclick lookup
            listings.forEach(l => { listingsMap[l.listing_id] = l; });
            
            const gridClass = currentView === 'list' ? 'products-grid list-view' : 'products-grid';
            container.innerHTML = `
                <div class="${gridClass}">
                    ${listings.map(listing => renderProductCard(listing)).join('')}
                </div>
            `;
        }

        // Render individual product card
        function renderProductCard(listing) {
            const lid = listing.listing_id;
            const sellerInitial = listing.seller_name ? listing.seller_name.charAt(0).toUpperCase() : '?';
            const conditionIcon = getConditionIcon(listing.condition);
            const conditionText = formatCondition(listing.condition);
            const formattedPrice = new Intl.NumberFormat('en-KE').format(listing.price);
            const humanDate = formatHumanDate(listing.created_at, listing.affiliation || listing.campus || 'Main Campus');
            const isSaved = listing.is_wishlisted || listing.is_favorited;

            // Pre-calculate media HTML to avoid complex IIFE inside template literal
            let mediaHtml = '';
            const media = (listing.media && listing.media.length > 0) ? listing.media : [{ media_url: listing.image_url || '/images/default-listing.jpg' }];
            const displayMedia = media.slice(0, 4);
            const moreCount = media.length - 4;
            
            mediaHtml = displayMedia.map((m, idx) => `
                <div class="media-item" onclick="openLightbox('${lid}', ${idx}, event)">
                    <img src="${m.media_url}" alt="${escapeHtml(listing.title)}" onerror="this.src='/images/default-listing.jpg'">
                    ${idx === 3 && moreCount > 0 ? `<div class="more-overlay">+${moreCount}</div>` : ''}
                </div>
            `).join('');

            const mediaGridClass = listing.media && listing.media.length > 0 ? 'grid-' + (listing.media.length > 4 ? 'more' : listing.media.length) : 'grid-1';

            return `
                <div class="product-card" onclick="viewListing('${lid}')">
                    <div class="product-header">
