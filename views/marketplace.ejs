            document.getElementById('confirmOrderBtn').addEventListener('click', confirmOrder);
            document.getElementById('viewSafeSpots').addEventListener('click', () => {
                window.location.href = '/safe-spots'; // Could be mapped appropriately later
            });
            
            // Image upload
            document.getElementById('imageUpload').addEventListener('click', () => {
                document.getElementById('itemImages').click();
            });
            
            // Close modals on outside click
            window.onclick = (event) => {
                const sellModal = document.getElementById('sellModal');
                const orderModal = document.getElementById('orderModal');
                if (event.target === sellModal) closeSellModal();
                if (event.target === orderModal) closeOrderModal();
            };
        });
    </script>
    <!-- Lightbox Viewer -->
