<%- include('partials/head', { title: 'Sparkle Mall | Campus E-Commerce' }) %>

<!-- State meta -->
<meta name="user-id"     content="<%= user?.user_id || '' %>">
<meta name="user-campus" content="<%= user?.campus || 'all' %>">

<style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap');
    :root {
        --primary: #E1306C;
        --primary-light: #fff0f5;
        --secondary: #833AB4;
        --accent: #F56040;
        --bg-main: #f5f5f7;
        --card-bg: #ffffff;
        --border-color: #efefef;
        --text-main: #1a1a2e;
        --text-muted: #8e8e8e;
        --gradient: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
        --shadow-sm: 0 2px 12px rgba(0,0,0,0.06);
        --shadow-md: 0 10px 40px rgba(0,0,0,0.10);
        --radius-sm: 14px;
        --radius-md: 22px;
        --radius-lg: 32px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        background: var(--bg-main);
        color: var(--text-main);
        font-family: 'Outfit', sans-serif;
    }

    /* ── Top Nav ── */
    .top-nav {
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--border-color);
        padding: 14px 5%;
        position: sticky;
        top: 0;
        z-index: 1000;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .brand-logo {
        font-weight: 900;
        font-size: 1.45rem;
        background: var(--gradient);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        white-space: nowrap;
    }

    .search-bar-wrapper {
        flex: 1;
        max-width: 550px;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 12px 20px 12px 46px;
        border-radius: 50px;
        border: 1.5px solid var(--border-color);
        background: #f1f1f1;
        font-size: 0.9rem;
        font-family: inherit;
        transition: .3s;
    }

    .search-input:focus {
        background: #fff;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(225,48,108,.1);
        outline: none;
    }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        width: 18px;
        height: 18px;
    }

    .nav-actions { display: flex; align-items: center; gap: 12px; }

    .icon-btn {
        width: 44px; height: 44px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        border: 1.5px solid var(--border-color);
        background: white;
        color: var(--text-main);
        position: relative;
        transition: .3s;
        cursor: pointer;
        text-decoration: none;
    }

    .icon-btn:hover { background: var(--primary-light); color: var(--primary); transform: translateY(-2px); }

    .badge {
        position: absolute; top: -4px; right: -4px;
        background: var(--primary); color: white;
        font-size: 10px; padding: 2px 5px;
        border-radius: 10px; border: 2px solid white;
        font-weight: 800;
    }

    /* ── Layout ── */
    .marketplace-container {
        display: grid;
        grid-template-columns: 260px 1fr 300px;
        gap: 28px;
        padding: 28px 5%;
        max-width: 1800px;
        margin: 0 auto;
    }

    /* ── Filter Sidebar ── */
    .filter-sidebar {
        position: sticky;
        top: 90px;
        height: calc(100vh - 110px);
        overflow-y: auto;
        scrollbar-width: thin;
    }

    .sidebar-card {
        background: white;
        border-radius: var(--radius-md);
        padding: 22px;
        box-shadow: var(--shadow-sm);
        margin-bottom: 18px;
        border: 1px solid var(--border-color);
    }

    .sidebar-title {
        font-weight: 800;
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 2px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .category-link {
        display: flex; align-items: center; gap: 12px;
        padding: 11px 16px;
        border-radius: 14px;
        color: var(--text-main);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.88rem;
        margin-bottom: 5px;
        transition: .25s;
    }

    .category-link:hover, .category-link.active {
        background: var(--primary-light);
        color: var(--primary);
    }

    .filter-label {
        display: block;
        font-weight: 700;
        margin-bottom: 10px;
        font-size: 0.85rem;
    }

    .filter-group { margin-bottom: 22px; }

    .price-inputs { display: flex; gap: 8px; align-items: center; }

    .price-input {
        width: 100%;
        padding: 9px 12px;
        border-radius: 10px;
        border: 1.5px solid var(--border-color);
        font-family: inherit;
        font-size: 0.85rem;
    }

    .filter-select {
        width: 100%;
        padding: 9px 12px;
        border-radius: 10px;
        border: 1.5px solid var(--border-color);
        font-family: inherit;
        font-size: 0.85rem;
        background: white;
        cursor: pointer;
    }

    /* ── Feed ── */
    .feed-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 24px;
    }

    .feed-title {
        font-size: 1.9rem;
        font-weight: 900;
        background: linear-gradient(to right, var(--text-main) 30%, var(--text-muted));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .feed-subtitle {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 600;
        margin-top: 4px;
    }

    .sort-select {
        padding: 11px 22px;
        border-radius: 50px;
        border: 1.5px solid var(--border-color);
        background: white;
        font-weight: 700;
        font-size: 0.85rem;
        cursor: pointer;
        font-family: inherit;
    }

    .listings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 24px;
    }

    /* ── Product Card ── */
    .product-card {
        background: white;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border-color);
        transition: all .4s cubic-bezier(.165,.84,.44,1);
        position: relative;
        display: flex;
        flex-direction: column;
        cursor: pointer;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-md);
        border-color: rgba(225,48,108,.2);
    }

    .product-img-wrap {
        height: 260px;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #fdf2f8 0%, #f3e8ff 100%);
    }

    .product-image {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: .8s cubic-bezier(.165,.84,.44,1);
    }

    .product-card:hover .product-image { transform: scale(1.08); }

    .product-no-image {
        width: 100%; height: 100%;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 10px;
        color: #ccc;
    }

    .fav-btn {
        position: absolute; top: 16px; right: 16px;
        width: 42px; height: 42px;
        background: rgba(255,255,255,.9);
        backdrop-filter: blur(6px);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        border: none;
        color: #ccc;
        cursor: pointer;
        transition: .3s;
        z-index: 10;
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .fav-btn.active { color: var(--primary); }
    .fav-btn:hover { transform: scale(1.15); color: var(--primary); }

    .product-badge {
        position: absolute; top: 16px; left: 16px;
        background: var(--gradient);
        color: white;
        padding: 5px 14px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        box-shadow: 0 4px 12px rgba(225,48,108,.3);
    }

    .condition-badge {
        position: absolute; bottom: 12px; left: 12px;
        background: rgba(0,0,0,.55);
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.68rem;
        font-weight: 700;
        backdrop-filter: blur(6px);
    }

    .product-content { padding: 22px; flex: 1; display: flex; flex-direction: column; }

    .product-category {
        font-size: 0.68rem;
        text-transform: uppercase;
        color: var(--primary);
        letter-spacing: 1.5px;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .product-title {
        font-weight: 800;
        font-size: 1.1rem;
        line-height: 1.3;
        margin-bottom: 6px;
        color: var(--text-main);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-price {
        font-size: 1.55rem;
        font-weight: 900;
        color: var(--primary);
        margin-bottom: 16px;
    }

    .product-price span { font-size: 0.9rem; font-weight: 700; opacity: .7; }

    .seller-row {
        display: flex; align-items: center; gap: 10px;
        margin-top: auto;
        padding-top: 16px;
        border-top: 1px solid #f5f5f5;
    }

    .seller-avatar {
        width: 36px; height: 36px;
        border-radius: 50%; object-fit: cover;
        border: 2px solid white;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

    .seller-name { font-weight: 700; font-size: 0.85rem; color: var(--text-main); }

    .seller-rating {
        font-size: 0.72rem;
        color: #f59e0b;
        font-weight: 700;
        display: flex; align-items: center; gap: 3px;
    }

    .card-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 16px;
    }

    .btn {
        padding: 12px;
        border-radius: 14px;
        font-weight: 800;
        font-size: 0.85rem;
        border: none;
        cursor: pointer;
        transition: .3s cubic-bezier(.175,.885,.32,1.275);
        font-family: inherit;
        display: flex; align-items: center; justify-content: center; gap: 6px;
    }

    .btn-primary {
        background: var(--gradient);
        color: white;
        box-shadow: 0 6px 18px rgba(225,48,108,.2);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(225,48,108,.35); }

    .btn-outline {
        background: #fdf2f8;
        color: var(--primary);
        border: 1.5px solid rgba(225,48,108,.15);
    }
    .btn-outline:hover { background: var(--primary-light); transform: translateY(-2px); }

    /* ── Right Sidebar ── */
    .right-sidebar {
        position: sticky;
        top: 90px;
        height: calc(100vh - 110px);
        overflow-y: auto;
        scrollbar-width: thin;
    }

    .rec-card {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px;
        border-radius: 16px;
        text-decoration: none;
        color: var(--text-main);
        transition: .25s;
        margin-bottom: 8px;
    }

    .rec-card:hover { background: #f8f8f8; }

    .rec-img {
        width: 58px; height: 58px;
        border-radius: 12px;
        object-fit: cover;
        background: linear-gradient(135deg, #fdf2f8 0%, #f3e8ff 100%);
        flex-shrink: 0;
    }

    .rec-title {
        font-weight: 700;
        font-size: 0.82rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .rec-price {
        color: var(--primary);
        font-weight: 900;
        font-size: 0.9rem;
        margin-top: 3px;
    }

    /* ── FAB ── */
    .fab-btn {
        position: fixed; bottom: 32px; right: 32px;
        width: 68px; height: 68px;
        border-radius: 50%;
        background: var(--gradient);
        color: white;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 14px 40px rgba(225,48,108,.4);
        cursor: pointer;
        z-index: 1000;
        transition: .4s;
        text-decoration: none;
        border: none;
    }
    .fab-btn:hover { transform: scale(1.12) rotate(90deg); }

    /* ── Empty state ── */
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 120px 20px;
    }

    /* ── Toast ── */
    #toast {
        position: fixed; bottom: 30px; left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #1a1a2e;
        color: white;
        padding: 14px 32px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.9rem;
        z-index: 9999;
        opacity: 0;
        transition: all .35s cubic-bezier(.175,.885,.32,1.275);
        pointer-events: none;
        white-space: nowrap;
    }

    #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ── Order Confirm Modal ── */
    .modal-overlay {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.5);
        backdrop-filter: blur(6px);
        z-index: 2000;
        display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none;
        transition: opacity .3s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }

    .modal-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 40px;
        max-width: 480px;
        width: 90%;
        box-shadow: 0 30px 80px rgba(0,0,0,.2);
        transform: scale(.92);
        transition: transform .3s cubic-bezier(.175,.885,.32,1.275);
    }
    .modal-overlay.open .modal-card { transform: scale(1); }

    .modal-title {
        font-size: 1.4rem;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .modal-product-name {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--text-main);
        margin-bottom: 6px;
    }

    .modal-price {
        font-size: 2rem;
        font-weight: 900;
        color: var(--primary);
        margin-bottom: 20px;
    }

    .modal-info {
        background: #fdf2f8;
        border-radius: 14px;
        padding: 16px;
        font-size: 0.85rem;
        line-height: 1.6;
        color: #555;
        margin-bottom: 28px;
    }

    .modal-actions { display: flex; gap: 14px; }

    /* ── Responsive ── */
    @media(max-width:900px) {
        .marketplace-container { grid-template-columns: 1fr; padding: 16px; gap: 16px; }
        .filter-sidebar, .right-sidebar { display: none; }
        .top-nav { padding: 12px 16px; }
        .feed-title { font-size: 1.5rem; }
    }
</style>

<div class="top-nav">
    <a href="/marketplace" class="brand-logo">
        <i data-lucide="sparkles" style="width:22px;height:22px;"></i> Sparkle Mall
    </a>

    <div class="search-bar-wrapper">
        <i data-lucide="search" class="search-icon"></i>
        <form action="/marketplace" method="GET">
            <input type="text" name="search" class="search-input"
                   placeholder="Search phones, books, fashion…"
                   value="<%= filters.search || '' %>">
        </form>
    </div>

    <div class="nav-actions">
        <a href="/marketplace/orders" class="icon-btn" title="My Orders" id="ordersNavBtn">
            <i data-lucide="package" style="width:20px;height:20px;"></i>
        </a>
        <a href="/marketplace/favorites" class="icon-btn" title="Wishlist">
            <i data-lucide="heart" style="width:20px;height:20px;"></i>
            <% if (counts.favoritesCount > 0) { %>
                <span class="badge"><%= counts.favoritesCount %></span>
            <% } %>
        </a>
        <a href="/messages" class="icon-btn" title="Messages">
            <i data-lucide="message-circle" style="width:20px;height:20px;"></i>
            <% if (counts.notificationCount > 0) { %>
                <span class="badge"><%= counts.notificationCount %></span>
            <% } %>
        </a>
        <a href="/marketplace/sell" class="icon-btn" title="Sell Item" style="background: var(--gradient); color:white; border:none;">
            <i data-lucide="plus" style="width:20px;height:20px;"></i>
        </a>
    </div>
</div>

<div class="marketplace-container">
    <!-- Left Sidebar: Filters -->
    <aside class="filter-sidebar">
        <div class="sidebar-card">
            <div class="sidebar-title"><i data-lucide="layers" style="width:14px;height:14px;"></i> Categories</div>
            <nav>
                <a href="/marketplace?category=all" class="category-link <%= (filters.category === 'all' || !filters.category) ? 'active' : '' %>">
                    <i data-lucide="grid" style="width:16px;"></i> All Items
                </a>
                <a href="/marketplace?category=electronics" class="category-link <%= filters.category === 'electronics' ? 'active' : '' %>">
                    <i data-lucide="monitor" style="width:16px;"></i> Electronics
                </a>
                <a href="/marketplace?category=books" class="category-link <%= filters.category === 'books' ? 'active' : '' %>">
                    <i data-lucide="book" style="width:16px;"></i> Books & Notes
                </a>
                <a href="/marketplace?category=fashion" class="category-link <%= filters.category === 'fashion' ? 'active' : '' %>">
                    <i data-lucide="shirt" style="width:16px;"></i> Fashion Lab
                </a>
                <a href="/marketplace?category=home" class="category-link <%= filters.category === 'home' ? 'active' : '' %>">
                    <i data-lucide="coffee" style="width:16px;"></i> Dorm Life
                </a>
                <a href="/marketplace?category=services" class="category-link <%= filters.category === 'services' ? 'active' : '' %>">
                    <i data-lucide="wrench" style="width:16px;"></i> Services
                </a>
                <a href="/marketplace?category=other" class="category-link <%= filters.category === 'other' ? 'active' : '' %>">
                    <i data-lucide="package" style="width:16px;"></i> Other
                </a>
            </nav>
        </div>

        <div class="sidebar-card">
            <div class="sidebar-title"><i data-lucide="sliders" style="width:14px;height:14px;"></i> Filters</div>
            <form action="/marketplace" method="GET">
                <input type="hidden" name="category" value="<%= filters.category || 'all' %>">

                <div class="filter-group">
                    <label class="filter-label">Price Range (KES)</label>
                    <div class="price-inputs">
                        <input type="number" name="minPrice" placeholder="Min" class="price-input" value="<%= filters.minPrice || '' %>">
                        <span style="color:var(--text-muted);font-weight:700;">–</span>
                        <input type="number" name="maxPrice" placeholder="Max" class="price-input" value="<%= filters.maxPrice || '' %>">
                    </div>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Condition</label>
                    <select name="condition" class="filter-select">
                        <option value="all">Any Condition</option>
                        <option value="new"      <%= filters.condition === 'new'      ? 'selected' : '' %>>Brand New 🔒</option>
                        <option value="like_new"  <%= filters.condition === 'like_new' ? 'selected' : '' %>>Like New ✨</option>
                        <option value="good"      <%= filters.condition === 'good'     ? 'selected' : '' %>>Good Used 👍</option>
                        <option value="fair"      <%= filters.condition === 'fair'     ? 'selected' : '' %>>Fair 🔄</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Min Seller Rating</label>
                    <select name="minRating" class="filter-select">
                        <option value="0">Any Rating</option>
                        <option value="4" <%= filters.minRating == 4 ? 'selected' : '' %>>4★ & above</option>
                        <option value="3" <%= filters.minRating == 3 ? 'selected' : '' %>>3★ & above</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%; margin-top:4px;">
                    <i data-lucide="search" style="width:16px;"></i> Apply Filters
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Feed -->
    <main>
        <div class="feed-header">
            <div>
                <h1 class="feed-title">
                    <%= filters.category === 'all' || !filters.category
                        ? 'Sparkle Market' 
                        : (filters.category.charAt(0).toUpperCase() + filters.category.slice(1)) %>
                </h1>
                <div class="feed-subtitle"><%= listings.length %> items found</div>
            </div>
            <select class="sort-select" id="sortSelect" onchange="applySort(this.value)">
                <option value="newest"     <%= filters.sort === 'newest'     ? 'selected' : '' %>>Just In 🔥</option>
                <option value="popular"    <%= filters.sort === 'popular'    ? 'selected' : '' %>>Popular</option>
                <option value="price_low"  <%= filters.sort === 'price_low'  ? 'selected' : '' %>>Price ↑</option>
                <option value="price_high" <%= filters.sort === 'price_high' ? 'selected' : '' %>>Price ↓</option>
            </select>
        </div>

        <div class="listings-grid" id="listingsGrid">
            <% if (listings && listings.length > 0) { %>
                <% listings.forEach(listing => { %>
                    <%
                        const imgUrl = (listing.image_urls && listing.image_urls.length > 0)
                            ? listing.image_urls[0]
                            : (listing.image_url || null);
                        const priceKes = parseFloat(listing.price || 0).toLocaleString('en-KE');
                        const conditionMap = { new: 'Brand New', like_new: 'Like New', good: 'Good', fair: 'Fair', poor: 'Poor' };
                    %>
                    <div class="product-card" id="card-<%= listing.listing_id %>">
                        <div class="product-img-wrap">
                            <% if (imgUrl) { %>
                                <img src="<%= imgUrl %>" class="product-image"
                                     alt="<%= listing.title %>"
                                     onerror="this.parentElement.innerHTML='<div class=\'product-no-image\'><svg xmlns=\'http://www.w3.org/2000/svg\' width=\'48\' height=\'48\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'1.5\' viewBox=\'0 0 24 24\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><path d=\'m21 15-5-5L5 21\'/></svg><span style=\'font-size:.75rem;\'>No Image</span></div>'">
                            <% } else { %>
                                <div class="product-no-image">
                                    <i data-lucide="image" style="width:48px;height:48px;"></i>
                                    <span style="font-size:.75rem;">No Image</span>
                                </div>
                            <% } %>
                            <button class="fav-btn <%= listing.is_favorited ? 'active' : '' %>"
                                    id="fav-<%= listing.listing_id %>"
                                    onclick="handleFavorite('<%= listing.listing_id %>', this); event.stopPropagation();"
                                    title="<%= listing.is_favorited ? 'Remove from wishlist' : 'Add to wishlist' %>">
                                <i data-lucide="heart" style="width:18px;height:18px;fill:<%= listing.is_favorited ? 'currentColor' : 'none' %>;"></i>
                            </button>
                            <% if (listing.is_promoted) { %>
                                <div class="product-badge">⚡ Featured</div>
                            <% } %>
                            <% if (listing.condition) { %>
                                <div class="condition-badge"><%= conditionMap[listing.condition] || listing.condition %></div>
                            <% } %>
                        </div>

                        <div class="product-content" data-listing-id="<%= listing.listing_id %>"
                             onclick="window.location.href='/marketplace/listings/<%= listing.listing_id %>'">
                            <div class="product-category"><%= listing.category || 'General' %></div>
                            <h3 class="product-title">
                                <%= listing.title %>
                                <% if (listing.is_mock) { %>
                                    <span class="mock-badge" style="background:#3b82f6;color:white;font-size:0.6rem;padding:2px 4px;border-radius:3px;margin-left:4px;">DEMO</span>
                                <% } %>
                            </h3>
                            <div class="product-price">
                                KES <%= priceKes %>
                            </div>

                            <div class="seller-row">
                                <img src="<%= listing.seller_avatar || '/images/default-avatar.png' %>"
                                     class="seller-avatar" alt="<%= listing.seller_username %>"
                                     onerror="this.src='/images/default-avatar.png'">
                                <div style="flex:1; min-width:0;">
                                    <div class="seller-name"><%= listing.seller_username %></div>
                                    <div class="seller-rating">
                                        <% const rating = parseFloat(listing.seller_rating || 0); %>
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <% if (i <= rating) { %>
                                                <i data-lucide="star" style="width:11px;height:11px;fill:#fbbf24;color:#fbbf24;"></i>
                                            <% } else if (i - 0.5 <= rating) { %>
                                                <i data-lucide="star-half" style="width:11px;height:11px;fill:#fbbf24;color:#fbbf24;"></i>
                                            <% } else { %>
                                                <i data-lucide="star" style="width:11px;height:11px;color:#d1d5db;"></i>
                                            <% } %>
                                        <% } %>
                                        <%= rating.toFixed(1) %> (<%= listing.seller_review_count || 0 %>)
                                    </div>
                                </div>
                                <% if (user && listing.seller_id !== user.user_id) { %>
                                <button class="icon-btn" style="width:34px;height:34px;"
                                        onclick="handleFollowSeller('<%= listing.seller_id %>', this); event.stopPropagation();"
                                        title="Follow seller">
                                    <i data-lucide="user-plus" style="width:15px;height:15px;"></i>
                                </button>
                                <% } %>
                            </div>

                            <div class="card-actions" onclick="event.stopPropagation()">
                                <% if (!user || listing.seller_id === user.user_id) { %>
                                    <button class="btn btn-primary" style="grid-column:1/-1;"
                                            onclick="window.location.href='/marketplace/listings/<%= listing.listing_id %>'">
                                        <i data-lucide="eye" style="width:15px;"></i> View Detail
                                    </button>
                                <% } else { %>
                                    <button class="btn btn-primary"
                                            onclick="openOrderModal('<%= listing.listing_id %>', '<%= listing.title.replace(/'/g, "\\'") %>', <%= listing.price %>)">
                                        <i data-lucide="shopping-bag" style="width:15px;"></i> Order
                                    </button>
                                    <button class="btn btn-outline"
                                            onclick="window.location.href='/messages?chat_with=<%= listing.seller_id %>&listing=<%= listing.listing_id %>'">
                                        <i data-lucide="message-circle" style="width:15px;"></i> Chat
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-state">
                    <i data-lucide="search-x" style="width:80px;height:80px;color:#ddd;display:block;margin:0 auto 20px;"></i>
                    <h2 style="font-weight:800;margin-bottom:10px;">Quiet in the market…</h2>
                    <p style="color:var(--text-muted);margin-bottom:24px;">No items for your current filters. Try resetting!</p>
                    <a href="/marketplace" class="btn btn-primary" style="display:inline-flex;">View All Items</a>
                </div>
            <% } %>
        </div>

        <!-- Load More -->
        <% if (listings.length >= 20) { %>
        <div style="text-align:center; margin-top:40px;">
            <button class="btn btn-outline" id="loadMoreBtn" onclick="loadMoreListings()" style="padding:14px 40px;">
                <i data-lucide="refresh-cw" style="width:15px;"></i> Load More
            </button>
        </div>
        <% } %>
    </main>

    <!-- Right Sidebar: Recommended -->
    <aside class="right-sidebar">
        <div class="sidebar-card">
            <div class="sidebar-title"><i data-lucide="zap" style="width:14px;height:14px;"></i> Recommended For You</div>
            <% if (recommendedListings && recommendedListings.length > 0) { %>
                <% recommendedListings.forEach(item => { %>
                    <%
                        const recImg = item.media_url || item.image_url || null;
                        const recPrice = parseFloat(item.price || 0).toLocaleString('en-KE');
                    %>
                    <a href="/marketplace/listings/<%= item.listing_id %>" class="rec-card">
                        <% if (recImg) { %>
                            <img src="<%= recImg %>" class="rec-img" alt="<%= item.title %>"
                                 onerror="this.src='/images/default-item.jpg'">
                        <% } else { %>
                            <div class="rec-img" style="display:flex;align-items:center;justify-content:center;">
                                <i data-lucide="image" style="width:22px;height:22px;color:#ccc;"></i>
                            </div>
                        <% } %>
                        <div>
                            <div class="rec-title"><%= item.title %></div>
                            <div class="rec-price">KES <%= recPrice %></div>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <p style="font-size:.8rem;color:var(--text-muted);text-align:center;padding:16px;">Browse more to get recommendations</p>
            <% } %>
        </div>

        <div class="sidebar-card">
            <div class="sidebar-title"><i data-lucide="shield-check" style="width:14px;height:14px;"></i> Safe Trading</div>
            <div style="font-size:.82rem;color:#555;line-height:1.7;">
                <p>✅ Always meet in a <strong>public campus spot</strong></p>
                <p>✅ Inspect before paying</p>
                <p>✅ Use <strong>M-PESA</strong> for safety</p>
                <p>⚠️ Never pay before seeing item</p>
            </div>
            <a href="/marketplace/safe-locations" style="display:block;margin-top:14px;text-align:center;font-weight:700;font-size:.82rem;color:var(--primary);text-decoration:none;">
                View Campus Safe Spots →
            </a>
        </div>
    </aside>
</div>

<!-- Sell FAB -->
<a href="/marketplace/sell" class="fab-btn" title="Sell your item">
    <i data-lucide="plus" style="width:28px;height:28px;"></i>
</a>

<!-- Toast -->
<div id="toast"></div>

<!-- Order Confirm Modal -->
<div class="modal-overlay" id="orderModal">
    <div class="modal-card">
        <div class="modal-title">🛍️ Confirm Order</div>
        <div class="modal-product-name" id="modalProductName"></div>
        <div class="modal-price" id="modalPrice"></div>
        <div class="modal-info">
            📦 Your order request will be sent to the seller. They'll accept or reject it.<br><br>
            📍 Arrange a safe campus meetup to complete the purchase.
        </div>
        <div class="modal-actions">
            <button class="btn btn-outline" style="flex:1;" onclick="closeOrderModal()">Cancel</button>
            <button class="btn btn-primary" style="flex:2;" id="confirmOrderBtn" onclick="submitOrder()">
                <i data-lucide="check" style="width:16px;"></i> Place Order
            </button>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script src="https://unpkg.com/lucide@latest"></script>

<!-- Firebase Realtime SDK (client-side) -->
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-database-compat.js"></script>

<script>
    lucide.createIcons();

    // ── Firebase Client Init ──────────────────────────────────────────────────
    const firebaseConfig = {
        apiKey: "AIzaSyDKKlpoJ4PgejlKFL-2LEhpHHWnHRpZoLM",
        authDomain: "sparkleapp-10f62.firebaseapp.com",
        databaseURL: "https://sparkleapp-10f62-default-rtdb.firebaseio.com",
        projectId: "sparkleapp-10f62",
        storageBucket: "sparkleapp-10f62.firebasestorage.app",
        messagingSenderId: "587326689034",
        appId: "1:587326689034:web:6b1d993cabfcb95bce74f3"
    };

    if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
    const rtdb = firebase.database();

    // ── Toast ─────────────────────────────────────────────────────────────────
    function showToast(msg, type = 'default') {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.style.background = type === 'error' ? '#dc2626' : type === 'success' ? '#16a34a' : '#1a1a2e';
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3500);
    }

    // ── Favorite ──────────────────────────────────────────────────────────────
    async function handleFavorite(listingId, btn) {
        try {
            const res = await fetch(`/api/marketplace/listings/${listingId}/favorite`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                const icon = btn.querySelector('i');
                btn.classList.toggle('active', data.favorited);
                icon.style.fill = data.favorited ? 'currentColor' : 'none';
                showToast(data.favorited ? '❤️ Added to wishlist!' : 'Removed from wishlist', data.favorited ? 'success' : 'default');
            }
        } catch(e) { showToast('Failed to update wishlist', 'error'); }
    }

    // ── Follow Seller ─────────────────────────────────────────────────────────
    async function handleFollowSeller(sellerId, btn) {
        try {
            const res = await fetch('/api/marketplace/seller/favorite', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sellerId })
            });
            const data = await res.json();
            if (data.success) {
                btn.innerHTML = data.favorited
                    ? '<i data-lucide="user-check" style="width:15px;height:15px;"></i>'
                    : '<i data-lucide="user-plus"  style="width:15px;height:15px;"></i>';
                lucide.createIcons();
                showToast(data.favorited ? '✅ Following seller!' : 'Unfollowed seller');
            }
        } catch(e) { showToast('Action failed', 'error'); }
    }

    // ── Sort ──────────────────────────────────────────────────────────────────
    function applySort(val) {
        const url = new URL(window.location.href);
        url.searchParams.set('sort', val);
        window.location.href = url.toString();
    }

    // ── Order Modal ───────────────────────────────────────────────────────────
    let _activeListingId = null;

    function openOrderModal(listingId, title, price) {
        _activeListingId = listingId;
        document.getElementById('modalProductName').textContent = title;
        document.getElementById('modalPrice').textContent = 'KES ' + parseFloat(price).toLocaleString('en-KE');
        document.getElementById('orderModal').classList.add('open');
    }

    function closeOrderModal() {
        document.getElementById('orderModal').classList.remove('open');
        _activeListingId = null;
    }

    async function submitOrder() {
        if (!_activeListingId) return;
        const btn = document.getElementById('confirmOrderBtn');
        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader" style="width:16px;"></i> Placing…';
        lucide.createIcons();

        try {
            const res = await fetch('/api/marketplace/order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ listingId: _activeListingId })
            });
            const data = await res.json();

            if (data.success) {
                closeOrderModal();
                showToast('🛍️ Order placed! Seller will respond shortly.', 'success');
                setTimeout(() => window.location.href = '/marketplace/orders', 1800);

                // Realtime: listen for seller's response on this order
                rtdb.ref(`marketplace/orders/${data.orderId}`).on('value', snap => {
                    const order = snap.val();
                    if (!order) return;
                    if (order.status === 'accepted')   showToast('✅ Seller accepted your order!', 'success');
                    if (order.status === 'rejected')   showToast('❌ Seller rejected the order.', 'error');
                    if (order.status === 'completed')  showToast('🎉 Order completed!', 'success');
                });
            } else {
                showToast(data.message || 'Order failed', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="check" style="width:16px;"></i> Place Order';
                lucide.createIcons();
            }
        } catch(e) {
            showToast('Connection error, try again', 'error');
            btn.disabled = false;
            btn.innerHTML = '<i data-lucide="check" style="width:16px;"></i> Place Order';
            lucide.createIcons();
        }
    }

    // Close modal on overlay click
    document.getElementById('orderModal').addEventListener('click', function(e) {
        if (e.target === this) closeOrderModal();
    });

    // ── Load More ─────────────────────────────────────────────────────────────
    let _offset = <%= listings.length %>;
    async function loadMoreListings() {
        const btn = document.getElementById('loadMoreBtn');
        if (!btn) return;
        btn.disabled = true;
        btn.textContent = 'Loading…';

        const params = new URLSearchParams(window.location.search);
        params.set('offset', _offset);
        params.set('limit', 20);

        try {
            const res = await fetch('/api/marketplace/listings?' + params.toString());
            const data = await res.json();

            if (data.success && data.listings.length > 0) {
                _offset += data.listings.length;
                data.listings.forEach(item => {
                    const div = document.createElement('div');
                    div.className = 'product-card';
                    const price = parseFloat(item.price || 0).toLocaleString('en-KE');
                    const img   = (item.image_urls && item.image_urls.length > 0) ? item.image_urls[0] : (item.image_url || '/images/default-item.jpg');
                    div.innerHTML = `
                        <div class="product-img-wrap">
                            <img src="${img}" class="product-image" alt="${item.title}"
                                 onerror="this.src='/images/default-item.jpg'">
                        </div>
                        <div class="product-content">
                            <div class="product-category">${item.category || 'General'}</div>
                            <h3 class="product-title">${item.title}</h3>
                            <div class="product-price">KES ${price}</div>
                            <div class="card-actions">
                                <button class="btn btn-primary" onclick="openOrderModal('${item.listing_id}','${item.title.replace(/'/g,"\\'")}',${item.price})">
                                    Order
                                </button>
                                <button class="btn btn-outline" onclick="window.location.href='/messages?chat_with=${item.seller_id}&listing=${item.listing_id}'">
                                    Chat
                                </button>
                            </div>
                        </div>`;
                    document.getElementById('listingsGrid').appendChild(div);
                });
                lucide.createIcons();

                if (!data.pagination.hasMore) {
                    btn.textContent = 'All items loaded';
                    btn.disabled = true;
                } else {
                    btn.disabled = false;
                    btn.innerHTML = '<i data-lucide="refresh-cw" style="width:15px;"></i> Load More';
                    lucide.createIcons();
                }
            } else {
                btn.textContent = 'No more items';
                btn.disabled = true;
            }
        } catch(e) {
            showToast('Failed to load more items', 'error');
            btn.disabled = false;
            btn.textContent = 'Retry';
        }
    }
</script>