<%- include('partials/head', { title: 'Sparkle Mall | Campus E-Commerce' }) %>

<!-- Meta tags for state -->
<meta name="user-id" content="<%= user?.user_id || '' %>">
<meta name="user-campus" content="<%= user?.campus || 'all' %>">

<style>
    :root {
        --primary: #E1306C;
        --primary-light: #fff0f5;
        --secondary: #833AB4;
        --accent: #F56040;
        --bg-main: #f8f9fa;
        --card-bg: #ffffff;
        --border-color: #efefef;
        --text-main: #262626;
        --text-muted: #8e8e8e;
        --gradient-pink: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
        --shadow-md: 0 8px 30px rgba(0,0,0,0.08);
        --radius-sm: 12px;
        --radius-md: 20px;
        --radius-lg: 30px;
    }

    body {
        background-color: var(--bg-main);
        color: var(--text-main);
        font-family: 'Outfit', sans-serif;
    }

    /* Modern Navigation */
    .top-nav {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(15px);
        border-bottom: 1px solid var(--border-color);
        padding: 15px 5%;
        position: sticky;
        top: 0;
        z-index: 1000;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .brand-logo {
        font-weight: 900;
        font-size: 1.5rem;
        background: var(--gradient-pink);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .search-bar-wrapper {
        flex: 1;
        max-width: 600px;
        margin: 0 30px;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 12px 20px 12px 45px;
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
        background: #f1f1f1;
        transition: 0.3s;
    }

    .search-input:focus {
        background: #fff;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(225, 48, 108, 0.1);
        outline: none;
    }

    .search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
    }

    .nav-actions {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .icon-btn {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border-color);
        background: white;
        color: var(--text-main);
        position: relative;
        transition: 0.3s;
        cursor: pointer;
        text-decoration: none;
    }

    .icon-btn:hover {
        background: var(--primary-light);
        color: var(--primary);
        transform: translateY(-2px);
    }

    .badge {
        position: absolute;
        top: -5px;
        right: -5px;
        background: var(--primary);
        color: white;
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 10px;
        border: 2px solid white;
    }

    /* Marketplace Layout */
    .marketplace-container {
        display: grid;
        grid-template-columns: 280px 1fr 320px;
        gap: 30px;
        padding: 30px 5%;
        max-width: 1800px;
        margin: 0 auto;
    }

    /* Filters Sidebar */
    .filter-sidebar {
        position: sticky;
        top: 100px;
        height: calc(100vh - 120px);
        overflow-y: auto;
    }

    .sidebar-card {
        background: white;
        border-radius: var(--radius-md);
        padding: 25px;
        box-shadow: var(--shadow-sm);
        margin-bottom: 20px;
        border: 1px solid var(--border-color);
    }

    .sidebar-title {
        font-weight: 800;
        font-size: 0.8rem;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 1.5px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .category-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        border-radius: 15px;
        color: var(--text-main);
        text-decoration: none;
        font-weight: 700;
        margin-bottom: 6px;
        transition: 0.25s;
    }

    .category-link:hover, .category-link.active {
        background: var(--primary-light);
        color: var(--primary);
    }

    .filter-group {
        margin-bottom: 25px;
    }

    .filter-label {
        display: block;
        font-weight: 700;
        margin-bottom: 12px;
        font-size: 0.9rem;
    }

    .price-inputs {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .price-input {
        width: 100%;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        font-size: 0.85rem;
    }

    /* Main Feed */
    .feed-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .feed-title {
        font-size: 2rem;
        font-weight: 900;
        background: linear-gradient(to right, var(--text-main), var(--text-muted));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .sort-select {
        padding: 12px 25px;
        border-radius: 50px;
        border: 1.5px solid var(--border-color);
        background: white;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: 0.3s;
    }

    .sort-select:hover { border-color: var(--primary); }

    .listings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 30px;
    }

    /* Product Card */
    .product-card {
        background: white;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border-color);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary-light);
    }

    .product-image-container {
        height: 280px;
        position: relative;
        overflow: hidden;
        background: #fdf2f8;
    }

    .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 1s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .product-card:hover .product-image {
        transform: scale(1.1);
    }

    .favorite-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 45px;
        height: 45px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(5px);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        color: #ddd;
        cursor: pointer;
        transition: 0.3s;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .favorite-btn.active {
        color: var(--primary);
        background: white;
    }

    .product-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        background: var(--gradient-pink);
        color: white;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        box-shadow: 0 4px 10px rgba(225, 48, 108, 0.3);
    }

    .product-content {
        padding: 25px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .product-category {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--primary);
        letter-spacing: 1.2px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .product-title {
        font-weight: 800;
        font-size: 1.2rem;
        margin-bottom: 8px;
        color: var(--text-main);
    }

    .product-price {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--primary);
        margin-bottom: 20px;
    }

    .seller-info {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: auto;
        padding-top: 20px;
        border-top: 1px solid #f8f8f8;
    }

    .seller-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .seller-name {
        font-weight: 700;
        font-size: 0.9rem;
        display: block;
        color: var(--text-main);
    }

    .seller-rating {
        font-size: 11px;
        color: #ffbc00;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 3px;
    }

    .card-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 20px;
    }

    .btn {
        padding: 14px;
        border-radius: 16px;
        font-weight: 800;
        font-size: 0.9rem;
        border: none;
        cursor: pointer;
        transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .btn-primary { 
        background: var(--gradient-pink); 
        color: white; 
        box-shadow: 0 6px 15px rgba(225, 48, 108, 0.2); 
    }
    .btn-primary:hover { 
        transform: translateY(-2px); 
        box-shadow: 0 10px 25px rgba(225, 48, 108, 0.3); 
    }

    .btn-outline { 
        background: #fdf2f8; 
        color: var(--primary); 
        border: 1.5px solid var(--primary-light); 
    }
    .btn-outline:hover { 
        background: var(--primary-light); 
        transform: translateY(-2px); 
    }

    /* FAB */
    .fab-btn {
        position: fixed;
        bottom: 35px;
        right: 35px;
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: var(--gradient-pink);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 12px 35px rgba(225, 48, 108, 0.4);
        cursor: pointer;
        z-index: 1000;
        transition: 0.4s;
    }

    .fab-btn:hover {
        transform: scale(1.1) rotate(90deg);
    }

    /* Mobile */
    @media (max-width: 900px) {
        .marketplace-container { grid-template-columns: 1fr; padding: 20px; }
        .filter-sidebar, .right-sidebar { display: none; }
        .top-nav { padding: 15px 20px; }
        .feed-title { font-size: 1.6rem; }
    }
</style>

<div class="top-nav">
    <a href="/marketplace" class="brand-logo">
        <i data-lucide="sparkles"></i> Sparkle Mall
    </a>

    <div class="search-bar-wrapper">
        <i data-lucide="search" class="search-icon"></i>
        <form action="/marketplace" method="GET" id="searchForm">
            <input type="text" name="search" class="search-input" placeholder="What are you looking for?" value="<%= filters.search || '' %>">
        </form>
    </div>

    <div class="nav-actions">
        <a href="/marketplace/orders" class="icon-btn" title="Track Orders">
            <i data-lucide="package"></i>
        </a>
        <a href="/marketplace/favorites" class="icon-btn" title="Wishlist">
            <i data-lucide="heart"></i>
        </a>
        <a href="/messages" class="icon-btn" title="Messages">
            <i data-lucide="message-circle"></i>
            <% if (counts.notificationCount > 0) { %>
                <span class="badge"><%= counts.notificationCount %></span>
            <% } %>
        </a>
    </div>
</div>

<div class="marketplace-container">
    <aside class="filter-sidebar">
        <div class="sidebar-card">
            <div class="sidebar-title"><i data-lucide="layers" style="width:16px;"></i> Categories</div>
            <nav>
                <a href="/marketplace?category=all" class="category-link <%= filters.category === 'all' ? 'active' : '' %>">
                    <i data-lucide="grid"></i> All Trending
                </a>
                <a href="/marketplace?category=electronics" class="category-link <%= filters.category === 'electronics' ? 'active' : '' %>">
                    <i data-lucide="monitor"></i> Electronics
                </a>
                <a href="/marketplace?category=books" class="category-link <%= filters.category === 'books' ? 'active' : '' %>">
                    <i data-lucide="book"></i> Books & Notes
                </a>
                <a href="/marketplace?category=fashion" class="category-link <%= filters.category === 'fashion' ? 'active' : '' %>">
                    <i data-lucide="shirt"></i> Fashion Lab
                </a>
                <a href="/marketplace?category=home" class="category-link <%= filters.category === 'home' ? 'active' : '' %>">
                    <i data-lucide="coffee"></i> Dorm Life
                </a>
            </nav>
        </div>

        <div class="sidebar-card">
            <div class="sidebar-title"><i data-lucide="sliders" style="width:16px;"></i> Advanced Filters</div>
            <form action="/marketplace" method="GET">
                <input type="hidden" name="category" value="<%= filters.category %>">
                
                <div class="filter-group">
                    <label class="filter-label">Price Range ($)</label>
                    <div class="price-inputs">
                        <input type="number" name="minPrice" placeholder="Min" class="price-input" value="<%= filters.minPrice %>">
                        <input type="number" name="maxPrice" placeholder="Max" class="price-input" value="<%= filters.maxPrice %>">
                    </div>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Condition</label>
                    <select name="condition" class="search-input" style="padding: 10px;">
                        <option value="all">Any Condition</option>
                        <option value="new" <%= filters.condition === 'new' ? 'selected' : '' %>>New / Sealed</option>
                        <option value="like_new" <%= filters.condition === 'like_new' ? 'selected' : '' %>>Like New</option>
                        <option value="good" <%= filters.condition === 'good' ? 'selected' : '' %>>Good / Pre-loved</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Min. Seller Rating</label>
                    <select name="minRating" class="search-input" style="padding: 10px;">
                        <option value="0">Any Rating</option>
                        <option value="4" <%= filters.minRating == 4 ? 'selected' : '' %>>4+ Stars ★★★★</option>
                        <option value="3" <%= filters.minRating == 3 ? 'selected' : '' %>>3+ Stars ★★★</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;">Refresh Market</button>
            </form>
        </div>
    </aside>

    <main>
        <div class="feed-header">
            <h1 class="feed-title">
                <%= filters.category === 'all' ? 'Sparkle Market' : filters.category.charAt(0).toUpperCase() + filters.category.slice(1) %>
            </h1>
            <select class="sort-select" onchange="window.location.href='/marketplace?sort=' + this.value">
                <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Just In</option>
                <option value="popular" <%= filters.sort === 'popular' ? 'selected' : '' %>>Popular</option>
                <option value="price_low" <%= filters.sort === 'price_low' ? 'selected' : '' %>>Price ↓</option>
                <option value="price_high" <%= filters.sort === 'price_high' ? 'selected' : '' %>>Price ↑</option>
            </select>
        </div>

        <div class="listings-grid">
            <% if (listings && listings.length > 0) { %>
                <% listings.forEach(listing => { %>
                    <div class="product-card">
                        <div class="product-image-container">
                            <img src="<%= listing.image_url || '/images/default-item.jpg' %>" class="product-image" alt="Item">
                            <button class="favorite-btn <%= listing.is_favorited ? 'active' : '' %>" onclick="handleFavorite('<%= listing.listing_id %>', this)">
                                <i data-lucide="heart"></i>
                            </button>
                            <% if (listing.is_promoted) { %>
                                <div class="product-badge">Promoted</div>
                            <% } %>
                        </div>
                        <div class="product-content" data-title="<%= listing.title %>">
                            <div class="product-category"><%= listing.category %> • <%= listing.condition %></div>
                            <h3 class="product-title"><%= listing.title %></h3>
                            <div class="product-price">$<%= parseFloat(listing.price).toFixed(2) %></div>
                            
                            <div class="seller-info">
                                <img src="<%= listing.seller_avatar || '/images/default-avatar.png' %>" class="seller-avatar" alt="Avatar">
                                <div style="flex: 1;">
                                    <span class="seller-name"><%= listing.seller_username %></span>
                                    <div class="seller-rating">
                                        <i data-lucide="star" style="width: 10px; height: 10px; fill: currentColor;"></i>
                                        <%= parseFloat(listing.seller_rating || 5.0).toFixed(1) %> (<%= listing.seller_review_count || 0 %>)
                                    </div>
                                </div>
                                <button class="icon-btn" onclick="handleFollow('<%= listing.seller_id %>', this)">
                                    <i data-lucide="user-plus"></i>
                                </button>
                            </div>

                            <div class="card-actions">
                                <button class="btn btn-primary" onclick="initOrder('<%= listing.listing_id %>', '<%= listing.seller_id %>', <%= listing.price %>, this)">Order Now</button>
                                <button class="btn btn-outline" onclick="window.location.href='/messages?chat_with=<%= listing.seller_id %>&listing=<%= listing.listing_id %>'">Chat</button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 120px 20px;">
                    <i data-lucide="search-x" style="width:80px; height:80px; color:#ddd; margin-bottom:20px;"></i>
                    <h2>Quiet in the market...</h2>
                    <p>No items found for your current search. Try resetting filters!</p>
                    <a href="/marketplace" class="btn btn-primary" style="display:inline-flex; margin-top:20px;">View All Items</a>
                </div>
            <% } %>
        </div>
    </main>

    <aside class="right-sidebar">
        <div class="sidebar-card">
            <div class="sidebar-title"><i data-lucide="zap" style="width:16px;"></i> Recommended</div>
            <% if (recommendedListings && recommendedListings.length > 0) { %>
                <% recommendedListings.forEach(item => { %>
                    <a href="/marketplace?search=<%= item.title %>" class="recommendation-card" style="display: flex; text-decoration: none;">
                        <img src="<%= item.media_url || '/images/default-item.jpg' %>" style="width:60px; height:60px; border-radius:12px; object-fit:cover;">
                        <div style="margin-left:12px; min-width:0;">
                            <div style="font-weight:700; font-size:0.85rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--text-main);"><%= item.title %></div>
                            <div style="color:var(--primary); font-weight:900; font-size:0.9rem;">$<%= parseFloat(item.price).toFixed(2) %></div>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <p style="font-size:0.8rem; color:var(--text-muted); text-align:center;">Browsing find for you...</p>
            <% } %>
        </div>
    </aside>
</div>

<a href="/marketplace/sell" class="fab-btn">
    <i data-lucide="plus"></i>
</a>

<!-- Success Toast -->
<div id="toast" style="position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 12px 30px; border-radius: 50px; font-weight: 800; z-index: 9999; display: none; box-shadow: 0 10px 30px rgba(0,0,0,0.3);"></div>

<%- include('partials/scripts') %>
<script src="https://unpkg.com/lucide@latest"></script>
<script>
    lucide.createIcons();

    function showToast(msg) {
        const toast = document.getElementById('toast');
        toast.innerText = msg;
        toast.style.display = 'block';
        setTimeout(() => toast.style.display = 'none', 3000);
    }

    async function handleFavorite(id, btn) {
        const res = await fetch('/api/marketplace/listings/' + id + '/favorite', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            btn.classList.toggle('active', data.favorited);
            showToast(data.favorited ? 'Added to wishlist! ❤️' : 'Removed from wishlist');
        }
    }

    async function handleFollow(sellerId, btn) {
        const res = await fetch('/api/marketplace/seller/favorite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sellerId })
        });
        const data = await res.json();
        if (data.success) {
            btn.innerHTML = data.favorited ? '<i data-lucide="user-check"></i>' : '<i data-lucide="user-plus"></i>';
            lucide.createIcons();
            showToast(data.favorited ? 'Following seller!' : 'Unfollowed seller');
        }
    }

    async function initOrder(listingId, sellerId, price, btn) {
        const title = btn.closest('.product-content').getAttribute('data-title');
        if (!confirm('Confirm purchase of "' + title + '" for $' + price.toFixed(2) + '?')) return;
        
        const res = await fetch('/api/marketplace/order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ listingId, sellerId, price })
        });
        const data = await res.json();
        if (data.success) {
            showToast('Order placed successfully! 🛍️');
            setTimeout(() => window.location.href = '/marketplace/orders', 1500);
        } else {
            alert(data.message || 'Failed to place order');
        }
    }
</script>