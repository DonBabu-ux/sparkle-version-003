<%- include('../partials/head', { title: 'My Shop | Sparkle Mall' }) %>

<style>
    :root {
        --primary: #E1306C;
        --secondary: #833AB4;
        --bg-main: #f8f9fa;
        --card-bg: #fff;
        --border: #efefef;
        --radius: 20px;
        --gradient: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    }

    body {
        background: var(--bg-main);
        padding-top: 80px;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .page-title {
        font-weight: 900;
        font-size: 2.22rem;
        background: var(--gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .listing-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 30px;
    }

    .shop-card {
        background: white;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1.5px solid var(--border);
        transition: 0.3s;
        display: flex;
        flex-direction: column;
    }

    .shop-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    .card-img-wrapper {
        height: 220px;
        position: relative;
    }

    .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .status-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        padding: 6px 15px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        backdrop-filter: blur(10px);
    }

    .status-active { background: rgba(76, 175, 80, 0.9); color: white; }
    .status-sold { background: rgba(0, 0, 0, 0.7); color: white; }

    .card-body {
        padding: 20px;
        flex: 1;
    }

    .item-title {
        font-weight: 800;
        font-size: 1.15rem;
        margin-bottom: 8px;
    }

    .item-price {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--primary);
        margin-bottom: 15px;
    }

    .card-actions {
        padding: 15px 20px;
        background: #fafafa;
        border-top: 1px solid var(--border);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .btn {
        padding: 10px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.85rem;
        border: none;
        cursor: pointer;
        transition: 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-primary { background: var(--gradient); color: white; }
    .btn-outline { background: white; border: 1.5px solid var(--border); color: #666; }
    .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
    .btn-danger { background: #fff1f0; color: #ff4d4f; }
    .btn-danger:hover { background: #ff4d4f; color: white; }
    .btn-success { background: #f6ffed; color: #52c41a; }
    .btn-success:hover { background: #52c41a; color: white; }

    .stat-bar {
        background: white;
        border-radius: var(--radius);
        padding: 25px;
        margin-bottom: 40px;
        display: flex;
        justify-content: space-around;
        border: 1.5px solid var(--border);
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--text-main);
        display: block;
    }

    .stat-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }
</style>

<div class="container">
    <div class="page-header">
        <h1 class="page-title">My Shop Dashboard</h1>
        <a href="/marketplace/sell" class="btn btn-primary" style="padding: 15px 30px; border-radius: 50px;">
            <i data-lucide="plus-circle"></i> New Listing
        </a>
    </div>

    <div class="stat-bar">
        <div class="stat-item">
            <span class="stat-value"><%= listings.length %></span>
            <span class="stat-label">Total Listings</span>
        </div>
        <div class="stat-item">
            <span class="stat-value"><%= listings.filter(l => l.is_sold).length %></span>
            <span class="stat-label">Items Sold</span>
        </div>
        <div class="stat-item">
            <span class="stat-value">$<%= listings.reduce((acc, l) => acc + (l.is_sold ? parseFloat(l.price) : 0), 0).toFixed(2) %></span>
            <span class="stat-label">Total Earnings</span>
        </div>
    </div>

    <div class="listing-grid">
        <% if (listings && listings.length > 0) { %>
            <% listings.forEach(listing => { %>
                <div class="shop-card">
                    <div class="card-img-wrapper">
                        <img src="<%= listing.thumbnail_url || '/images/default-item.jpg' %>" class="card-img" alt="Item">
                        <span class="status-badge <%= listing.is_sold ? 'status-sold' : 'status-active' %>">
                            <%= listing.is_sold ? 'Sold' : 'Active' %>
                        </span>
                    </div>

                    <div class="card-body">
                        <h3 class="item-title"><%= listing.title %></h3>
                        <div class="item-price">$<%= parseFloat(listing.price).toFixed(2) %></div>
                        <div style="font-size: 0.85rem; color: #888; font-weight: 700;">
                            <i data-lucide="calendar" style="width:14px; height:14px; display:inline-block;"></i> 
                            <%= new Date(listing.created_at).toLocaleDateString() %>
                        </div>
                    </div>

                    <div class="card-actions">
                        <a href="/marketplace/listings/<%= listing.listing_id %>" class="btn btn-outline" title="Public View">
                            <i data-lucide="external-link"></i> View
                        </a>
                        <% if (!listing.is_sold) { %>
                            <button onclick="markAsSold('<%= listing.listing_id %>')" class="btn btn-success">
                                <i data-lucide="check-circle"></i> Sell
                            </button>
                        <% } else { %>
                            <button onclick="relist('<%= listing.listing_id %>')" class="btn btn-outline">
                                <i data-lucide="rotate-ccw"></i> Relist
                            </button>
                        <% } %>
                        <a href="/marketplace/edit-listing/<%= listing.listing_id %>" class="btn btn-outline">
                            <i data-lucide="edit-3"></i> Edit
                        </a>
                        <button onclick="deleteListing('<%= listing.listing_id %>')" class="btn btn-danger">
                            <i data-lucide="trash-2"></i> Del
                        </button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="grid-column: 1 / -1; text-align: center; padding: 100px 0;">
                <i data-lucide="store" style="width:80px; height:80px; color:#ddd; margin-bottom:20px;"></i>
                <h2>Your shop is empty</h2>
                <p>Start selling items to your fellow students!</p>
                <a href="/marketplace/sell" class="btn btn-primary" style="display:inline-flex; margin-top:20px; padding: 15px 40px;">List Your First Item</a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/scripts') %>
<script src="https://unpkg.com/lucide@latest"></script>
<script>
    lucide.createIcons();

    async function markAsSold(id) {
        if (!confirm('Mark this item as SOLD? This will move it to your sales history.')) return;
        const res = await fetch('/api/marketplace/listings/' + id + '/sold', { method: 'POST' });
        if ((await res.json()).success) window.location.reload();
    }

    async function relist(id) {
        if (!confirm('Relist this item for sale?')) return;
        const res = await fetch('/api/marketplace/listings/' + id + '/relist', { method: 'POST' });
        if ((await res.json()).success) window.location.reload();
    }

    async function deleteListing(id) {
        if (!confirm('Permanently delete this listing? This action cannot be undone.')) return;
        const res = await fetch('/api/marketplace/listings/' + id, { method: 'DELETE' });
        if ((await res.json()).success) window.location.reload();
    }
</script>