        display: flex;
        align-items: center;
        gap: 6px;
    }
    .active-friends-title::after {
        content: '';
        width: 6px;
        height: 6px;
        background: #10b981;
        border-radius: 50%;
    }
    .active-friends-carousel {
        display: flex;
        gap: 15px;
        padding: 0 20px;
        overflow-x: auto;
        scrollbar-width: none;
    }
    .active-friends-carousel::-webkit-scrollbar { display: none; }
    
    .active-friend-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        min-width: 65px;
    }
    .af-avatar-wrapper {
