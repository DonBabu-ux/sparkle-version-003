        font-size: 11px;
        font-weight: 700;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 65px;
        text-align: center;
    }

    /* Sparkle Spinner */
    .spinner-pink {
        width: 24px;
        height: 24px;
        border: 2px solid rgba(255, 61, 109, 0.1);
        border-top: 2px solid var(--primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* Custom nav highlights */
    .nav-item[href="/messages"] { color: var(--primary) !important; font-weight: 700; }
    
    body { padding-bottom: 0 !important; } /* Messages uses full height */
</style>
<!-- EmojiMart for 3600+ emojis -->
<script src="https://cdn.jsdelivr.net/npm/@emoji-mart/data"></script>
<script src="https://cdn.jsdelivr.net/npm/emoji-mart@latest/dist/browser.js"></script>

<!-- ================================================================
     UNIFIED PICKER PANEL — position:fixed body-level
     Tab 1: Emoji (EmojiMart, 3600+)
     Tab 2: GIF   (Giphy API)
     Tab 3: Sticker (Giphy Stickers)
     ================================================================ -->
<div id="emojiPickerPanel" style="
    display: none;
    position: fixed;
    bottom: 70px;
    left: 0;
    right: 0;
    height: 360px;
    background: #1a2530;
    border-top: 1px solid #2a3942;
    flex-direction: column;
    z-index: 99999;
    overflow: hidden !important;
    overscroll-behavior: contain;
    box-shadow: 0 -8px 30px rgba(0,0,0,0.6);
    animation: pickerSlideUp 0.2s cubic-bezier(0.4,0,0.2,1);
">

    <!-- ── HEADER ── -->
    <div style="display:flex; align-items:center; justify-content:space-between; background:#111b21; padding:10px 15px; border-bottom:1px solid #2a3942; flex-shrink:0; position:relative; z-index:10;">
        <span style="color:#8696a0; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px;">Messaging Picker</span>
        <button onclick="window.sparkChat.closeEmojiPicker()" style="background:none; border:none; color:#8696a0; font-size:26px; cursor:pointer; display:flex; align-items:center; justify-content:center; padding:10px; margin:-10px; position:relative; z-index:20;">
            <i class="bi bi-x"></i>
        </button>
    </div>

    <!-- ── TAB BAR ───────────────────────────────────────────── -->
    <div id="pickerTabBar" style="
        display: flex;
        background: #111b21;
        border-bottom: 1px solid #2a3942;
        flex-shrink: 0;
        position: relative;
        z-index: 100;
        pointer-events: auto;
    ">
        <button id="tabBtnEmoji" onclick="window.sparkChat.switchPickerTab('emoji')"
            style="flex:1; background:none; border:none; border-bottom:3px solid #00a884;
                   color:#00a884; font-size:13px; font-weight:700; padding:10px 0; cursor:pointer;
                   display:flex; align-items:center; justify-content:center; gap:5px;">
            <i class="bi bi-emoji-smile-fill" style="font-size:16px; pointer-events:none;"></i> Emoji
        </button>
        <button id="tabBtnGif" onclick="window.sparkChat.switchPickerTab('gif')"
            style="flex:1; background:none; border:none; border-bottom:3px solid transparent;
                   color:#8696a0; font-size:13px; font-weight:700; padding:10px 0; cursor:pointer;
                   display:flex; align-items:center; justify-content:center; gap:5px;">
            <span style="font-size:11px; font-weight:900; background:#53bdeb; color:#000; padding:1px 5px; border-radius:3px; pointer-events:none;">GIF</span>
        </button>
        <button id="tabBtnSticker" onclick="window.sparkChat.switchPickerTab('sticker')"
            style="flex:1; background:none; border:none; border-bottom:3px solid transparent;
                   color:#8696a0; font-size:13px; font-weight:700; padding:10px 0; cursor:pointer;
                   display:flex; align-items:center; justify-content:center; gap:5px;">
            <i class="bi bi-sticky-fill" style="font-size:16px; pointer-events:none;"></i> Stickers
        </button>
    </div>

    <div id="pickerTabEmoji" style="flex:1; display:flex; flex-direction:column; overflow:hidden; min-height:0; max-height:100%;">
        <!-- EmojiMart will be appended here as a web component -->
        <div id="emojiMartMount" style="flex:1; width:100%; height:100%; overflow:hidden; display:flex; flex-direction:column; min-height:0; -webkit-overflow-scrolling:touch !important; touch-action:pan-y !important;"></div>
    </div>

    <!-- ── GIF TAB ───────────────────────────────────────────── -->
    <div id="pickerTabGif" style="flex:1; display:none; flex-direction:column; overflow:hidden;">
        <div style="padding:8px 10px; background:#111b21; flex-shrink:0;">
            <input id="gifSearchInput" type="text" placeholder="🔍  Search GIFs..."
                   oninput="window.sparkChat.searchGiphy(this.value)"
                   style="width:100%; background:#2a3942; border:none; padding:8px 14px; border-radius:20px;
                          color:#fff; font-size:14px; outline:none; box-sizing:border-box;
                          caret-color:#00a884;">
        </div>
        <div id="gifResultsGrid" style="
            flex: 1;
            min-height: 0;
            max-height: 280px;
            overflow-y: auto !important;
            -webkit-overflow-scrolling: touch !important;
            touch-action: pan-y !important;
            padding: 10px;
            display: grid !important;
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 8px !important;
            align-content: flex-start;
        ">
            <!-- GIFs loaded here -->
        </div>
    </div>

    <!-- ── STICKER TAB ───────────────────────────────────────── -->
    <div id="pickerTabSticker" style="flex:1; display:none; flex-direction:column; overflow:hidden; min-height:0;">
        <div style="padding:8px 10px; background:#111b21; flex-shrink:0;">
            <input id="stickerSearchInput" type="text" placeholder="🔍  Search Stickers..."
                   oninput="window.sparkChat.searchGiphyStickers(this.value)"
                   style="width:100%; background:#2a3942; border:none; padding:8px 14px; border-radius:20px;
                          color:#fff; font-size:14px; outline:none; box-sizing:border-box;
                          caret-color:#00a884;">
        </div>
        <div id="stickerResultsGrid" style="
            flex: 1;
            min-height: 0;
            max-height: 280px;
            overflow-y: auto !important;
            -webkit-overflow-scrolling: touch !important;
            touch-action: pan-y !important;
            padding: 10px;
            display: grid !important;
            grid-template-columns: repeat(3, 1fr) !important;
            gap: 10px !important;
            align-content: flex-start;
        ">
            <!-- Stickers loaded here -->
        </div>
    </div>

</div>

<style>
@keyframes pickerSlideUp {
    from { transform: translateY(100%); opacity: 0; }
    to   { transform: translateY(0);   opacity: 1; }
}
/* EmojiMart dark theme overrides */
em-emoji-picker {
    --background-rgb: 26, 37, 48;
    --border-radius: 0;
    --category-icon-size: 18px;
    --color-border: #2a3942;
    --color-border-over: #3a4952;
    --font-family: inherit;
    --input-border-radius: 20px;
    --input-padding: 6px 14px;
    --rgb-background: 26, 37, 48;
    --rgb-color: 233, 237, 239;
    --rgb-input: 42, 57, 66;
    --rgb-accent: 0, 168, 132;
    height: 100%;
    width: 100%;
}
</style>

</body>
</html>