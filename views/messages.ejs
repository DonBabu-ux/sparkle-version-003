        <div class="action-item" onclick="sparkChat.handleArchiveChat()" style="padding:12px; display:flex; gap:15px; align-items:center; cursor:pointer; color:#fff;">
            <i class="bi bi-archive-fill"></i> Archive Chat
        </div>
        <div class="action-item" onclick="sparkChat.handleMuteNotifications()" style="padding:12px; display:flex; gap:15px; align-items:center; cursor:pointer; color:#fff;">
            <i class="bi bi-bell-slash-fill"></i> Mute Notifications
        </div>
        <div class="action-item text-danger" onclick="sparkChat.handleDeleteChat()" style="padding:12px; display:flex; gap:15px; align-items:center; cursor:pointer;">
            <i class="bi bi-trash-fill"></i> Delete Chat
        </div>
        <div class="action-item text-danger" onclick="sparkChat.handleBlockUser()" style="padding:12px; display:flex; gap:15px; align-items:center; cursor:pointer;">
            <i class="bi bi-slash-circle-fill"></i> Block User
        </div>
    </div>
</div>

<!-- Profile Picture Expanded Modal -->
<div id="pfpExpandModal" class="wa-modal-overlay" style="display:none; background:rgba(0,0,0,0.9); transition:none;" onclick="this.style.display='none'">
    <div style="position:absolute; top:20px; left:0; width:100%; display:flex; justify-content:space-between; padding:0 20px; align-items:center; pointer-events:none;">
        <span id="expandedPartnerName" style="color:#fff; font-size:18px; font-weight:600; pointer-events:auto;">Username</span>
        <i class="bi bi-x-lg" style="color:#fff; font-size:24px; cursor:pointer; pointer-events:auto;"></i>
    </div>
    <img id="expandedPfp" src="" style="width:100%; max-width:500px; aspect-ratio:1/1; object-fit:cover; animation: zoomIn 0.2s ease-out;">
</div>

<!-- Modal Logic Refinement -->
<style>
.action-item:hover { background: #111b21; border-radius: 8px; }
.wa-modal-overlay { 
    position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
    background: rgba(0,0,0,0.85); z-index: 10000; 
    display: flex; justify-content: center; align-items: center; 
}
.wa-modal-content { 
    background: #222; border-radius: 20px; 
    width: 95%; max-width: 450px; 
    max-height: 90vh; overflow-y: auto; 
    display: flex; flex-direction: column;
    animation: modalIn 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
}
.disappearing-active .wa-composer-input-wrapper {
    border: 2px dashed #00a884 !important;
}

@keyframes zoomIn { from { transform:scale(0.8); opacity:0; } to { transform:scale(1); opacity:1; } }

@media (max-width: 768px) {
    .wa-modal-content.full-mobile {
        width: 100%; height: 100%; max-height: 100%; border-radius: 0; 
    }
}
@keyframes modalIn { from { transform: scale(0.85); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>

<%- include('partials/bottom-nav') %>

<!-- Scripts -->
<script src="/socket.io/socket.io.js"></script>
<script>
    function safeParse(jsonString) {
      try { return JSON.parse(jsonString); } catch (e) { return {}; }
    }
    const currentUserDataStr = '<%- Buffer.from(JSON.stringify(user || {})).toString("base64") %>';
    const currentUserData = safeParse(atob(currentUserDataStr));
    window.sparkleUser = { user_id: currentUserData.user_id || currentUserData.userId || null, username: currentUserData.username || null, name: currentUserData.name || null };
</script>
<script src="/js/messaging-v3.js"></script>

<style>
    /* Active Friends Section */
    .active-friends-section {
        padding: 15px 0 10px;
        border-bottom: 1px solid #f1f5f9;
        margin-bottom: 10px;
    }
    .active-friends-title {
        font-size: 13px;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        padding: 0 20px;
