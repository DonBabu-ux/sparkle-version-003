<%- include('partials/head', { title: 'Messages' }) %>

<link rel="stylesheet" href="/css/messaging-v3.css">
<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div id="mainContent" class="messaging-page">
    <div class="messaging-layout">
        
        <!-- SIDEBAR -->
        <aside class="conversation-sidebar">
            <div class="sidebar-header">
                <h1>Conversations</h1>
                <div class="search-bar-container">
                    <i class="bi bi-search"></i>
                    <input type="text" id="sidebarSearch" class="sidebar-search" placeholder="Search chats or friends...">
                </div>
            </div>

            <!-- Active Friends -->
            <div class="active-friends-section" id="activeFriendsSection">
                <h4 class="active-friends-title">Active Friends</h4>
                <div class="active-friends-carousel" id="activeFriendsCarousel">
                    <div class="chat-loader"><div class="spinner-pink"></div></div>
                </div>
            </div>

            <!-- List -->
            <div class="conversation-list" id="conversationList">
                <div class="chat-loader" style="display: flex; justify-content: center; padding: 40px;">
                    <div class="spinner-pink"></div>
                </div>
            </div>
        </aside>

        <!-- CHAT MAIN -->
        <main class="chat-main" id="chatMain" style="display: none;">
            <header class="chat-banner" id="chatBanner">
                <div class="chat-banner-left">
                    <i class="bi bi-chevron-left mobile-back-btn" onclick="closeChat()"></i>
                    <img id="bannerAvatar" src="" class="banner-avatar">
                    <div class="banner-info">
                        <h2 id="bannerName">Loading...</h2>
                        <span id="bannerStatus" class="banner-status">Offline</span>
                    </div>
                </div>
                <div class="chat-actions">
                    <div class="header-search-wrap" id="headerSearchWrap" style="display: none;">
                        <input type="text" id="chatMsgSearch" placeholder="Search in chat...">
                        <i class="bi bi-x-lg" onclick="sparkChat.toggleChatSearch(false)"></i>
                    </div>
                    <i class="bi bi-search" onclick="sparkChat.toggleChatSearch(true)"></i>
                    <i class="bi bi-telephone"></i>
                    <i class="bi bi-camera-video"></i>
                    <i class="bi bi-three-dots-vertical"></i>
                </div>
            </header>

            <div class="messages-container" id="messagesContainer">
                <!-- Messages go here -->
            </div>

            <footer class="chat-composer" id="chatComposer">
                <input type="file" id="mediaUpload" accept="image/*,video/*" hidden>
                <div class="composer-actions">
                    <i class="bi bi-plus-lg"></i>
                    <i class="bi bi-image"></i>
                    <i class="bi bi-emoji-smile"></i>
                    <i class="bi bi-mic"></i>
                </div>
                <div class="composer-top">
                    <div class="input-wrapper">
                        <textarea id="messageInput" class="composer-textarea" placeholder="Type a message..." rows="1"></textarea>
                    </div>
                    <button class="msg-send-btn" id="sendBtn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </footer>
        </main>

        <!-- EMPTY STATE WINDOW -->
        <div class="empty-window" id="chatEmptyWindow">
            <div class="empty-content">
                <i class="bi bi-chat-heart"></i>
                <h2>Spark Your Connections</h2>
                <p>Select a friend from the left sidebar to start messaging in real-time. Share your sparkles!</p>
                <button class="btn-primary" style="margin-top: 20px; border-radius: 20px; padding: 10px 25px;" onclick="window.location.href='/connect'">Find New Friends</button>
            </div>
        </div>

    </div>
</div>

<%- include('partials/navbar') %>
<%- include('partials/bottom-nav') %>

<!-- Scripts -->
<script src="/socket.io/socket.io.js"></script>
<script>
    const user = <%- JSON.stringify(user || {}) %>;
    window.sparkleUser = {
        user_id: user.user_id || user.userId || null,
        username: user.username || null,
        name: user.name || null
    };
</script>
<script src="/js/messaging-v3.js"></script>

<style>
    /* Active Friends Section */
    .active-friends-section {
        padding: 15px 0 10px;
        border-bottom: 1px solid #f1f5f9;
        margin-bottom: 10px;
    }
    .active-friends-title {
        font-size: 13px;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        padding: 0 20px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .active-friends-title::after {
        content: '';
        width: 6px;
        height: 6px;
        background: #10b981;
        border-radius: 50%;
    }
    .active-friends-carousel {
        display: flex;
        gap: 15px;
        padding: 0 20px;
        overflow-x: auto;
        scrollbar-width: none;
    }
    .active-friends-carousel::-webkit-scrollbar { display: none; }
    
    .active-friend-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        min-width: 65px;
    }
    .af-avatar-wrapper {
        position: relative;
        width: 48px;
        height: 48px;
    }
    .af-avatar-wrapper img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .af-online-dot {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 12px;
        height: 12px;
        background: #10b981;
        border: 2px solid white;
        border-radius: 50%;
    }
    .af-name {
        font-size: 11px;
        font-weight: 700;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 65px;
        text-align: center;
    }

    /* Sparkle Spinner */
    .spinner-pink {
        width: 24px;
        height: 24px;
        border: 2px solid rgba(255, 61, 109, 0.1);
        border-top: 2px solid var(--primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* Custom nav highlights */
    .nav-item[href="/messages"] { color: var(--primary) !important; font-weight: 700; }
    
    body { padding-bottom: 0 !important; } /* Messages uses full height */
</style>

</body>
</html>