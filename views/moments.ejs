<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Sparkle - Moments</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #000;
            --text-primary: #fff;
            --accent-pink: #FF3D6D;
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.15);
        }

        body {
            background: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            overflow: hidden;
        }

        .app-container {
            position: relative;
            height: 100vh;
            max-width: 480px;
            margin: 0 auto;
            background: var(--bg-primary);
            overflow: hidden;
        }

        /* Main Feed - Vertical Scroller */
        .feed-scroller {
            height: 100%;
            overflow-y: scroll;
            scroll-snap-type: y mandatory;
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        .feed-scroller::-webkit-scrollbar {
            display: none;
        }

        /* Video Card */
        .video-card {
            position: relative;
            height: 100%;
            width: 100%;
            scroll-snap-align: start;
            background: #000;
        }

        .video-wrapper {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            cursor: pointer;
        }

        .video-element {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Video Info Overlay - Bottom Section */
        .video-info-overlay {
            position: absolute;
            bottom: 80px;
            left: 16px;
            right: 80px;
            z-index: 10;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .user-info-row {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
        }

        .user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 2px solid var(--accent-pink);
            overflow: hidden;
        }

        .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .username {
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .follow-btn {
            font-size: 12px;
            color: var(--accent-pink);
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-block;
            padding: 2px 0;
        }

        .follow-btn.following {
            color: rgba(255, 255, 255, 0.7);
        }

        .follow-btn:hover {
            transform: scale(1.05);
        }

        .video-caption {
            font-size: 14px;
            line-height: 1.4;
            color: #fff;
            text-shadow: 0 1px 2px rgba(0,0,0,0.8);
            margin-top: 4px;
        }

        .hashtags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 4px;
        }

        .hashtag {
            font-size: 13px;
            color: var(--accent-pink);
            font-weight: 500;
            text-shadow: 0 1px 2px rgba(0,0,0,0.8);
            cursor: pointer;
        }

        .hashtag:hover {
            text-decoration: underline;
        }

        /* Side Actions - Right Side */
        .side-actions {
            position: absolute;
            right: 12px;
            bottom: 100px;
            z-index: 15;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        .action-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            cursor: pointer;
        }

        .action-circle {
            width: 48px;
            height: 48px;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(8px);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
            cursor: pointer;
            transition: transform 0.2s;
        }

        .action-circle:active {
            transform: scale(0.9);
        }

        .action-circle.liked i {
            color: var(--accent-pink);
            animation: heartBeat 0.3s ease-out;
        }

        @keyframes heartBeat {
            0% { transform: scale(1); }
            50% { transform: scale(1.3); }
            100% { transform: scale(1); }
        }

        .action-count {
            font-size: 12px;
            font-weight: 600;
            color: #fff;
            text-shadow: 0 1px 2px rgba(0,0,0,0.8);
        }

        /* Header Section */
        .app-header {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            z-index: 30;
            padding: 12px 16px;
            background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 70%, transparent 100%);
            pointer-events: none;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            pointer-events: auto;
        }

        .logo {
            font-size: 24px;
            font-weight: 900;
            letter-spacing: 1px;
            color: var(--accent-pink);
            text-shadow: 0 0 20px rgba(255, 61, 109, 0.5);
        }

        .header-icons {
            display: flex;
            gap: 12px;
        }

        .header-icon {
            width: 40px;
            height: 40px;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(8px);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.15);
            cursor: pointer;
        }

        /* Search Section */
        .search-section {
            position: relative;
            pointer-events: auto;
            margin-bottom: 12px;
        }

        .search-bar {
            display: flex;
            align-items: center;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 8px 16px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
        }

        .search-bar:focus-within {
            background: rgba(0, 0, 0, 0.7);
            border-color: var(--accent-pink);
            box-shadow: 0 0 15px rgba(255, 61, 109, 0.3);
        }

        .search-bar i {
            color: rgba(255, 255, 255, 0.7);
            font-size: 16px;
            margin-right: 12px;
        }

        .search-bar input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: #fff;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
        }

        .search-bar input::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .clear-search {
            cursor: pointer;
            color: rgba(255, 255, 255, 0.5);
            padding: 4px;
            display: none;
        }

        .clear-search:hover {
            color: var(--accent-pink);
        }

        /* Search History Dropdown */
        .search-history {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: rgba(20, 20, 20, 0.98);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            margin-top: 8px;
            padding: 16px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: none;
            z-index: 40;
            max-height: 300px;
            overflow-y: auto;
        }

        .search-history.show {
            display: block;
        }

        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            color: rgba(255, 255, 255, 0.7);
            font-size: 14px;
            padding-bottom: 8px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .clear-history {
            color: var(--accent-pink);
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
        }

        .history-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
        }

        .history-item:last-child {
            border-bottom: none;
        }

        .history-left {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #fff;
        }

        .history-left i {
            color: var(--accent-pink);
            font-size: 14px;
        }

        .delete-history-item {
            color: rgba(255, 255, 255, 0.5);
            cursor: pointer;
            padding: 4px;
        }

        .delete-history-item:hover {
            color: var(--accent-pink);
        }

        /* Category Filters */
        .categories-wrapper {
            overflow-x: auto;
            scrollbar-width: none;
            -ms-overflow-style: none;
            pointer-events: auto;
            margin-top: 8px;
        }

        .categories-wrapper::-webkit-scrollbar {
            display: none;
        }

        .categories-list {
            display: flex;
            gap: 10px;
            padding: 4px 0;
        }

        .category-pill {
            font-size: 13px;
            font-weight: 500;
            color: #fff;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            padding: 8px 18px;
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            white-space: nowrap;
            cursor: pointer;
            transition: all 0.2s;
        }

        .category-pill:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.3);
        }

        .category-pill.active {
            background: var(--accent-pink);
            border-color: var(--accent-pink);
        }

        /* Bottom Navigation */
        .bottom-nav {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 70px;
            background: linear-gradient(to top, rgba(0,0,0,0.98) 0%, rgba(0,0,0,0.8) 70%, transparent 100%);
            backdrop-filter: blur(5px);
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 25;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            color: rgba(255, 255, 255, 0.6);
            font-size: 10px;
            text-decoration: none;
            transition: color 0.2s;
            cursor: pointer;
        }

        .nav-item:hover {
            color: #fff;
        }

        .nav-item.active {
            color: #fff;
        }

        .nav-item i {
            font-size: 20px;
        }

        .add-button {
            width: 45px;
            height: 30px;
            background: #fff;
            color: #000;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.3);
            transition: transform 0.2s;
        }

        .add-button:hover {
            transform: scale(1.05);
        }

        /* Long Press Menu */
        .long-press-menu {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(20, 20, 20, 0.98);
            backdrop-filter: blur(10px);
            border-top-left-radius: 20px;
            border-top-right-radius: 20px;
            padding: 20px;
            transform: translateY(100%);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 50;
            max-width: 480px;
            margin: 0 auto;
        }

        .long-press-menu.show {
            transform: translateY(0);
        }

        .menu-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .menu-header h3 {
            font-size: 18px;
            font-weight: 600;
        }

        .close-menu {
            font-size: 24px;
            cursor: pointer;
            color: rgba(255, 255, 255, 0.7);
        }

        .menu-items {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .menu-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            padding: 10px;
            border-radius: 12px;
            transition: background 0.2s;
        }

        .menu-item:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .menu-icon {
            width: 50px;
            height: 50px;
            background: rgba(255, 61, 109, 0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: var(--accent-pink);
        }

        .menu-label {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.8);
        }

        /* Skeleton Loading */
        .skeleton-card {
            position: relative;
            height: 100%;
            width: 100%;
            scroll-snap-align: start;
            background: #000;
        }

        .skeleton-media {
            width: 100%;
            height: 100%;
            background: linear-gradient(110deg, #1a1a1a 8%, #2a2a2a 18%, #1a1a1a 33%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }

        .skeleton-overlay {
            position: absolute;
            bottom: 80px;
            left: 16px;
            right: 80px;
            z-index: 2;
        }

        .skeleton-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            margin-bottom: 12px;
            animation: pulse 1.5s ease-in-out infinite;
        }

        .skeleton-line {
            height: 16px;
            width: 60%;
            background: rgba(255,255,255,0.1);
            border-radius: 8px;
            margin-bottom: 10px;
            animation: pulse 1.5s ease-in-out infinite;
        }

        .skeleton-line.short {
            width: 40%;
        }

        .skeleton-line.long {
            width: 80%;
        }

        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        @keyframes pulse {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.6; }
        }

        /* End Message */
        .end-message {
            height: 100px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: rgba(255, 255, 255, 0.5);
            gap: 10px;
            scroll-snap-align: none;
        }

        .end-message i {
            font-size: 30px;
            color: var(--accent-pink);
        }

        /* Loading Screen */
        .loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #000;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(255, 61, 109, 0.3);
            border-top-color: var(--accent-pink);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Double Tap Heart */
        .floating-heart {
            position: fixed;
            font-size: 80px;
            color: var(--accent-pink);
            pointer-events: none;
            z-index: 200;
            animation: floatHeart 0.8s ease-out forwards;
        }

        @keyframes floatHeart {
            0% {
                transform: scale(0) rotate(-10deg);
                opacity: 0;
            }
            50% {
                transform: scale(1.2) rotate(5deg);
                opacity: 1;
            }
            100% {
                transform: scale(1) rotate(0);
                opacity: 0;
                transform: translateY(-100px);
            }
        }

        /* Toast Notification */
        .toast-notification {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px);
            color: white;
            padding: 12px 24px;
            border-radius: 30px;
            font-size: 14px;
            z-index: 60;
            border: 1px solid var(--accent-pink);
            box-shadow: 0 4px 15px rgba(255, 61, 109, 0.3);
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translate(-50%, 20px);
            }
            to {
                opacity: 1;
                transform: translate(-50%, 0);
            }
        }
    </style>
</head>

<body>
    <div class="app-container">
        <!-- Main Feed -->
        <div class="feed-scroller" id="feedContainer"></div>

        <!-- Header -->
        <div class="app-header">
            <div class="header-top">
                <div class="logo">SPARKLE</div>
                <div class="header-icons">
                    <div class="header-icon" onclick="toggleMute()" id="muteBtn">
                        <i class="fas fa-volume-mute"></i>
                    </div>
                    <div class="header-icon" onclick="goBack()">
                        <i class="fas fa-times"></i>
                    </div>
                </div>
            </div>

            <!-- Search Section with Input -->
            <div class="search-section">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" id="searchInput" placeholder="Search videos..." autocomplete="off">
                    <i class="fas fa-times-circle clear-search" id="clearSearch" onclick="clearSearch()"></i>
                </div>

                <!-- Search History Dropdown -->
                <div class="search-history" id="searchHistory">
                    <div class="history-header">
                        <span>Recent searches</span>
                        <span class="clear-history" onclick="clearAllHistory(event)">Clear all</span>
                    </div>
                    <div id="historyList"></div>
                </div>
            </div>

            <!-- Categories -->
            <div class="categories-wrapper">
                <div class="categories-list" id="categoryList">
                    <span class="category-pill active" data-cat="all">All</span>
                    <span class="category-pill" data-cat="sports">Sports</span>
                    <span class="category-pill" data-cat="music">Music</span>
                    <span class="category-pill" data-cat="food">Food</span>
                    <span class="category-pill" data-cat="travel">Travel</span>
                    <span class="category-pill" data-cat="tech">Tech</span>
                    <span class="category-pill" data-cat="fashion">Fashion</span>
                    <span class="category-pill" data-cat="dance">Dance</span>
                    <span class="category-pill" data-cat="fitness">Fitness</span>
                    <span class="category-pill" data-cat="gaming">Gaming</span>
                    <span class="category-pill" data-cat="lifestyle">Lifestyle</span>
                </div>
            </div>
        </div>

        <!-- Bottom Navigation -->
        <div class="bottom-nav">
            <a href="/dashboard" class="nav-item">
                <i class="fas fa-home"></i>
                <span>Home</span>
            </a>
            <a href="/connect" class="nav-item">
                <i class="fas fa-search"></i>
                <span>Discover</span>
            </a>
            <div class="nav-item active" onclick="location.href='/moments'">
                <div class="add-button"><i class="fas fa-plus"></i></div>
            </div>
            <a href="/messages" class="nav-item">
                <i class="fas fa-comment"></i>
                <span>Chats</span>
            </a>
            <a href="/profile" class="nav-item">
                <i class="fas fa-user"></i>
                <span>Me</span>
            </a>
        </div>

        <!-- Long Press Menu -->
        <div class="long-press-menu" id="longPressMenu">
            <div class="menu-header">
                <h3>Video options</h3>
                <span class="close-menu" onclick="hideLongPressMenu()">&times;</span>
            </div>
            <div class="menu-items">
                <div class="menu-item" onclick="reportVideo()">
                    <div class="menu-icon"><i class="fas fa-flag"></i></div>
                    <span class="menu-label">Report</span>
                </div>
                <div class="menu-item" onclick="saveToCollection()">
                    <div class="menu-icon"><i class="fas fa-bookmark"></i></div>
                    <span class="menu-label">Save</span>
                </div>
                <div class="menu-item" onclick="shareVideo()">
                    <div class="menu-icon"><i class="fas fa-share"></i></div>
                    <span class="menu-label">Share</span>
                </div>
                <div class="menu-item" onclick="downloadVideo()">
                    <div class="menu-icon"><i class="fas fa-download"></i></div>
                    <span class="menu-label">Download</span>
                </div>
                <div class="menu-item" onclick="hideVideo()">
                    <div class="menu-icon"><i class="fas fa-eye-slash"></i></div>
                    <span class="menu-label">Not interested</span>
                </div>
                <div class="menu-item" onclick="copyLink()">
                    <div class="menu-icon"><i class="fas fa-link"></i></div>
                    <span class="menu-label">Copy link</span>
                </div>
            </div>
        </div>

        <!-- Loading Screen -->
        <div class="loading-screen" id="loadingScreen">
            <div class="spinner"></div>
        </div>
    </div>

    <!-- Share Modal Partial -->
    <div id="shareModal" class="share-modal" style="display: none;">
        <div class="share-modal-content">
            <div class="share-modal-header">
                <h3>Share to...</h3>
                <i class="fas fa-times" onclick="closeShareModal()"></i>
            </div>
            <div class="share-options">
                <div class="share-option" onclick="shareTo('facebook')">
                    <i class="fab fa-facebook"></i>
                    <span>Facebook</span>
                </div>
                <div class="share-option" onclick="shareTo('twitter')">
                    <i class="fab fa-twitter"></i>
                    <span>Twitter</span>
                </div>
                <div class="share-option" onclick="shareTo('whatsapp')">
                    <i class="fab fa-whatsapp"></i>
                    <span>WhatsApp</span>
                </div>
                <div class="share-option" onclick="shareTo('telegram')">
                    <i class="fab fa-telegram"></i>
                    <span>Telegram</span>
                </div>
                <div class="share-option" onclick="shareTo('copy')">
                    <i class="fas fa-link"></i>
                    <span>Copy Link</span>
                </div>
            </div>
        </div>
    </div>

    <style>
        .share-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .share-modal-content {
            background: #1a1a1a;
            border-radius: 20px;
            padding: 20px;
            width: 90%;
            max-width: 400px;
            border: 1px solid var(--accent-pink);
        }

        .share-modal-header {
