        // Show Skeleton
        function showSkeleton(count = 3) {
            const container = document.getElementById('feedContainer');
            let skeleton = '';
            for (let i = 0; i < count; i++) {
                skeleton += `
                    <div class="skeleton-card">
                        <div class="skeleton-media"></div>
                        <div class="skeleton-overlay">
                            <div class="skeleton-avatar"></div>
                            <div class="skeleton-line long"></div>
                            <div class="skeleton-line"></div>
                            <div class="skeleton-line short"></div>
                        </div>
                    </div>
                `;
            }
            container.innerHTML = skeleton;
        }

        // Hide Loading Screen
        function hideLoadingScreen() {
            setTimeout(() => {
                document.getElementById('loadingScreen').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('loadingScreen').style.display = 'none';
                }, 500);
            }, 1500);
        }

        // Render Feed
        function renderFeed(videos) {
            const container = document.getElementById('feedContainer');
            
            if (!videos || videos.length === 0) {
                container.innerHTML = `
                    <div class="video-card" style="display: flex; align-items: center; justify-content: center;">
                        <div style="text-align: center; padding: 40px;">
                            <i class="fas fa-video-slash" style="font-size: 60px; color: #FF3D6D; margin-bottom: 20px;"></i>
                            <h3 style="margin-bottom: 10px;">No videos found</h3>
                            <p style="color: rgba(255,255,255,0.5);">Try adjusting your search or filter</p>
                        </div>
                    </div>
                    <div class="end-message">
                        <i class="fas fa-check-circle"></i>
                        <span>That's all for now</span>
                    </div>
                `;
                return;
            }

            let html = videos.map(video => createVideoCard(video)).join('');
            html += `<div class="end-message">
                        <i class="fas fa-check-circle"></i>
                        <span>That's all for now</span>
                    </div>`;
            
            container.innerHTML = html;
        }

        // Create Video Card
        function createVideoCard(video) {
            const tags = video.caption.match(/#[a-zA-Z0-9_]+/g) || [];
            const cleanCaption = video.caption.replace(/#[a-zA-Z0-9_]+/g, '').trim();
            
            return `
                <div class="video-card" data-id="${video.moment_id}" data-category="${video.category}">
                    <div class="video-wrapper" 
                         ondblclick="handleDoubleTap(event, '${video.moment_id}')"
                         oncontextmenu="handleLongPress(event, '${video.moment_id}')"
                         ontouchstart="handleTouchStart(event, '${video.moment_id}')"
                         ontouchend="handleTouchEnd()">
                        <video class="video-element" loop playsinline muted="${isMuted}" preload="auto">
                            <source src="${video.video_url}" type="video/mp4">
                        </video>
                    </div>

                    <!-- Video Info Overlay -->
                    <div class="video-info-overlay">
                        <div class="user-info-row" onclick="goToProfile('${video.username}')">
                            <div class="user-avatar">
                                <img src="${video.avatar_url}" alt="${video.username}" onerror="this.src='https://randomuser.me/api/portraits/men/1.jpg'">
                            </div>
                            <div class="user-details">
                                <span class="username">@${video.username}</span>
                                <span class="follow-btn" onclick="toggleFollow(event, '${video.username}')" id="follow-${video.username}">Follow</span>
                            </div>
                        </div>
                        <div class="video-caption">${cleanCaption}</div>
                        <div class="hashtags">
                            ${tags.map(tag => `<span class="hashtag" onclick="searchHashtag('${tag}')">${tag}</span>`).join('')}
                        </div>
                    </div>

                    <!-- Side Actions -->
                    <div class="side-actions">
                        <div class="action-item">
                            <div class="action-circle" onclick="toggleLike('${video.moment_id}')" id="like-${video.moment_id}">
                                <i class="far fa-heart"></i>
                            </div>
                            <span class="action-count">${formatCount(video.likes)}</span>
                        </div>
                        <div class="action-item" onclick="openComments('${video.moment_id}')">
                            <div class="action-circle">
                                <i class="far fa-comment"></i>
                            </div>
                            <span class="action-count">${formatCount(video.comments)}</span>
                        </div>
                        <div class="action-item" onclick="shareVideo('${video.moment_id}')">
                            <div class="action-circle">
                                <i class="far fa-paper-plane"></i>
                            </div>
                            <span class="action-count">${formatCount(video.share_count)}</span>
                        </div>
                        <div class="action-item" onclick="saveToCollection('${video.moment_id}')">
                            <div class="action-circle">
                                <i class="far fa-bookmark"></i>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Setup Search Listener
        function setupSearchListener() {
            const searchInput = document.getElementById('searchInput');
            const clearBtn = document.getElementById('clearSearch');
            
            if (searchInput) {
                searchInput.addEventListener('input', function(e) {
                    const query = e.target.value.toLowerCase().trim();
                    clearBtn.style.display = query ? 'block' : 'none';
                    
                    if (query.length > 0) {
                        filterBySearch(query);
                    } else {
                        filteredMoments = [...moments];
                        if (currentCategory !== 'all') {
                            filteredMoments = filteredMoments.filter(v => v.category === currentCategory);
                        }
                        showSkeleton(2);
                        setTimeout(() => {
                            renderFeed(filteredMoments);
                            if (observer) {
                                observer.disconnect();
                                initVideoObserver();
                            }
                        }, 500);
                    }
                });

                searchInput.addEventListener('focus', function() {
                    toggleSearchHistory();
                });

                searchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        const query = e.target.value.trim();
                        if (query) {
                            addToHistory(query);
                            filterBySearch(query);
                            document.getElementById('searchHistory').classList.remove('show');
                        }
                    }
                });
            }
        }

        // Clear Search
        function clearSearch() {
            const searchInput = document.getElementById('searchInput');
            const clearBtn = document.getElementById('clearSearch');
            if (searchInput) {
                searchInput.value = '';
                clearBtn.style.display = 'none';
                filteredMoments = [...moments];
                if (currentCategory !== 'all') {
                    filteredMoments = filteredMoments.filter(v => v.category === currentCategory);
                }
                showSkeleton(2);
                setTimeout(() => {
                    renderFeed(filteredMoments);
                    if (observer) {
                        observer.disconnect();
                        initVideoObserver();
                    }
                }, 500);
                searchInput.focus();
            }
        }

        // Video Observer
        function initVideoObserver() {
            const options = { threshold: 0.7 };
            observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    const video = entry.target.querySelector('video');
                    if (!video) return;

                    if (entry.isIntersecting) {
                        video.play().catch(() => {});
                    } else {
                        video.pause();
                        video.currentTime = 0;
                    }
                });
            }, options);

            document.querySelectorAll('.video-card').forEach(card => observer.observe(card));
        }

        // Toggle Mute
        function toggleMute() {
            isMuted = !isMuted;
            const icon = document.querySelector('#muteBtn i');
            icon.className = isMuted ? 'fas fa-volume-mute' : 'fas fa-volume-up';
            
            document.querySelectorAll('video').forEach(video => {
                video.muted = isMuted;
            });
        }

        // Double Tap Like
        function handleDoubleTap(event, videoId) {
            const heart = document.createElement('i');
            heart.className = 'fas fa-heart floating-heart';
            heart.style.left = (event.clientX - 40) + 'px';
            heart.style.top = (event.clientY - 40) + 'px';
            document.body.appendChild(heart);
            
            setTimeout(() => heart.remove(), 800);
            toggleLike(videoId, true);
        }

        // Toggle Like
        function toggleLike(videoId, forceLike = false) {
            const likeBtn = document.getElementById(`like-${videoId}`);
            if (!likeBtn) return;
            
            const icon = likeBtn.querySelector('i');
            const isLiked = icon.classList.contains('fas');
            
            if (forceLike && isLiked) return;
            
            if (isLiked) {
                icon.className = 'far fa-heart';
                likeBtn.classList.remove('liked');
                updateLikeCount(videoId, -1);
            } else {
                icon.className = 'fas fa-heart';
                likeBtn.classList.add('liked');
                updateLikeCount(videoId, 1);
            }
        }

        function updateLikeCount(videoId, change) {
            const card = document.querySelector(`[data-id="${videoId}"]`);
            if (!card) return;
            
            const countSpan = card.querySelector('.action-item:first-child .action-count');
            let currentCount = parseInt(countSpan.textContent.replace(/[^0-9]/g, '')) || 0;
            countSpan.textContent = formatCount(currentCount + change);
        }

        // Toggle Follow (Clickable)
        function toggleFollow(event, username) {
            event.stopPropagation();
            const followBtn = document.getElementById(`follow-${username}`);
            const isFollowing = followBtn.classList.contains('following');
            
            if (isFollowing) {
                followBtn.textContent = 'Follow';
                followBtn.classList.remove('following');
                showToast(`Unfollowed @${username}`);
            } else {
                followBtn.textContent = 'Following';
                followBtn.classList.add('following');
                showToast(`Following @${username}`);
            }
        }

        // Long Press Handlers
        function handleLongPress(event, videoId) {
            event.preventDefault();
            currentVideoId = videoId;
            document.getElementById('longPressMenu').classList.add('show');
        }

        function handleTouchStart(event, videoId) {
            longPressTimer = setTimeout(() => {
                currentVideoId = videoId;
                document.getElementById('longPressMenu').classList.add('show');
            }, 500);
        }

        function handleTouchEnd() {
            clearTimeout(longPressTimer);
        }

        function hideLongPressMenu() {
            document.getElementById('longPressMenu').classList.remove('show');
        }

        // Long Press Menu Actions
        function reportVideo() {
            showToast('Video reported');
            hideLongPressMenu();
        }

        function saveToCollection(videoId) {
            const id = videoId || currentVideoId;
            const btn = document.querySelector(`[data-id="${id}"] .action-item:last-child .action-circle i`);
            if (btn) {
                btn.className = 'fas fa-bookmark';
                btn.style.color = '#FF3D6D';
            }
            showToast('Saved to collection');
            hideLongPressMenu();
        }

        function shareVideo(videoId) {
            if (shareManager) {
                shareManager.openShareModal(videoId || currentVideoId);
            } else {
                showToast('Share video');
            }
            hideLongPressMenu();
        }

        function downloadVideo() {
            showToast('Download started');
            hideLongPressMenu();
        }

        function hideVideo() {
            const card = document.querySelector(`[data-id="${currentVideoId}"]`);
            if (card) {
                card.style.display = 'none';
            }
            showToast('Video hidden');
            hideLongPressMenu();
        }

        function copyLink() {
            navigator.clipboard.writeText(window.location.href);
            showToast('Link copied to clipboard');
            hideLongPressMenu();
        }

        // Search History
        function toggleSearchHistory() {
            const history = document.getElementById('searchHistory');
            history.classList.toggle('show');
        }

        function renderSearchHistory() {
            const list = document.getElementById('historyList');
            if (searchHistory.length === 0) {
                list.innerHTML = '<div style="color: rgba(255,255,255,0.5); text-align: center; padding: 20px;">No recent searches</div>';
                return;
            }

            list.innerHTML = searchHistory.map(term => `
                <div class="history-item" onclick="searchFromHistory('${term}')">
                    <div class="history-left">
                        <i class="fas fa-history"></i>
                        <span>${term}</span>
                    </div>
                    <i class="fas fa-times delete-history-item" onclick="deleteHistoryItem('${term}', event)"></i>
                </div>
            `).join('');
        }

        function addToHistory(term) {
            if (!term || term.trim() === '') return;
            term = term.trim();
            searchHistory = [term, ...searchHistory.filter(t => t !== term)].slice(0, 10);
            localStorage.setItem('searchHistory', JSON.stringify(searchHistory));
            renderSearchHistory();
        }

        function deleteHistoryItem(term, event) {
            event.stopPropagation();
            searchHistory = searchHistory.filter(t => t !== term);
            localStorage.setItem('searchHistory', JSON.stringify(searchHistory));
            renderSearchHistory();
        }

        function clearAllHistory(event) {
            event.stopPropagation();
            searchHistory = [];
            localStorage.setItem('searchHistory', JSON.stringify(searchHistory));
            renderSearchHistory();
            showToast('Search history cleared');
        }

        function searchFromHistory(term) {
            document.getElementById('searchInput').value = term;
            document.getElementById('clearSearch').style.display = 'block';
            filterBySearch(term);
            toggleSearchHistory();
        }

        // Search by hashtag
        function searchHashtag(tag) {
            const searchTerm = tag.replace('#', '');
            document.getElementById('searchInput').value = searchTerm;
            document.getElementById('clearSearch').style.display = 'block';
            filterBySearch(searchTerm);
        }

        // Filter by search
        function filterBySearch(term) {
            addToHistory(term);
            showSkeleton(2);
            
            setTimeout(() => {
                let filtered = moments.filter(v => 
                    v.caption.toLowerCase().includes(term.toLowerCase()) ||
                    v.username.toLowerCase().includes(term.toLowerCase()) ||
                    v.user_name.toLowerCase().includes(term.toLowerCase())
                );
                
                if (currentCategory !== 'all') {
                    filtered = filtered.filter(v => v.category === currentCategory);
                }
                
                filteredMoments = filtered;
                renderFeed(filteredMoments);
                if (observer) {
                    observer.disconnect();
                    initVideoObserver();
                }
            }, 800);
        }

        // Category Filter
        document.querySelectorAll('.category-pill').forEach(pill => {
            pill.addEventListener('click', function() {
                document.querySelectorAll('.category-pill').forEach(p => p.classList.remove('active'));
                this.classList.add('active');
                
                const category = this.dataset.cat;
                filterByCategory(category);
            });
        });

        function filterByCategory(category) {
            currentCategory = category;
            const searchInput = document.getElementById('searchInput');
            const searchTerm = searchInput.value.toLowerCase().trim();
            
            showSkeleton(2);
            
            setTimeout(() => {
                let filtered = moments;
                
                if (category !== 'all') {
                    filtered = filtered.filter(v => v.category === category);
                }
                
                if (searchTerm) {
                    filtered = filtered.filter(v => 
                        v.caption.toLowerCase().includes(searchTerm) ||
                        v.username.toLowerCase().includes(searchTerm) ||
                        v.user_name.toLowerCase().includes(searchTerm)
                    );
                }
                
                filteredMoments = filtered;
                renderFeed(filteredMoments);
                if (observer) {
                    observer.disconnect();
                    initVideoObserver();
                }
            }, 800);
        }

        // Share Modal Functions
        function closeShareModal() {
            document.getElementById('shareModal').style.display = 'none';
        }

        function shareTo(platform) {
            showToast(`Shared to ${platform}`);
            closeShareModal();
        }

        // Utility Functions
        function formatCount(num) {
            if (num >= 1000000) return (num/1000000).toFixed(1) + 'M';
            if (num >= 1000) return (num/1000).toFixed(1) + 'K';
            return num;
        }

        function showToast(message) {
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 2000);
        }

        function goToProfile(username) {
            window.location.href = `/profile/${username}`;
        }

        function openComments(videoId) {
            showToast('Comments coming soon!');
        }

        function goBack() {
            window.location.href = '/dashboard';
        }

        // Close search history when clicking outside
        document.addEventListener('click', function(event) {
            const searchSection = document.querySelector('.search-section');
            const searchHistory = document.getElementById('searchHistory');
            const searchInput = document.getElementById('searchInput');
            
            if (!searchSection.contains(event.target) && searchHistory.classList.contains('show')) {
                searchHistory.classList.remove('show');
            }
        });

        // Video play/pause on click
        function setupEventListeners() {
            document.addEventListener('click', function(event) {
                const videoCard = event.target.closest('.video-card');
                if (!videoCard) return;
                
                const video = videoCard.querySelector('video');
                const isActionBtn = event.target.closest('.action-circle');
                const isUserRow = event.target.closest('.user-info-row');
                const isHashtag = event.target.closest('.hashtag');
                const isFollowBtn = event.target.closest('.follow-btn');
                
                if (video && !isActionBtn && !isUserRow && !isHashtag && !isFollowBtn) {
                    if (video.paused) {
                        video.play();
                    } else {
                        video.pause();
                    }
                }
            });
        }

        // Initialize on load
        window.addEventListener('load', init);
    </script>

    <!-- External Scripts -->
   <%- include('partials/share-modal') %>
        <script src="/js/dashboardAPI.js"></script>
        <script src="/js/shareManager.js"></script>
        <script>
            window.addEventListener('load', init);
        </script>
</body>

</html>
