                caption: 'Dance practice 🔥 #dance #choreography #hiphop',
                likes: 67890,
                comments: 5678,
                share_count: 3456
            },
            {
                moment_id: 'dance2',
                username: 'street_dancer',
                user_name: 'Carlos Mendez',
                avatar_url: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=100&h=100',
                video_url: 'https://assets.mixkit.co/videos/preview/mixkit-breakdancer-performing-on-the-street-4334-large.mp4',
                media_url: 'https://assets.mixkit.co/videos/preview/mixkit-breakdancer-performing-on-the-street-4334-large.mp4',
                media_type: 'video',
                caption: 'Street performance #dance #streetdance #breakdance',
                likes: 34567,
                comments: 2345,
                share_count: 1234
            },
            {
                moment_id: 'dance3',
                username: 'ballet_dancer',
                user_name: 'Natalia Petrova',
                avatar_url: 'https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?auto=format&fit=crop&q=80&w=100&h=100',
                video_url: 'https://assets.mixkit.co/videos/preview/mixkit-ballerina-performing-on-stage-22671-large.mp4',
                media_url: 'https://assets.mixkit.co/videos/preview/mixkit-ballerina-performing-on-stage-22671-large.mp4',
                media_type: 'video',
                caption: 'Graceful ballet performance 🩰 #dance #ballet #performance',
                likes: 45678,
                comments: 3456,
                share_count: 1876
            },
            {
                moment_id: 'dance4',
                username: 'latin_dancer',
                user_name: 'Diego Martinez',
                avatar_url: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=100&h=100',
                video_url: 'https://assets.mixkit.co/videos/preview/mixkit-couple-dancing-salsa-in-a-club-32824-large.mp4',
                media_url: 'https://assets.mixkit.co/videos/preview/mixkit-couple-dancing-salsa-in-a-club-32824-large.mp4',
                media_type: 'video',
                caption: 'Salsa night! 💃 #dance #salsa #latin',
                likes: 34567,
                comments: 2345,
                share_count: 987
            }
        ];

        // Inject data directly while ensuring it's safe for JS
        let moments = [];
        let user = {};
        let filteredMoments = [];
        let currentCategory = 'all';
        let searchQuery = '';

        try {
            // Using Base64 as the ultimate fallback
            const rawMoments = "<%- Buffer.from(JSON.stringify(initialMoments || [])).toString('base64') %>";
            const rawUser = "<%- Buffer.from(JSON.stringify(user || {})).toString('base64') %>";

            const serverMoments = JSON.parse(atob(rawMoments || "W10="));
            user = JSON.parse(atob(rawUser || "e30="));
            
            // Combine server moments with mock videos
            moments = [...serverMoments, ...mockVideos];
            filteredMoments = [...moments];

            console.log("DEBUG FRONTEND: Successfully injected moments:", moments.length);
        } catch (e) {
            console.error("DEBUG FRONTEND: Fallback triggered. Using mock videos only:", e);
            moments = [...mockVideos];
            filteredMoments = [...moments];
            user = {};
        }

        let isMuted = true;
        let observer;

        function init() {
            console.log("DEBUG FRONTEND: Initializing feed...");
            
            // Show skeleton first
            showSkeleton(3);
            
            // Simulate loading delay then render feed
            setTimeout(() => {
                renderFeed();
                setupObserver();
                setupSearchAndFilters();
            }, 1500);

            // Hide loading screen
            setTimeout(() => {
                const ls = document.getElementById('loadingScreen');
                if (ls) ls.style.opacity = '0';
                setTimeout(() => ls && ls.remove(), 500);
            }, 1200);
        }

        function showSkeleton(count = 3) {
            const feed = document.getElementById('mainFeed');
            
            let skeletonHTML = '';
            for (let i = 0; i < count; i++) {
                skeletonHTML += `
                    <div class="skeleton-card">
                        <div class="skeleton-content"></div>
                        <div class="skeleton-overlay">
                            <div class="skeleton-avatar"></div>
                            <div class="skeleton-line long"></div>
                            <div class="skeleton-line"></div>
                            <div class="skeleton-line short"></div>
                        </div>
                        <div class="skeleton-side">
                            <div class="skeleton-circle"></div>
                            <div class="skeleton-circle"></div>
                            <div class="skeleton-circle"></div>
                            <div class="skeleton-circle"></div>
                        </div>
                    </div>
                `;
            }
            
            feed.innerHTML = skeletonHTML;
        }

        function setupSearchAndFilters() {
            const searchInput = document.getElementById('searchInput');
            const clearBtn = document.getElementById('clearSearch');
            
            if (searchInput) {
                searchInput.addEventListener('input', function(e) {
                    searchQuery = e.target.value.toLowerCase().trim();
                    clearBtn.style.display = searchQuery ? 'block' : 'none';
                    filterMoments();
                });
            }

            document.querySelectorAll('.category-item').forEach(item => {
                item.addEventListener('click', function() {
                    document.querySelectorAll('.category-item').forEach(cat => cat.classList.remove('active'));
                    this.classList.add('active');
                    currentCategory = this.dataset.category;
                    filterMoments();
                });
            });
        }

        function clearSearch() {
            const searchInput = document.getElementById('searchInput');
            const clearBtn = document.getElementById('clearSearch');
            if (searchInput) {
                searchInput.value = '';
                searchQuery = '';
                clearBtn.style.display = 'none';
                filterMoments();
            }
        }

        function filterMoments() {
            showSkeleton(2);
            
            setTimeout(() => {
                filteredMoments = moments.filter(moment => {
                    if (currentCategory !== 'all') {
                        const tags = moment.caption ? (moment.caption.match(/#[a-zA-Z0-9_]+/g) || []).map(t => t.toLowerCase()) : [];
                        if (!tags.includes(`#${currentCategory}`) && !tags.includes(`#${currentCategory.replace('&', '').trim()}`)) {
                            return false;
                        }
                    }

                    if (searchQuery) {
                        const caption = moment.caption ? moment.caption.toLowerCase() : '';
                        const username = moment.username ? moment.username.toLowerCase() : '';
                        const user_name = moment.user_name ? moment.user_name.toLowerCase() : '';
                        const tags = moment.caption ? (moment.caption.match(/#[a-zA-Z0-9_]+/g) || []).join(' ').toLowerCase() : '';
                        
                        return caption.includes(searchQuery) || 
                               username.includes(searchQuery) || 
                               user_name.includes(searchQuery) ||
                               tags.includes(searchQuery);
                    }

                    return true;
                });

                renderFeed();
                
                if (observer) {
                    observer.disconnect();
                    setupObserver();
                }
            }, 800);
        }

        function renderFeed() {
            const feed = document.getElementById('mainFeed');

            if (!filteredMoments || filteredMoments.length === 0) {
                feed.innerHTML = `
                    <div class="moment-card" style="padding: 40px; text-align: center;">
                        <div style="background: rgba(255,255,255,0.05); padding: 50px; border-radius: 30px; border: 1px solid rgba(255,255,255,0.1);">
                            <i class="fas fa-video-slash" style="font-size: 60px; color: #ff3d6d; margin-bottom: 25px;"></i>
                            <h2 style="font-weight: 800; margin-bottom: 10px;">${searchQuery || currentCategory !== 'all' ? 'No Matching Moments' : 'No Moments Yet'}</h2>
                            <p style="opacity: 0.6; margin-bottom: 30px;">${searchQuery || currentCategory !== 'all' ? 'Try adjusting your search or filter' : 'Be the first one to share a moment!'}</p>
                        </div>
                    </div>
                    <div class="end-feed-message">
                        <i class="fas fa-check-circle"></i>
                        <span>That's all for now</span>
                    </div>
                `;
                return;
            }

            let feedHTML = filteredMoments.map((m, i) => createMomentHTML(m, i)).join('');
            
            // Add "That's all for now" message at the end
            feedHTML += `
                <div class="end-feed-message">
                    <i class="fas fa-check-circle"></i>
                    <span>That's all for now</span>
                </div>
            `;
            
            feed.innerHTML = feedHTML;
        }

        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function createMomentHTML(m, i) {
            const mediaSrc = m.video_url || m.media_url;
            const isVideo = m.media_type !== 'image';
            const tags = m.caption ? (m.caption.match(/#[a-zA-Z0-9_]+/g) || []) : [];
            const rawCaption = m.caption ? m.caption.replace(/#[a-zA-Z0-9_]+/g, '').trim() : '';
            const cleanCaption = escapeHtml(rawCaption);
            const avatar = m.avatar_url || 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=100&h=100';

            let mediaHTML = '';
            if (isVideo) {
                mediaHTML = `
                    <video class="sparkle-video" loop playsinline muted="${isMuted}" preload="auto" 
                           onplaying="handleMediaLoad(this)" onwaiting="handleMediaWaiting(this)">
                        <source src="${mediaSrc}" type="video/mp4" onerror="handleMediaError(this)">
                        Your browser does not support the video tag.
                    </video>
                `;
            } else {
                mediaHTML = `
                    <img src="${mediaSrc}" class="sparkle-video" style="object-fit: cover;" 
                         onload="handleMediaLoad(this)" onerror="handleMediaError(this)">
                `;
            }

            return `
                <div class="moment-card" data-id="${m.moment_id}">
                    <div class="video-container" id="container-${m.moment_id}" ondblclick="handleDoubleTap(event, '${m.moment_id}')" onclick="togglePlay('${m.moment_id}')">
                        <div class="media-loading-overlay" style="display: none;">
                            <div class="mini-spinner"></div>
                        </div>
                        <div class="media-error-overlay">
                            <i class="fas fa-exclamation-triangle"></i>
                            <p style="font-size: 16px; font-weight: 600; margin-bottom: 4px;">Video unavailable</p>
                            <span style="font-size: 12px; opacity: 0.5;">This video could not be loaded</span>
                        </div>
                        ${mediaHTML}
                    </div>

                    <div class="ui-overlay">
                        <div class="user-info">
                            <div class="name-box" onclick="location.href='/profile/${m.username}'" style="margin-bottom: 10px; cursor: pointer;">
                                <h3 style="font-size: 17px; text-shadow: 0 1px 3px rgba(0,0,0,0.8); margin-bottom: 2px;">@${m.username}</h3>
                                <p style="font-size: 13px; opacity: 0.9; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${m.user_name || 'Sparkle User'}</p>
                            </div>
                            <div class="caption" style="font-size: 15px; margin-bottom: 12px; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${cleanCaption}</div>
                            <div class="tags">
                                ${tags.map(t => `<span class="tag" style="text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${t}</span>`).join('')}
                            </div>
                        </div>
                    </div>

                    <div class="side-actions">
                        <div class="action-btn-circle profile-action" onclick="location.href='/profile/${m.username}'" style="margin-bottom: 12px; position: relative;">
                            <div class="avatar-circle" style="width: 48px; height: 48px; border: 2px solid white; box-shadow: 0 2px 8px rgba(0,0,0,0.5);">
                                <img src="${avatar}" alt="${m.user_name}" onerror="this.src='https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=100&h=100';" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                            </div>
                            <div class="follow-plus" style="position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); background: #FF3D6D; color: white; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; border: 2px solid white;">
                                <i class="fas fa-plus"></i>
                            </div>
                        </div>

                        <div class="action-btn-circle" onclick="toggleLike('${m.moment_id}')">
                            <div class="icon-circle"><i class="fas fa-heart"></i></div>
                            <span class="count-label">${formatCount(m.likes || 0)}</span>
                        </div>
                        <div class="action-btn-circle" onclick="openComments('${m.moment_id}')">
                            <div class="icon-circle"><i class="fas fa-comment"></i></div>
                            <span class="count-label">${formatCount(m.comments || 0)}</span>
                        </div>
                        <div class="action-btn-circle share-btn" data-type="moment" data-id="${m.moment_id}">
                            <div class="icon-circle"><i class="fas fa-paper-plane"></i></div>
                            <span class="count-label">${formatCount(m.share_count || 0)}</span>
                        </div>
                        <div class="action-btn-circle" onclick="saveMoment('${m.moment_id}')">
                            <div class="icon-circle"><i class="fas fa-bookmark"></i></div>
                        </div>
                    </div>
                </div>
            `;
        }

        async function safePlay(video) {
            if (!video) return;
            if (video.readyState < 2) {
                video.addEventListener('canplay', () => safePlay(video), { once: true });
                return;
            }
            try {
                const playPromise = video.play();
                if (playPromise !== undefined) {
                    await playPromise;
                }
            } catch (e) {
                if (e.name !== 'AbortError') {
                    console.log("Playback error:", e);
                }
            }
        }

        function handleMediaLoad(el) {
            const container = el.closest('.video-container');
            if (!container) return;
            const loader = container.querySelector('.media-loading-overlay');
            const error = container.querySelector('.media-error-overlay');
            if (loader) loader.style.display = 'none';
            if (error) error.style.display = 'none';
            el.style.opacity = '1';
        }

        function handleMediaWaiting(el) {
            const container = el.closest('.video-container');
            if (!container) return;
            const loader = container.querySelector('.media-loading-overlay');
            if (loader) loader.style.display = 'flex';
        }

        function handleMediaError(el) {
            const container = el.closest('.video-container');
            if (!container) return;

            const errorOverlay = container.querySelector('.media-error-overlay');
            const loader = container.querySelector('.media-loading-overlay');
            
            if (loader) loader.style.display = 'none';
            if (errorOverlay) {
                errorOverlay.style.display = 'flex';
            }
            
            if (el.tagName === 'VIDEO' || el.tagName === 'IMG') {
                el.style.opacity = '0';
            }
        }

        function setupObserver() {
            const options = { threshold: 0.6 };
            observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    const video = entry.target.querySelector('video');
                    if (!video) return;

                    if (entry.isIntersecting) {
                        safePlay(video);
                    } else {
                        video.pause();
                        video.currentTime = 0;
                    }
                });
            }, options);

            document.querySelectorAll('.moment-card').forEach(card => observer.observe(card));
        }

        function togglePlay(id) {
            const video = document.querySelector(`[data-id="${id}"] video`);
            if (!video) return;
            if (video.paused) safePlay(video);
            else video.pause();
        }

        function toggleGlobalSound() {
            isMuted = !isMuted;
            const icon = document.querySelector('#soundToggle i');
            icon.className = isMuted ? 'fas fa-volume-mute' : 'fas fa-volume-up';
            document.querySelectorAll('video').forEach(v => v.muted = isMuted);
        }

        function handleDoubleTap(e, id) {
            const heart = document.createElement('i');
            heart.className = 'fas fa-heart tap-heart';
            heart.style.left = `${e.clientX - 50}px`;
            heart.style.top = `${e.clientY - 50}px`;
            document.body.appendChild(heart);
            setTimeout(() => heart.remove(), 800);
            toggleLike(id, true);
        }

        async function toggleLike(id, forceLike = false) {
            const card = document.querySelector(`[data-id="${id}"]`);
            if (!card) return;
            const btn = card.querySelector('.action-btn-circle:nth-child(2)');
            const countLabel = btn.querySelector('.count-label');
            const isLiked = btn.classList.contains('liked');

            if (forceLike && isLiked) return;

            btn.classList.toggle('liked', forceLike || !isLiked);
            let currentCount = parseInt(countLabel.innerText.replace(/[^0-9]/g, '')) || 0;
            countLabel.innerText = formatCount(isLiked ? Math.max(0, currentCount - 1) : currentCount + 1);
        }

        function formatCount(num) {
            if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
            if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
            return num;
        }

        function openComments(id) { 
            alert('Comments feature coming soon!'); 
        }

        function saveMoment(id) { 
            const btn = document.querySelector(`[data-id="${id}"] .action-btn-circle:last-child .icon-circle i`);
            btn.style.color = '#FF3D6D';
            setTimeout(() => {
                btn.style.color = '#fff';
            }, 500);
            alert('Moment saved to collection!'); 
        }

    </script>

    <%- include('partials/share-modal') %>
        <script src="/js/dashboardAPI.js"></script>
        <script src="/js/shareManager.js"></script>
        <script>
            window.addEventListener('load', init);
        </script>
</body>

</html>
