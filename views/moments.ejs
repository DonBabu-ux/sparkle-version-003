        // Initialize
        function init() {
            showSkeleton();
            setTimeout(() => {
                renderFeed(filteredMoments);
                initVideoObserver();
                hideLoadingScreen();
            }, 2000);
            
            renderSearchHistory();
            setupSearchListener();
            setupEventListeners();
