<% 
  const pId = post.post_id || post.id;
  const uname = (post.username && post.username !== 'undefined') ? post.username : 'sparkler';
  const avatar = post.avatar_url || post.actor_avatar || '/uploads/avatars/default.png';
  const isSparked = post.is_sparked || post.is_liked || false;
  const sparks = post.spark_count || post.sparks || 0;
  const comments = post.comment_count || post.comments || 0;
  
  const bufCaption = post.content || post.caption || '';
  const finalCaption = (bufCaption && bufCaption !== 'undefined' && bufCaption !== 'null') ? bufCaption : '';

  const actorId = post.user_id || post.actor_id;
  const avatarAction = post.has_story ? `openStoryViewer('${actorId}')` : `window.location.href='/profile/${uname}'`;
%>

<div class="post-card animate-fade-in <%= (!post.media_url || post.media_url === 'undefined' || post.media_url === 'null' || post.media_url.trim() === '') ? 'text-only' : '' %>" data-post-id="<%= pId %>">
    <div class="post-header">
        <div class="post-avatar-wrapper" onclick="event.stopPropagation(); <%= avatarAction %>">
            <img src="<%= avatar %>" class="post-avatar <%= post.has_story ? (post.story_viewed ? 'story-viewed' : 'story-ring') : '' %>" onerror="this.src='/uploads/avatars/default.png'">
        </div>
        <div class="post-info" onclick="event.stopPropagation(); window.location.href='/profile/<%= uname %>'">
            <div class="post-author-name">
                <%= uname %>
                <%- include('verified-badge', { id: post.user_id || post.actor_id }) %>
                <% if (post.campus && post.campus !== 'undefined') { %>
                    <span class="campus-badge" style="background: var(--bg-main); color: var(--text-muted); font-size: 0.75rem; padding: 2px 8px; border-radius: 12px; font-weight: 700; margin-left: 5px;"><%= post.campus %></span>
                <% } %>
            </div>
            <div class="post-meta"><%= typeof timeAgo !== 'undefined' ? timeAgo(post.created_at) : 'recently' %></div>
        </div>
        <button class="post-options">
            <i class="fas fa-ellipsis-h"></i>
        </button>
    </div>

    <% if (post.media_url && post.media_url !== 'undefined' && post.media_url !== 'null' && post.media_url.trim() !== '') { %>
        <div class="post-media" ondblclick="event.stopPropagation(); const btn = this.closest('.post-card').querySelector('.like-btn'); if(btn && !btn.classList.contains('liked')) btn.click();">
            <% if (post.media_url.match(/\.(mp4|webm|ogg|mov)$/i)) { %>
                <video src="<%= post.media_url %>" autoplay loop muted playsinline></video>
            <% } else { %>
                <img src="<%= post.media_url %>" loading="lazy" onclick="event.stopPropagation(); window.openImageViewer('<%= pId %>', '<%= post.media_url %>')" onerror="this.src='/uploads/posts/default.png'">
            <% } %>
        </div>
    <% } %>

    <div class="post-content">
        <% if (finalCaption) { %>
            <div class="post-text <%= finalCaption.length > 150 ? 'truncated' : '' %>">
                <strong style="margin-right: 6px; cursor: pointer;" onclick="event.stopPropagation(); window.location.href='/profile/<%= uname %>'"><%= uname %></strong>
                <%- finalCaption.replace(/#(\w+)/g, '<a href="/dashboard/hashtag/$1" class="hashtag">#$1</a>') %>
            </div>
            <% if (finalCaption.length > 150) { %>
                <button class="read-more-btn" onclick="event.stopPropagation(); this.previousElementSibling.classList.toggle('truncated'); this.remove();">
                    ... more
                </button>
            <% } %>
        <% } %>
    </div>

    <div class="post-actions">
        <div class="actions-left">
            <button class="action-btn like-btn <%= isSparked ? 'liked' : '' %>" onclick="event.stopPropagation(); window.toggleLikePremium('<%= pId %>', this)">
                <i class="<%= isSparked ? 'fas' : 'far' %> fa-heart"></i>
            </button>
            <button class="action-btn" onclick="event.stopPropagation(); window.openCommentSplitView('<%= pId %>')">
                <i class="far fa-comment"></i>
            </button>
            <button class="action-btn" onclick="event.stopPropagation(); window.sharePost('<%= pId %>')">
                <i class="far fa-paper-plane"></i>
            </button>
        </div>
        <div class="actions-right">
            <button class="action-btn">
                <i class="far fa-bookmark"></i>
            </button>
        </div>
    </div>

    <div class="post-stats">
        <span onclick="event.stopPropagation(); showSparksModal('<%= pId %>')"><%= sparks %> sparks</span>
        <% if (comments > 0) { %>
            <span onclick="event.stopPropagation(); window.openCommentSplitView('<%= pId %>')">View all <%= comments %> comments</span>
        <% } %>
    </div>
</div>