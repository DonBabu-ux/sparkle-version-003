<% 
  const pId = post.post_id || post.id;
  const uname = (post.username && post.username !== 'undefined') ? post.username : 'sparkler';
  const avatar = post.avatar_url || post.actor_avatar || '/uploads/avatars/default.png';
  const isSparked = post.is_sparked || post.is_liked || false;
  const sparks = post.spark_count || post.sparks || 0;
  const comments = post.comment_count || post.comments || 0;
  
  // Truncate logic for caption
  const bufCaption = post.content || post.caption || '';
  const finalCaption = (bufCaption && bufCaption !== 'undefined' && bufCaption !== 'null') ? bufCaption : '';
%>

<div class="post" data-post-id="<%= pId %>">
    <div class="post-header">
        <div class="avatar-wrapper <%= post.has_story ? (post.story_viewed ? 'story-viewed' : 'story-ring') : '' %>" 
             onclick="event.stopPropagation(); <%= post.has_story ? 'openStoryViewer(\'' + (post.user_id || post.actor_id) + '\')' : 'window.location.href=\'/profile/' + uname + '\'' %>">
            <img src="<%= avatar %>" class="avatar" onerror="this.onerror=null; this.src='/uploads/avatars/default.png'">
        </div>

        <div class="user-info" onclick="event.stopPropagation(); window.location.href='/profile/<%= uname %>'">
            <div class="username"><%= uname %></div>
            <div class="meta">
                <%= post.campus || 'Main Campus' %> • <%= typeof timeAgo !== 'undefined' ? timeAgo(post.created_at) : 'recently' %>
            </div>
        </div>

        <div style="margin-left: auto; display: flex; align-items: center; gap: 8px;">
            <% if (post.user_id && post.user_id != user.user_id && !post.is_followed) { %>
                <button class="follow-btn-mini" 
                        onclick="event.stopPropagation(); window.toggleFollow('<%= post.user_id %>', this)"
                        style="background: none; border: 1px solid var(--accent); color: var(--accent); border-radius: 8px; padding: 4px 12px; font-size: 12px; font-weight: 700; cursor: pointer; transition: all 0.2s;">
                    Follow
                </button>
            <% } %>

            <button class="options-btn" onclick="event.stopPropagation()">
                <i class="fas fa-ellipsis-h"></i>
            </button>
        </div>
    </div>

    <% if (finalCaption) { %>
        <div class="caption">
            <span class="caption-text" id="caption-<%= pId %>"><%= finalCaption %></span>
        </div>
    <% } %>

    <% if (post.media_url && post.media_url !== 'undefined') { %>
        <div class="post-media">
            <% if (post.media_url.match(/\.(mp4|webm|ogg|mov)$/i)) { %>
                <video src="<%= post.media_url %>" autoplay loop muted playsinline onclick="event.stopPropagation()"></video>
            <% } else { %>
                <img src="<%= post.media_url %>" class="post-image" loading="lazy" onclick="event.stopPropagation(); window.openImageViewer('<%= pId %>', '<%= post.media_url %>')" onerror="this.onerror=null; this.src='/uploads/posts/default.png'">
            <% } %>
        </div>
    <% } %>

    <div class="engagement-summary" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 16px;">
        <span class="sparks-count" style="color: <%= isSparked ? 'var(--insta-pink)' : 'var(--text-muted)' %>; font-weight: 700;">
            <i class="<%= isSparked ? 'fas' : 'far' %> fa-heart"></i> <%= sparks %>
        </span>
        <span class="comments-count" style="color: var(--text-muted); font-size: 12px; font-weight: 600;">
            <%= comments %> comments
        </span>
    </div>

    <div class="actions" style="display: flex; justify-content: space-between; border-top: 1px solid var(--border-color); padding: 4px 8px;">
        <button class="action-btn <%= isSparked ? 'active' : '' %>" 
                onclick="event.stopPropagation(); window.toggleSpark('<%= pId %>', this)">
            <i class="<%= isSparked ? 'fas' : 'far' %> fa-heart"></i>
            <span>Like</span>
        </button>
        <button class="action-btn" 
                onclick="event.stopPropagation(); window.openCommentSplitView('<%= pId %>')">
            <i class="far fa-comment"></i>
            <span>Comment</span>
        </button>
        <button class="action-btn" 
                onclick="event.stopPropagation(); window.sharePost('<%= pId %>')">
            <i class="far fa-share-square"></i>
            <span>Share</span>
        </button>
    </div>
</div>