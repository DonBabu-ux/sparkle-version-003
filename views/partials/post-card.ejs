<div class="post-card" data-post-id="<%= post.post_id %>">
    <!-- Header -->
    <div class="post-header">
        <img src="<%= post.avatar_url || '/uploads/avatars/default.png' %>" alt="<%= post.username %>"
            class="post-avatar" onerror="this.onerror=null;this.src='/uploads/avatars/default.png';">
        <div class="post-author-info">
            <div class="post-username-row">
                <div class="post-username">@<%= (post.username && post.username !=='undefined' && post.username
                        !=='null' ) ? post.username : 'Sparkler' %>
                </div>
            </div>
            <div class="post-meta-row">
                <span>
                    <%= (post.campus && post.campus !=='undefined' && post.campus !=='null' ) ? post.campus
                        : 'Main Campus' %>
                </span> •
                <span class="post-time-simple">
                    <% let d=new Date(post.created_at); %>
                        <%= (d && !isNaN(d.getTime())) ? d.toLocaleDateString() : 'Recently' %>
                </span>
            </div>
        </div>
        <button class="post-options-btn">
            <i class="fas fa-ellipsis-h"></i>
        </button>
    </div>

    <!-- Content -->
    <% if (post.content && post.content !=='undefined' && post.content !=='null' && post.content !=='NaN' &&
        post.content.trim() !=='' ) { %>
        <div class="post-text-body">
            <div class="post-caption-full">
                <%= post.content %>
            </div>
        </div>
        <% } %>

            <!-- Media Area (Full Bleed) -->
            <% if (post.media_url) { %>
                <div class="post-media-proper">
                    <% if (post.media_url.match(/\.(mp4|webm|ogg|mov)$/i)) { %>
                        <video class="media-obj-proper" src="<%= post.media_url %>" controls preload="metadata"></video>
                        <% } else { %>
                            <img class="media-obj-proper" src="<%= post.media_url %>" alt="Post media" loading="lazy">
                            <% } %>
                </div>
                <% } %>

                    <!-- Interaction Area (Facebook Style) -->
                    <div class="post-interaction-metrics">
                        <div class="metric-stat spark-stat">
                            <i class="fas fa-bolt"></i>
                            <span class="spark-count-val">
                                <%= post.spark_count || post.sparks || 0 %>
                            </span> Sparks
                        </div>
                        <div class="metric-stat comment-stat">
                            <i class="far fa-comment"></i>
                            <span class="comment-count-val">
                                <%= post.comment_count || post.comments || 0 %>
                            </span> Comments
                        </div>
                    </div>

                    <div class="post-interaction-actions">
                        <button class="action-btn-custom spark <%= post.is_sparked ? 'active' : '' %>"
                            onclick="sparkPost('<%= post.post_id %>', this)">
                            <i class="<%= post.is_sparked ? 'fas' : 'far' %> fa-bolt"></i>
                            <span>Spark</span>
                        </button>

                        <button class="action-btn-custom comment" onclick="toggleComments('<%= post.post_id %>')">
                            <i class="far fa-comment"></i>
                            <span>Comment</span>
                        </button>

                        <button class="action-btn-custom share" onclick="sharePost('<%= post.post_id %>')">
                            <i class="far fa-share-square"></i>
                            <span>Share</span>
                        </button>

                        <button class="action-btn-custom save <%= post.is_saved ? 'active' : '' %>"
                            onclick="savePost('<%= post.post_id %>', this)">
                            <i class="<%= post.is_saved ? 'fas' : 'far' %> fa-bookmark"></i>
                            <span>Save</span>
                        </button>
                    </div>

                    <!-- Footnote / Quick Comment -->
                    <div class="post-footer-minimal">
                        <div class="post-comment-quick">
                            <img src="<%= user.avatar_url || '/uploads/avatars/default.png' %>" class="post-avatar"
                                style="width: 32px !important; height: 32px !important;">
                            <input type="text" id="comment-input-<%= post.post_id %>" class="comment-input-min"
                                placeholder="Add a comment..."
                                onkeypress="if(event.key === 'Enter') addComment('<%= post.post_id %>', this)">
                        </div>

                        <!-- Comments Container -->
                        <div class="comments-section" id="comments-<%= post.post_id %>"
                            style="display: none; padding: 0 16px 16px;">
                            <div class="comments-loading"
                                style="text-align: center; color: var(--text-muted); font-size: 13px;">
                                <i class="fas fa-spinner fa-spin"></i> Loading comments...
                            </div>
                        </div>
                    </div>
</div>