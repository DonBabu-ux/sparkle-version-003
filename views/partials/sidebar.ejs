<style>
    .hamburger-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        padding-right: 15px;
    }

    .hamburger-section-header .hamburger-section-title {
        margin-bottom: 0;
    }

    .toggle-chevron {
        font-size: 12px;
        color: var(--primary);
        transition: transform 0.3s ease;
    }

    .hamburger-section.collapsible .collapsible-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out, margin-top 0.3s ease;
        padding-left: 10px;
    }

    .hamburger-section.collapsible.active .collapsible-content {
        max-height: 60vh;
        margin-top: 10px;
        overflow-y: auto;
        scrollbar-width: thin;
    }

    .hamburger-section.collapsible.active .toggle-chevron {
        transform: rotate(180deg);
    }
</style>

<script>
    function toggleSidebarSection(header) {
        const section = header.parentElement;
        section.classList.toggle('active');
    }

    // Global toggle for the mobile hamburger menu
    window.toggleHamburger = function () {
        const menu = document.getElementById('hamburgerMenu');
        const overlay = document.getElementById('hamburgerOverlay');
        if (!menu || !overlay) return;

        menu.classList.toggle('active');
        overlay.classList.toggle('active');

        const isOpen = menu.classList.contains('active');
        document.body.style.overflow = isOpen ? 'hidden' : '';

        // Update legacy appState if it exists
        if (window.appState) {
            window.appState.hamburgerOpen = isOpen;
        }
    };

    window.hideHamburger = function () {
        const menu = document.getElementById('hamburgerMenu');
        const overlay = document.getElementById('hamburgerOverlay');
        if (!menu || !overlay) return;

        menu.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';

        if (window.appState) {
            window.appState.hamburgerOpen = false;
        }
    };

    // Close on overlay click
    document.getElementById('hamburgerOverlay')?.addEventListener('click', hideHamburger);

    // Multi-Account Logic
    const authMultiAccounts = {
        getAccounts() {
            try {
                const accounts = localStorage.getItem('sparkleAccounts');
                return accounts ? JSON.parse(accounts) : [];
            } catch (e) {
                return [];
            }
        },
        saveAccounts(accounts) {
            localStorage.setItem('sparkleAccounts', JSON.stringify(accounts));
        },
        getCurrentSession() {
            try {
                const userJson = localStorage.getItem('sparkleUser');
                const token = localStorage.getItem('sparkleToken');
                if (userJson && token) {
                    return { user: JSON.parse(userJson), token };
                }
            } catch (e) {}
            return null;
        },
        syncCurrentSession() {
            const current = this.getCurrentSession();
            if (!current) return;
            let accounts = this.getAccounts();
            
            const existingIndex = accounts.findIndex(a => a.userId === current.user.id || a.userId === current.user.user_id);
            const acctObj = {
                userId: current.user.id || current.user.user_id,
                username: current.user.username,
                avatar: current.user.avatar_url || '/uploads/avatars/default.png',
                token: current.token
            };

            if (existingIndex >= 0) {
                accounts[existingIndex] = acctObj;
            } else {
                accounts.push(acctObj);
            }
            this.saveAccounts(accounts);
        },
        renderAccounts() {
            this.syncCurrentSession();
            const accounts = this.getAccounts();
            const current = this.getCurrentSession();
            const currentId = current ? (current.user.id || current.user.user_id) : null;

            const html = accounts.map(acct => `
                <div onclick="authMultiAccounts.switchAccount('${acct.userId}')" style="display: flex; align-items: center; justify-content: space-between; padding: 8px; cursor: pointer; border-radius: 8px; background: ${acct.userId === currentId ? 'rgba(0,0,0,0.05)' : 'transparent'};">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <img src="${acct.avatar}" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;">
                        <span style="font-size: 13px; font-weight: ${acct.userId === currentId ? '700' : '500'}; color: var(--text-main);">@${acct.username}</span>
                    </div>
                    ${acct.userId === currentId ? '<i class="fas fa-check-circle" style="color: var(--accent); font-size: 12px;"></i>' : ''}
                </div>
            `).join('');

            const deskContainer = document.getElementById('desktop-account-switcher');
            if (deskContainer) deskContainer.innerHTML = html;

            const mobContainer = document.getElementById('mobile-account-switcher');
            if (mobContainer) {
                const mobHtml = accounts.map(acct => `
                    <div class="hamburger-item" onclick="authMultiAccounts.switchAccount('${acct.userId}'); hideHamburger();">
                        <img src="${acct.avatar}" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover; margin-right: 15px;">
                        <span style="font-weight: ${acct.userId === currentId ? '700' : '500'}; color: var(--text-main);">@${acct.username}</span>
                        ${acct.userId === currentId ? '<i class="fas fa-check-circle" style="color: var(--accent); font-size: 14px; margin-left: auto;"></i>' : ''}
                    </div>
                `).join('');
                mobContainer.innerHTML = mobHtml;
            }

            const navbarContainer = document.getElementById('navbar-account-switcher');
            if (navbarContainer) {
                const navHtml = accounts.map(acct => `
                    <a href="javascript:void(0)" class="dropdown-menu-item" onclick="authMultiAccounts.switchAccount('${acct.userId}');" style="display:flex; justify-content:space-between; align-items:center;">
                        <div style="display:flex; align-items:center; gap:12px;">
                            <img src="${acct.avatar}" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;">
                            <span style="font-weight: ${acct.userId === currentId ? '700' : '500'}; color: var(--text-main);">@${acct.username}</span>
                        </div>
                        ${acct.userId === currentId ? '<i class="fas fa-check-circle" style="color: var(--accent); font-size: 14px;"></i>' : ''}
                    </a>
                `).join('');
                navbarContainer.innerHTML = navHtml;
            }
        },
        async switchAccount(userId) {
            const accounts = this.getAccounts();
            const targetAccount = accounts.find(a => String(a.userId) === String(userId));
            if (!targetAccount) {
                console.warn('[MultiAccount] switchAccount: no account found for userId:', userId);
                return;
            }

            // Check if already on this account
            const currentToken = localStorage.getItem('sparkleToken');
            if (currentToken === targetAccount.token) {
                console.log('[MultiAccount] Already on account:', targetAccount.username);
                return;
            }

            console.log('[MultiAccount] Switching to account:', targetAccount.username);

            try {
                // Tell server to set the cookie  
                const res = await fetch('/api/auth/switch-account', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: targetAccount.token })
                });

                if (res.ok) {
                    // Save current session BEFORE switching (keeps Account A alive)
                    this.syncCurrentSession();

                    // Update localStorage to the target account so app rehydrates correctly
                    localStorage.setItem('sparkleToken', targetAccount.token);

                    // Rebuild a minimal sparkleUser object from stored data
                    // The full profile will be fetched from server after reload
                    const rebuiltUser = {
                        user_id: targetAccount.userId,
                        id: targetAccount.userId,
                        username: targetAccount.username,
                        avatar_url: targetAccount.avatar,
                        loggedIn: true
                    };
                    localStorage.setItem('sparkleUser', JSON.stringify(rebuiltUser));

                    console.log('[MultiAccount] Switched successfully. Reloading for user:', targetAccount.username);
                    window.location.reload();
                } else {
                    const errData = await res.json().catch(() => ({}));
                    console.warn('[MultiAccount] Server rejected switch:', errData.message);
                    alert('Session expired for @' + targetAccount.username + '. Please log in again.');
                    // Remove stale account from list
                    this.saveAccounts(accounts.filter(a => String(a.userId) !== String(userId)));
                    this.renderAccounts();
                }
            } catch (e) {
                console.error('[MultiAccount] switchAccount error:', e);
            }
        },
        addNewAccount() {
            window.location.href = '/login?add_account=true';
        }
    };

    document.addEventListener('DOMContentLoaded', () => {
        authMultiAccounts.renderAccounts();
    });
</script>