<!-- Desktop Side Navigation (Instagram Style) -->
<div class="desktop-sidebar">
    <div class="sidebar-logo">
        <i class="fas fa-sparkles"></i>
        <span>Sparkle</span>
    </div>

    <nav class="sidebar-nav">
        <!-- 1. Home -->
        <a href="/dashboard" class="sidebar-item <%= title === 'Dashboard' ? 'active' : '' %>" title="Home">
            <i class="fas fa-house-chimney"></i>
            <span>Home</span>
        </a>

        <!-- 2. Discover Students Hub -->
        <div class="sidebar-hub-container" id="discoverHub">
            <div class="sidebar-item hub-trigger">
                <i class="fas fa-compass"></i>
                <span>Discover</span>
                <i class="fas fa-chevron-right hub-chevron"></i>
            </div>
            <div class="hub-dropdown">
                <a href="/connect" class="hub-sub-item">
                    <i class="fas fa-search"></i>
                    <span>Find Students</span>
                </a>
                <a href="/follow-requests" class="hub-sub-item">
                    <i class="fas fa-user-plus"></i>
                    <span>Follow Requests</span>
                </a>
            </div>
        </div>

        <!-- 3. Moments -->
        <a href="/moments" class="sidebar-item <%= title === 'Moments' ? 'active' : '' %>" title="Moments">
            <i class="fas fa-play-circle"></i>
            <span>Moments</span>
        </a>

        <!-- 4. Profile -->
        <a href="/profile" class="sidebar-item <%= title === 'Profile' ? 'active' : '' %>" title="Profile">
            <img src="<%= (typeof user !== 'undefined' && user) ? (user.avatar_url || '/uploads/avatars/default.png') : '/uploads/avatars/default.png' %>"
                style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;">
            <span>Profile</span>
        </a>

        <!-- 5. Confessions -->
        <a href="/confessions" class="sidebar-item <%= title === 'Confessions' ? 'active' : '' %>" title="Confessions">
            <i class="fas fa-user-secret"></i>
            <span>Confessions</span>
        </a>

        <!-- 6. Create -->
        <a href="#" class="sidebar-item create-trigger" onclick="window.showCreateOptions(); return false;"
            title="Create">
            <i class="fas fa-plus-square"></i>
            <span>Create</span>
        </a>

        <!-- 7. Messages -->
        <a href="/messages" class="sidebar-item <%= title === 'Messages' ? 'active' : '' %>" title="Messages">
            <i class="fas fa-paper-plane"></i>
            <span>Messages</span>
        </a>

        <!-- 8. Sparkle Shop Hub (Marketplace + Skill Market) -->
        <div class="sidebar-hub-container" id="shopHub">
            <div class="sidebar-item hub-trigger">
                <i class="fas fa-bag-shopping"></i>
                <span>Sparkle Shop</span>
                <i class="fas fa-chevron-right hub-chevron"></i>
            </div>
            <div class="hub-dropdown">
                <a href="/marketplace" class="hub-sub-item">
                    <i class="fas fa-store"></i>
                    <span>Marketplace</span>
                </a>
                <a href="/skill-market" class="hub-sub-item">
                    <i class="fas fa-graduation-cap"></i>
                    <span>Skill Market</span>
                </a>
            </div>
        </div>

        <!-- 9. More Menu -->
        <div class="sidebar-hub-container" id="moreHub" style="margin-top: auto;">
            <div class="sidebar-item hub-trigger">
                <i class="fas fa-ellipsis-h"></i>
                <span>More</span>
            </div>
            <div class="hub-dropdown up">
                <a href="/groups" class="hub-sub-item">
                    <i class="fas fa-users"></i>
                    <span>Groups & Clubs</span>
                </a>
                <a href="/lost-found" class="hub-sub-item">
                    <i class="fas fa-search"></i>
                    <span>Lost & Found</span>
                </a>
                <a href="/polls" class="hub-sub-item">
                    <i class="fas fa-poll-h"></i>
                    <span>Polls</span>
                </a>
                <a href="/events" class="hub-sub-item">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Events</span>
                </a>
                <a href="/settings" class="hub-sub-item">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
                <div class="hub-divider"></div>
                <a href="/logout" class="hub-sub-item logout">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </div>
    </nav>
</div>

<!-- Hamburger Menu Overlay (Mobile) -->
<div class="hamburger-overlay" id="hamburgerOverlay"></div>

<!-- Hamburger Menu (Mobile/Drawer) -->
<div class="hamburger-menu" id="hamburgerMenu">
    <div class="hamburger-header">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;">
            <div class="logo">Sparkle Menu</div>
            <button class="close-modal" id="closeHamburger">&times;</button>
        </div>

        <!-- User Profile Header house 5.0 -->
        <div class="user-profile-header" onclick="window.location.href='/profile'; hideHamburger();"
            style="display: flex; align-items: center; gap: 12px; padding: 10px; background: #fafafa; border-radius: 12px; margin-bottom: 20px; cursor: pointer;">
            <img src="<%= (typeof user !== 'undefined' && user) ? (user.avatar_url || '/uploads/avatars/default.png') : '/uploads/avatars/default.png' %>"
                style="width: 45px; height: 45px; border-radius: 50%; border: 2px solid var(--primary);"
                onerror="this.onerror=null;this.src='/uploads/avatars/default.png';">
            <div style="overflow: hidden;">
                <div
                    style="font-weight: 700; font-size: 15px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    <%= (typeof user !=='undefined' && user) ? user.name : 'Sparkle Student' %>
                </div>
                <div style="font-size: 12px; color: #666; display: flex; align-items: center; gap: 4px;">
                    <i class="fas fa-graduation-cap" style="font-size: 10px; color: var(--primary);"></i>
                    <%= (typeof user !=='undefined' && user) ? user.campus : 'Select Campus' %>
                </div>
            </div>
        </div>

        <div style="font-size: 13px; color: #666;">Access all features from here</div>
    </div>

    <!-- Main Navigation -->
    <div class="hamburger-section">
        <div class="hamburger-item" onclick="window.location.href='/dashboard'; hideHamburger();">
            <i class="fas fa-house-chimney"></i>
            <span>Home Feed</span>
        </div>

        <!-- Discover Hub -->
        <div class="hamburger-section collapsible">
            <div class="hamburger-section-header" onclick="toggleSidebarSection(this)">
                <div class="hamburger-section-title">
                    <i class="fas fa-compass"></i> Discover
                </div>
                <i class="fas fa-chevron-down toggle-chevron"></i>
            </div>
            <div class="collapsible-content">
                <div class="hamburger-item" onclick="window.location.href='/connect'; hideHamburger();">
                    <i class="fas fa-search"></i>
                    <span>Find Students</span>
                </div>
                <div class="hamburger-item" onclick="window.location.href='/follow-requests'; hideHamburger();">
                    <i class="fas fa-user-plus"></i>
                    <span>Follow Requests</span>
                </div>
            </div>
        </div>

        <div class="hamburger-item" onclick="window.location.href='/moments'; hideHamburger();">
            <i class="fas fa-play-circle"></i>
            <span>Moments</span>
        </div>
        <div class="hamburger-item" onclick="window.location.href='/profile'; hideHamburger();">
            <i class="fas fa-user-circle"></i>
            <span>My Profile</span>
        </div>
        <div class="hamburger-item" onclick="window.location.href='/confessions'; hideHamburger();">
            <i class="fas fa-user-secret"></i>
            <span>Confessions</span>
        </div>
        <div class="hamburger-item" onclick="window.location.href='/messages'; hideHamburger();">
            <i class="fas fa-paper-plane"></i>
            <span>Messaging</span>
        </div>
    </div>

    <!-- Sparkle Shop Hub -->
    <div class="hamburger-section collapsible">
        <div class="hamburger-section-header" onclick="toggleSidebarSection(this)">
            <div class="hamburger-section-title">
                <i class="fas fa-bag-shopping"></i> Sparkle Shop
            </div>
            <i class="fas fa-chevron-down toggle-chevron"></i>
        </div>
        <div class="collapsible-content">
            <div class="hamburger-item" onclick="window.location.href='/marketplace'; hideHamburger();">
                <i class="fas fa-store"></i>
                <span>Marketplace</span>
            </div>
            <div class="hamburger-item" onclick="window.location.href='/skill-market'; hideHamburger();">
                <i class="fas fa-graduation-cap"></i>
                <span>Skill Market</span>
            </div>
        </div>
    </div>

    <!-- More Menu Hub -->
    <div class="hamburger-section collapsible">
        <div class="hamburger-section-header" onclick="toggleSidebarSection(this)">
            <div class="hamburger-section-title">
                <i class="fas fa-ellipsis-h"></i> More
            </div>
            <i class="fas fa-chevron-down toggle-chevron"></i>
        </div>
        <div class="collapsible-content">
            <div class="hamburger-item" onclick="window.location.href='/groups'; hideHamburger();">
                <i class="fas fa-users"></i>
                <span>Groups & Clubs</span>
            </div>
            <div class="hamburger-item" onclick="window.location.href='/lost-found'; hideHamburger();">
                <i class="fas fa-search"></i>
                <span>Lost & Found</span>
            </div>
            <div class="hamburger-item" onclick="window.location.href='/polls'; hideHamburger();">
                <i class="fas fa-poll-h"></i>
                <span>Polls</span>
            </div>
            <div class="hamburger-item" onclick="window.location.href='/events'; hideHamburger();">
                <i class="fas fa-calendar-alt"></i>
                <span>Events</span>
            </div>
            <div class="hamburger-item" onclick="window.location.href='/settings'; hideHamburger();">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </div>
            <div class="hamburger-item logout" onclick="window.location.href='/logout'; hideHamburger();">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </div>
        </div>
    </div>

    <div style="padding: 20px; text-align: center; color: #999; font-size: 12px;">
        Sparkle v2.1 Enhanced<br>
        Campus Social Network
    </div>
</div>

<style>
    .hamburger-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        padding-right: 15px;
    }

    .hamburger-section-header .hamburger-section-title {
        margin-bottom: 0;
    }

    .toggle-chevron {
        font-size: 12px;
        color: var(--primary);
        transition: transform 0.3s ease;
    }

    .hamburger-section.collapsible .collapsible-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out, margin-top 0.3s ease;
        padding-left: 10px;
    }

    .hamburger-section.collapsible.active .collapsible-content {
        max-height: 500px;
        margin-top: 10px;
    }

    .hamburger-section.collapsible.active .toggle-chevron {
        transform: rotate(180deg);
    }
</style>

<script>
    function toggleSidebarSection(header) {
        const section = header.parentElement;
        section.classList.toggle('active');
    }

    // Global toggle for the mobile hamburger menu
    window.toggleHamburger = function () {
        const menu = document.getElementById('hamburgerMenu');
        const overlay = document.getElementById('hamburgerOverlay');
        if (!menu || !overlay) return;

        menu.classList.toggle('active');
        overlay.classList.toggle('active');

        const isOpen = menu.classList.contains('active');
        document.body.style.overflow = isOpen ? 'hidden' : '';

        // Update legacy appState if it exists
        if (window.appState) {
            window.appState.hamburgerOpen = isOpen;
        }
    };

    window.hideHamburger = function () {
        const menu = document.getElementById('hamburgerMenu');
        const overlay = document.getElementById('hamburgerOverlay');
        if (!menu || !overlay) return;

        menu.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';

        if (window.appState) {
            window.appState.hamburgerOpen = false;
        }
    };

    // Close on overlay click
    document.getElementById('hamburgerOverlay')?.addEventListener('click', hideHamburger);
</script>