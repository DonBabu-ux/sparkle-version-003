<%- include('partials/head', { title: 'Professional Dashboard - Sparkle' }) %>

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.4);
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        --pink-gradient: linear-gradient(135deg, #f472b6 0%, #db2777 100%);
        --card-bg: #ffffff;
        --body-bg: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --accent: #6366f1;
    }

    body {
        background-color: var(--body-bg);
        background-image:
            radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.05) 0, transparent 50%),
            radial-gradient(at 100% 0%, rgba(255, 61, 109, 0.05) 0, transparent 50%);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }

    .dashboard-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 25px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 85px 20px 40px;
    }

    .sidebar-column {
        position: sticky;
        top: 85px;
        height: calc(100vh - 100px);
        overflow-y: auto;
        scrollbar-width: none;
    }

    .sidebar-column::-webkit-scrollbar { display: none; }

    .main-column {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    @media (max-width: 900px) {
        .dashboard-layout {
            grid-template-columns: 1fr;
            padding-top: 80px;
        }
        .sidebar-column {
            display: none;
        }
        .flex-row {
            flex-direction: column;
            gap: 24px;
        }
        .glass-panel {
            width: 100%;
            min-width: 100% !important;
            box-sizing: border-box;
        }
    }

    .pro-header {
        background: var(--primary-gradient);
        border-radius: 24px;
        padding: 40px 30px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(99, 102, 241, 0.2);
    }

    .pro-header h1 {
        font-weight: 800;
        font-size: 28px;
        margin: 0 0 10px 0;
    }

    .pro-header p {
        opacity: 0.9;
        margin: 0;
        font-size: 15px;
    }

    .grid-4 {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
    }

    .stat-card {
        background: rgba(255,255,255,0.8);
        backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .stat-card .title {
        color: var(--text-muted);
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
    }

    .stat-card .value {
        font-size: 28px;
        font-weight: 800;
        color: var(--text-main);
    }

    .stat-card .trend {
        font-size: 13px;
        font-weight: 700;
        margin-top: 8px;
        color: #10b981;
    }

    .section-title {
        font-size: 18px;
        font-weight: 800;
        color: var(--text-main);
        margin: 20px 0 15px 0;
    }

    .flex-row {
        display: flex;
        gap: 16px;
    }

    .flex-1 { flex: 1; }

    .content-dist-bar {
        height: 12px;
        border-radius: 6px;
        background: #e2e8f0;
        display: flex;
        overflow: hidden;
        margin-top: 15px;
    }

    .dist-segment {
        height: 100%;
    }

    .dist-legend {
        display: flex;
        gap: 15px;
        margin-top: 15px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-muted);
    }

    .dist-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .dist-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .glass-panel {
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        padding: 24px;
        border: 1px solid var(--glass-border);
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .top-post {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px;
        background: white;
        border-radius: 16px;
        margin-bottom: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .top-post img {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        object-fit: cover;
    }

    .top-post-info h4 {
        margin: 0 0 5px 0;
        font-size: 14px;
        color: var(--text-main);
        font-weight: 700;
    }

    .top-post-stats {
        display: flex;
        gap: 12px;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
    }

    .btn-create-ad {
        background: var(--pink-gradient);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s;
        box-shadow: 0 4px 15px rgba(219, 39, 119, 0.3);
    }

    .btn-create-ad:hover {
        transform: translateY(-2px);
    }

    /* Graph Removed */

</style>

<div id="mainContent">
    <%- include('partials/navbar') %>

    <div class="dashboard-layout">
        <aside class="sidebar-column">
            <%- include('partials/sidebar') %>
        </aside>

        <main class="main-column">
            <div class="pro-header">
                <h1>Professional Dashboard</h1>
                <p>Insights, Analytics & Monetization for Creators</p>
                <i class="fas fa-chart-line" style="position: absolute; right: -20px; bottom: -40px; font-size: 150px; opacity: 0.1;"></i>
            </div>

            <h2 class="section-title">Overview</h2>
            <div class="grid-4">
                <div class="stat-card">
                    <div class="title">Profile Views <i class="fas fa-eye text-indigo-500"></i></div>
                    <div class="value"><%= stats.profileViews %></div>
                    <div class="trend"><i class="fas fa-arrow-up"></i> +<%= stats.followersGrowth %>%</div>
                </div>
                <div class="stat-card">
                    <div class="title">Account Reach <i class="fas fa-globe text-pink-500"></i></div>
                    <div class="value"><%= stats.accountReach %></div>
                    <div class="trend"><i class="fas fa-arrow-up"></i> +8.2%</div>
                </div>
                <div class="stat-card">
                    <div class="title">Followers <i class="fas fa-users text-blue-500"></i></div>
                    <div class="value"><%= stats.followers %></div>
                    <div class="trend" style="color: var(--text-muted);"><i class="fas fa-minus"></i> Stable</div>
                </div>
                <div class="stat-card">
                    <div class="title">Interactions <i class="fas fa-heart text-red-500"></i></div>
                    <div class="value"><%= stats.likesRecv + stats.commentsRecv %></div>
                    <div class="trend"><i class="fas fa-arrow-up"></i> +12.4%</div>
                </div>
            </div>

            <div class="flex-row" style="flex-wrap: wrap; margin-bottom: 24px;">
                <div class="glass-panel flex-1">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 class="section-title" style="margin: 0;">Insights Graph</h2>
                        <select style="background: white; border: 1px solid #cbd5e1; border-radius: 8px; padding: 4px 8px; outline: none; font-weight: 600; color: var(--text-main);">
                            <option>Last 7 Days</option>
                            <option>Last 30 Days</option>
                        </select>
                    </div>
                    <div style="height: 250px; background: white; border-radius: 16px; padding: 15px; position: relative; margin-top: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); display: flex; align-items: center; justify-content: center;">
                        <canvas id="insightsChart"></canvas>
                    </div>
                </div>

                <div class="glass-panel" style="flex: 1; background: linear-gradient(135deg, rgba(255,255,255,0.7) 0%, rgba(255,240,245,0.8) 100%); position: relative; overflow: hidden; min-width: 300px; display: none;">
                    <i class="fas fa-bullhorn" style="position: absolute; right: -20px; top: -20px; font-size: 150px; opacity: 0.05; transform: rotate(-15deg);"></i>
                    <h2 class="section-title" style="margin-top: 0;">Ads & Monetization</h2>
                    <p style="color: var(--text-muted); font-weight: 600; font-size: 14px; margin-bottom: 20px;">
                        Reach more students across the Sparkle network. Turn your best performing posts into ads.
                    </p>
                    
                    <div style="background: white; padding: 15px; border-radius: 16px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
                        <div>
                            <div style="font-size: 12px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Available Balance</div>
                            <div style="font-size: 24px; font-weight: 800; color: #10b981;">KES 0.00</div>
                        </div>
                        <button style="background: #10b981; color: white; border: none; padding: 8px 16px; border-radius: 8px; font-weight: 700; cursor: pointer; box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);">
                            + Add Funds
                        </button>
                    </div>
 
                    <div style="display: flex; gap: 10px;">
                        <button class="btn-create-ad" style="flex: 1;" onclick="openCreateAdModal()">Create Ad</button>
                        <button class="btn-create-ad" style="flex: 1; background: var(--primary-gradient);" onclick="openBoostPostModal()">Boost Post</button>
                    </div>
                    <div style="text-align: center; margin-top: 15px; font-size: 12px; font-weight: 700; color: var(--text-muted);">
                        Monetization Features Active
                    </div>
                </div>
            </div>

            <div class="flex-row" style="flex-wrap: wrap;">
                <div class="glass-panel flex-1">
                    <h2 class="section-title" style="margin-top:0;">Content Analytics</h2>
                    <p style="color: var(--text-muted); font-size: 14px; font-weight: 600;">Content Types Distribution</p>
                    <div class="content-dist-bar">
                        <div class="dist-segment" style="width: <%= dist.videos %>%; background: #a855f7;"></div>
                        <div class="dist-segment" style="width: <%= dist.photos %>%; background: #f472b6;"></div>
                        <div class="dist-segment" style="width: <%= dist.stories %>%; background: #60a5fa;"></div>
                    </div>
                    <div class="dist-legend">
                        <div class="dist-item"><div class="dist-dot" style="background:#a855f7;"></div> Videos (<%= dist.videos %>%)</div>
                        <div class="dist-item"><div class="dist-dot" style="background:#f472b6;"></div> Photos/Posts (<%= dist.photos %>%)</div>
                        <div class="dist-item"><div class="dist-dot" style="background:#60a5fa;"></div> Stories (<%= dist.stories %>%)</div>
                    </div>
                    
                    <h3 style="font-size: 14px; font-weight: 700; margin-top: 25px; color: var(--text-main);">Audience Makeup</h3>
                    <div style="display: flex; justify-content: space-between; margin-top: 10px;">
                        <div>
                            <div style="font-size: 20px; font-weight: 800; color: var(--text-main);"><%= (stats.followerLikes / (stats.followerLikes + stats.nonFollowerLikes || 1) * 100).toFixed(1) %>%</div>
                            <div style="font-size: 12px; font-weight: 600; color: var(--text-muted);">From Followers</div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 20px; font-weight: 800; color: var(--text-main);"><%= (stats.nonFollowerLikes / (stats.followerLikes + stats.nonFollowerLikes || 1) * 100).toFixed(1) %>%</div>
                            <div style="font-size: 12px; font-weight: 600; color: var(--text-muted);">From Non-Followers</div>
                        </div>
                    </div>
                </div>

                <div class="glass-panel" style="flex: 1; min-width: 300px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 class="section-title" style="margin: 0;">Top Content</h2>
                    </div>

                    <% if (topPosts && topPosts.length > 0) { %>
                        <% topPosts.forEach(post => { %>
                            <div class="top-post">
                                <img src="<%= post.media_url || '/uploads/avatars/default.png' %>" alt="Post thumbnail">
                                <div class="top-post-info" style="flex: 1;">
                                    <h4><%= (post.content && post.content.length > 30) ? post.content.substring(0, 30) + '...' : (post.content || 'Media Post') %></h4>
                                    <div class="top-post-stats">
                                        <span><i class="fas fa-heart text-red-500"></i> <%= post.likes %></span>
                                        <span><i class="fas fa-comment text-blue-500"></i> <%= post.comments %></span>
                                    </div>
                                </div>
                                <div style="font-weight: 800; color: var(--accent);"><i class="fas fa-fire"></i></div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div style="text-align: center; padding: 30px 10px; color: var(--text-muted); font-weight: 600;">
                            No content posted yet to rank.
                        </div>
                    <% } %>
                </div>
            </div>

        </main>
    </div>
</div>

<!-- Simple Modals Simulation for Monetization -->
<div id="adModal" style="display:none; position: fixed; inset:0; background: rgba(0,0,0,0.5); z-index: 9999; align-items:center; justify-content:center; backdrop-filter: blur(5px);">
    <div style="background: white; padding: 30px; border-radius: 20px; width: 90%; max-width: 400px; box-shadow: 0 20px 50px rgba(0,0,0,0.2);">
        <h3 style="margin-top:0; font-weight: 800;">Create Advertisement</h3>
        <p style="color: var(--text-muted); font-size: 13px;">Set your budget and duration to start reaching more students.</p>
        
        <label style="font-weight: 700; font-size: 13px; margin-top: 15px; display: block;">Budget (KES)</label>
        <input type="number" placeholder="e.g. 500" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd; margin-bottom: 15px;">
        
        <label style="font-weight: 700; font-size: 13px; display: block;">Duration (Days)</label>
        <input type="number" placeholder="e.g. 7" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd; margin-bottom: 25px;">
        
        <div style="display: flex; gap: 10px;">
            <button onclick="document.getElementById('adModal').style.display='none'" style="flex: 1; padding: 10px; border-radius: 8px; border: none; background: #eee; font-weight: 700; cursor: pointer;">Cancel</button>
            <button onclick="document.getElementById('adModal').style.display='none'; alert('Ad request submitted and stored in local cache!');" style="flex: 1; padding: 10px; border-radius: 8px; border: none; background: var(--primary-gradient); color: white; font-weight: 700; cursor: pointer;">Start Campaign</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('insightsChart');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Day 1', 'Day 2', 'Day 3', 'Day 4', 'Day 5', 'Day 6', 'Today'],
                    datasets: [{
                        label: 'Profile Views',
                        data: [12, 19, 15, 25, 22, 30, Number('<%= stats.profileViews %>') || 40],
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.1)',
                        borderWidth: 3,
                        tension: 0.4,
                        fill: true
                    }, {
                        label: 'Interactions',
                        data: [5, 8, 12, 10, 15, 18, Number('<%= stats.likesRecv %>') + Number('<%= stats.commentsRecv %>') || 20],
                        borderColor: '#a855f7',
                        borderWidth: 3,
                        tension: 0.4,
                        borderDash: [5, 5]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { usePointStyle: true, boxWidth: 8 } }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
    });

    function openCreateAdModal() {
        document.getElementById('adModal').style.display = 'flex';
    }
    function openBoostPostModal() {
        alert("Select a post to boost from your profile!");
        window.location.href = '/profile';
    }
</script>

<%- include('partials/bottom-nav') %>
<script src="/js/script.js"></script>
</body>
</html>
