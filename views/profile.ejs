<%- include('partials/head', { title: title }) %>

    <style>
        @media (max-width: 768px) {
            .container {
                padding: 15px;
                padding-bottom: 80px;
            }

            .profile-header-card {
                padding: 20px 15px !important;
            }

            .profile-header-top {
                flex-direction: column !important;
                text-align: center;
                gap: 20px;
            }

            .profile-info {
                width: 100%;
            }

            .profile-info-header {
                justify-content: center !important;
                flex-direction: column;
                gap: 15px;
            }

            .profile-stats {
                justify-content: center !important;
                gap: 20px !important;
                background: white;
                padding: 15px;
                border-radius: 16px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
                margin: 20px 0 !important;
                display: flex !important;
            }

            .profile-avatar-container {
                width: 100px !important;
                height: 100px !important;
                margin: 0 auto;
            }

            .profile-bio {
                text-align: center;
            }

            .profile-tabs {
                padding: 10px 0;
                gap: 10px;
                overflow-x: auto;
                justify-content: space-around;
            }

            .profile-posts-grid {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 8px !important;
                padding: 10px 0;
            }

            .post-card {
                border-radius: 12px !important;
            }
        }

        .profile-posts-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            padding: 20px 0;
        }

        /* Image Viewer Modal */
        .image-viewer-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            justify-content: center;
            align-items: center;
        }

        .image-viewer-content {
            max-width: 90%;
            max-height: 90%;
        }

        .image-viewer-content img {
            max-width: 100%;
            max-height: 100%;
            border-radius: 8px;
            box-shadow: 0 0 30px rgba(0,0,0,0.5);
        }

        .close-viewer {
            position: absolute;
            top: 20px;
            right: 30px;
            color: white;
            font-size: 40px;
            cursor: pointer;
        }

        /* Mutual Connections Styles */
        .mutual-connections {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 15px;
            cursor: pointer;
            font-size: 14px;
            color: #64748b;
        }

        .mutual-avatars {
            display: flex;
            align-items: center;
        }

        .mutual-avatars img {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid white;
            margin-left: -8px;
        }

        .mutual-avatars img:first-child {
            margin-left: 0;
        }

        /* Follow List Modal Styles */
        .follow-list-content {
            max-width: 400px !important;
            padding: 0 !important;
        }

        .modal-header {
            padding: 15px 20px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: #94a3b8;
        }

        .follow-list-body {
            max-height: 400px;
            overflow-y: auto;
            padding: 10px 0;
        }

        .user-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            transition: background 0.2s;
        }

        .user-item:hover {
            background: #f8fafc;
        }

        .user-item-info {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
        }

        .user-item-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
        }

        .user-item-details h4 {
            font-size: 14px;
            margin: 0;
            color: #1e293b;
        }

        .user-item-details p {
            font-size: 12px;
            margin: 0;
            color: #64748b;
        }

        /* New Profile Section Styles */
        .profile-headline { font-weight: 600; color: #475569; margin-top: 5px; font-size: 15px; }
        .profile-website { color: #6366f1; text-decoration: none; font-size: 14px; display: flex; align-items: center; gap: 5px; margin-top: 5px; }
        .profile-website:hover { text-decoration: underline; }
        .profile-details-grid { display: grid; grid-template-columns: 1fr; gap: 15px; margin-top: 25px; padding: 20px; background: rgba(255,255,255,0.5); border-radius: 20px; border: 1px solid rgba(225, 48, 108, 0.1); }
        .detail-item { display: flex; align-items: flex-start; gap: 12px; }
        .detail-icon { width: 36px; height: 36px; background: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .detail-content h4 { margin: 0; font-size: 12px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; }
        .detail-content p { margin: 2px 0 0; font-size: 14px; font-weight: 600; color: #1e293b; }
        .social-links { display: flex; gap: 10px; margin-top: 20px; }
        .social-btn { width: 40px; height: 40px; background: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #475569; text-decoration: none; transition: 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .social-btn:hover { background: var(--primary); color: white; transform: translateY(-3px); }
        
        .birthday-badge { background: linear-gradient(135deg, #FF3D6D 0%, #FF8A00 100%); color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; margin-left: 8px; display: inline-flex; align-items: center; gap: 4px; box-shadow: 0 4px 10px rgba(255, 61, 109, 0.2); }
        .similar-birthdays-btn { background: #fee2e2; color: #ef4444; border: none; padding: 8px 16px; border-radius: 12px; font-size: 12px; font-weight: 700; cursor: pointer; margin-top: 15px; display: flex; align-items: center; gap: 8px; transition: 0.2s; width: 100%; justify-content: center; }
        .similar-birthdays-btn:hover { background: #fecaca; transform: scale(1.02); }
        
        /* Birthday Wish Template Modal */
        .birthday-list-item { display: flex; align-items: center; justify-content: space-between; padding: 15px; border-bottom: 1px solid #f1f5f9; }
        .birthday-user-info { display: flex; align-items: center; gap: 12px; }
        .birthday-user-avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }
        .wish-btn { background: var(--primary); color: white; border: none; padding: 6px 12px; border-radius: 8px; font-size: 11px; font-weight: 700; cursor: pointer; }
    </style>
    <%- include('partials/sidebar') %>

        <div class="container" id="mainContent">
            <%- include('partials/navbar') %>

                <main class="profile-container">
                    <!-- Premium Profile Header Card -->
                    <div class="profile-header-card">
                        <div class="profile-header-top">
                            <div class="avatar-section">
                                <div class="profile-avatar-container" style="cursor: pointer;" 
                                    data-avatar-url="<%= profile.avatar_url || '/uploads/avatars/default.png' %>"
                                    onclick="openImageViewer(this.dataset.avatarUrl)">
                                    <img src="<%= profile.avatar_url || '/uploads/avatars/default.png' %>"
                                        alt="<%= profile.name %>"
                                        onerror="this.onerror=null;this.src='/uploads/avatars/default.png';">
                                </div>
                            </div>

                            <div class="profile-info">
                                <div class="profile-info-header">
                                    <h1>
                                        <%= profile.username %>
                                            <% if (profile.is_verified) { %>
                                                <i class="fas fa-check-circle"
                                                    style="color: var(--primary, #FF3D6D); font-size: 20px;"></i>
                                                <% } %>
                                    </h1>

                                    <!-- Action Buttons -->
                                    <% if (isOwnProfile) { %>
                                        <a href="/settings" class="btn btn-secondary">Edit Profile</a>
                                        <button class="btn btn-secondary" onclick="window.location.href='/dashboard'">
                                            <i class="fas fa-cog"></i>
                                        </button>
                                        <% } else { %>
                                            <div class="profile-actions" style="display: flex; gap: 10px;">
                                                <% if (profile.is_followed_by_me) { %>
                                                    <button class="btn btn-secondary follow-btn" id="followButton" onclick="toggleFollow('<%= profile.user_id %>', this)">Following</button>
                                                <% } else if (profile.is_requested_by_me) { %>
                                                    <button class="btn btn-secondary" disabled id="followButton">Requested</button>
                                                <% } else { %>
                                                    <button class="btn btn-primary follow-btn" id="followButton" onclick="toggleFollow('<%= profile.user_id %>', this)">Follow</button>
                                                <% } %>

                                                                <button class="btn btn-secondary"
                                                                    onclick="openMessages('<%= profile.user_id %>', '<%= profile.username %>')">
                                                                    Message
                                                                </button>

                                                                <button class="btn btn-secondary"
                                                                    data-user-id="<%= profile.user_id %>" onclick="toggleBlockUser(this.dataset.userId)"
                                                                    title="Block User">
                                                                    <i class="fas fa-user-slash"></i>
                                                                </button>
                                            </div>
                                            <% } %>
                                </div>

                                    <!-- Stats View -->
                                    <% 
                                        const isPrivate = !isOwnProfile && (profile.is_private || profile.profile_visibility === 'private') && !profile.is_followed_by_me;
                                        const followersOnclick = isPrivate ? '' : 'onclick="showFollowList(\'followers\')"';
                                        const followingOnclick = isPrivate ? '' : 'onclick="showFollowList(\'following\')"';
                                        const statsStyle = isPrivate ? 'style="cursor: default;"' : 'style="cursor: pointer;"';
                                    %>
                                    <div class="profile-stats">
                                        <div>
                                            <span class="profile-stats-item" id="postsCount">
                                                <%= (typeof posts !== 'undefined') ? posts.length : 0 %>
                                            </span>
                                            <span class="profile-stats-label"> posts</span>
                                        </div>
                                        <div <%- statsStyle %> <%- followersOnclick %>>
                                            <span class="profile-stats-item" id="followersCount">
                                                <%= profile.followers_count || 0 %>
                                            </span>
                                            <span class="profile-stats-label"> followers</span>
                                        </div>
                                        <div <%- statsStyle %> <%- followingOnclick %>>
                                            <span class="profile-stats-item" id="followingCount">
                                                <%= profile.following_count || 0 %>
                                            </span>
                                            <span class="profile-stats-label"> following</span>
                                        </div>
                                    </div>

                                <!-- Bio Section -->
                                <div class="profile-bio">
                                    <div class="profile-bio-name">
                                        <%= profile.name %>
                                    </div>
                                    <% if (profile.headline) { %>
                                        <div class="profile-headline"><%= profile.headline %></div>
                                    <% } %>

                                    <% if (profile.bio) { %>
                                        <div class="profile-bio-text" style="margin-top: 10px;">
                                            <%- profile.bio.replace(/@(\w+)/g, '<a href="/profile/$1" style="color: var(--primary); text-decoration: none; font-weight: 600;">@$1</a>') %>
                                        </div>
                                    <% } %>

                                    <% if (profile.website) { %>
                                        <a href="https://<%= profile.website.replace('https://', '').replace('http://', '') %>" target="_blank" class="profile-website">
                                            <i class="fas fa-link"></i> <%= profile.website.replace('https://', '').replace('http://', '') %>
                                        </a>
                                    <% } %>
                                    
                                    <div class="profile-details-grid">
                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                                            <h3 style="margin: 0; font-size: 14px; font-weight: 800; color: var(--primary);">Personal details</h3>
                                        </div>

                                        <% if (profile.campus) { %>
                                            <div class="detail-item">
                                                <div class="detail-icon"><i class="fas fa-graduation-cap"></i></div>
                                                <div class="detail-content">
                                                    <h4>Education</h4>
                                                    <p><%= profile.campus %> <%= profile.year_of_study ? `(${profile.year_of_study})` : '' %></p>
                                                    <% if (profile.major) { %><p style="font-size: 12px; color: #64748b;"><%= profile.major %></p><% } %>
                                                </div>
                                            </div>
                                        <% } %>

                                        <% if (profile.relationship_status) { %>
                                            <div class="detail-item">
                                                <div class="detail-icon"><i class="fas fa-heart"></i></div>
                                                <div class="detail-content">
                                                    <h4>Relationship</h4>
                                                    <p>
                                                        <%= profile.relationship_status %>
                                                        <% if (profile.partner_username) { %>
                                                            with <a href="/profile/<%= profile.partner_username %>" style="color: var(--primary); text-decoration: none;">@<%= profile.partner_username %></a>
                                                        <% } %>
                                                    </p>
                                                    <% if (profile.relationship_since) { %>
                                                        <p style="font-size: 12px; color: #64748b;">Since <%= new Date(profile.relationship_since).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></p>
                                                    <% } %>
                                                </div>
                                            </div>
                                        <% } %>

                                        <% if (profile.birthday && (isOwnProfile || profile.show_birthday)) { %>
                                            <div class="detail-item">
                                                <div class="detail-icon"><i class="fas fa-birthday-cake"></i></div>
                                                <div class="detail-content">
                                                    <h4>Birthday</h4>
                                                    <p>
                                                        <%= new Date(profile.birthday).toLocaleDateString('en-US', { month: 'long', day: 'numeric' }) %>
                                                        <% if (isOwnProfile) { %>
                                                            <span style="font-size: 11px; color: #94a3b8; font-weight: normal;">(<%= new Date(profile.birthday).getFullYear() %>)</span>
                                                        <% } %>
                                                    </p>
                                                    <% if (isOwnProfile) { %>
                                                        <button class="similar-birthdays-btn" onclick="openSimilarBirthdays()">
                                                            <i class="fas fa-magic"></i> Show similar birthdays
                                                        </button>
                                                    <% } %>
                                                </div>
                                            </div>
                                        <% } %>

                                        <% if (isOwnProfile || profile.show_contact_info) { %>
                                            <div class="detail-item">
                                                <div class="detail-icon"><i class="fas fa-address-book"></i></div>
                                                <div class="detail-content">
                                                    <h4>Contact info</h4>
                                                    <p><%= profile.username %></p>
                                                    <p style="font-size: 13px; color: #475569;"><i class="fas fa-envelope" style="font-size: 10px;"></i> <%= profile.email %></p>
                                                    <% if (profile.phone_number) { %>
                                                        <p style="font-size: 13px; color: #475569;"><i class="fas fa-phone" style="font-size: 10px;"></i> <%= profile.phone_number %></p>
                                                    <% } %>
                                                </div>
                                            </div>
                                        <% } %>
                                    </div>

                                    <div class="social-links">
                                        <% if (profile.github_url) { %>
                                            <a href="<%= profile.github_url %>" target="_blank" class="social-btn" title="GitHub"><i class="fab fa-github"></i></a>
                                        <% } %>
                                        <% if (profile.linkedin_url) { %>
                                            <a href="<%= profile.linkedin_url %>" target="_blank" class="social-btn" title="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                                        <% } %>
                                        <% if (profile.instagram_url) { %>
                                            <a href="<%= profile.instagram_url %>" target="_blank" class="social-btn" title="Instagram"><i class="fab fa-instagram"></i></a>
                                        <% } %>
                                        <% if (profile.twitter_url) { %>
                                            <a href="<%= profile.twitter_url %>" target="_blank" class="social-btn" title="X"><i class="fab fa-twitter"></i></a>
                                        <% } %>
                                    </div>

                                    <% if (mutualConnections && mutualConnections.length> 0) { %>
                                        <div class="mutual-connections"
                                            onclick="showFollowList('mutual')">
                                            <div class="mutual-avatars">
                                                <% mutualConnections.slice(0, 3).forEach(user=> { %>
                                                    <img src="<%= user.avatar_url || '/uploads/avatars/default.png' %>"
                                                        alt="Mutual">
                                                    <% }) %>
                                            </div>
                                            <span>Followed by <%= mutualConnections[0].username %>
                                                    <%= mutualConnections.length> 1 ? `and
                                                        ${mutualConnections.length - 1} others` : ''
                                                        %></span>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Follow List Modal -->
                    <div class="modal" id="followListModal">
                        <div class="modal-content follow-list-content">
                            <div class="modal-header">
                                <h3 id="followListTitle">Followers</h3>
                                <button class="close-modal" onclick="closeFollowModal()">&times;</button>
                            </div>
                            <div class="follow-list-body" id="followListBody">
                                <!-- Users will be injected here -->
                            </div>
                        </div>
                    </div>

                    <!-- Image Viewer Modal -->
                    <div id="imageViewerModal" class="image-viewer-modal">
                        <span class="close-viewer" onclick="closeImageViewer()">&times;</span>
                        <div class="image-viewer-content">
                            <img id="viewerImage" src="" alt="Full size profile">
                        </div>
                    </div>

                    <!-- Active Friends Section -->
                    <% if (typeof activeFriends !== 'undefined' && activeFriends && activeFriends.length > 0) { %>
                    <div class="profile-extra-section" style="margin-top: 20px; padding: 0 10px;">
                        <h3 style="font-weight: 800; font-size: 18px; color: var(--text-main); margin-bottom: 15px; display: flex; align-items: center;">
                            Active Friends <span style="background: #10b981; width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-left: 6px;"></span>
                        </h3>
                        <div style="display: flex; gap: 12px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: none; -ms-overflow-style: none;">
                            <style>.profile-extra-section div::-webkit-scrollbar { display: none; }</style>
                            <% activeFriends.forEach(u => { %>
                                <div onclick="window.location.href='/profile/<%= u.username %>'" style="min-width: 65px; text-align: center; cursor: pointer;">
                                    <div style="position: relative; width: 52px; height: 52px; margin: 0 auto;">
                                        <img src="<%= u.avatar_url %>" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 2.5px solid var(--accent); background: white;">
                                        <div style="position: absolute; bottom: 1px; right: 1px; width: 13px; height: 13px; background: #10b981; border: 2px solid white; border-radius: 50%;"></div>
                                    </div>
                                    <div style="font-size: 11px; font-weight: 600; margin-top: 6px; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= u.username %></div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>

                    <!-- Friends List (Following) -->
                    <% if (isOwnProfile && typeof followingList !== 'undefined' && followingList && followingList.length > 0) { %>
                    <div class="profile-extra-section" style="margin-top: 25px; padding: 0 10px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <h3 style="font-weight: 800; font-size: 18px; color: var(--text-main); margin: 0;">Connected Sparklers</h3>
                            <a href="javascript:void(0)" onclick="showFollowList('following')" style="color: var(--accent); font-size: 13px; font-weight: 700; text-decoration: none;">View All</a>
                        </div>
                        <div style="display: flex; gap: 12px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: none;">
                            <% followingList.slice(0, 12).forEach(u => { %>
                                <div onclick="window.location.href='/profile/<%= u.username %>'" style="min-width: 65px; text-align: center; cursor: pointer;">
                                    <img src="<%= u.avatar_url %>" style="width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 1px solid #edf2f7; background: white; margin: 0 auto;">
                                    <div style="font-size: 11px; font-weight: 600; margin-top: 6px; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= u.username %></div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>

                    <!-- Content Tabs -->
                    <div class="profile-tabs">
                        <div class="tab active" onclick="switchTab(event, 'posts')">
                            <i class="fas fa-th"></i> POSTS
                        </div>
                        <% if (isOwnProfile) { %>
                        <div class="tab" onclick="switchTab(event, 'sparks')">
                            <i class="fas fa-heart"></i> LIKED
                        </div>
                        <div class="tab" onclick="switchTab(event, 'saved')">
                            <i class="fas fa-bookmark"></i> SAVED
                        </div>
                        <% } %>
                    </div>

                    <!-- Posts Grid -->
                    <div class="profile-posts-grid" id="postsGrid">
                        <% if (!isOwnProfile && (profile.is_private || profile.profile_visibility==='private') && !profile.is_followed_by_me) { %>
                            <div class="private-account-message"
                                style="grid-column: 1 / -1; text-align: center; padding: 60px 20px; background: #f8fafc; border-radius: 20px;">
                                <i class="fas fa-lock"
                                    style="font-size: 48px; color: #94a3b8; margin-bottom: 20px;"></i>
                                <h2 style="color: #1e293b; margin-bottom: 10px;">This Account is Private</h2>
                                <p style="color: #64748b;">Follow this account to see their photos and videos.</p>
                            </div>
                        <% } else if (posts && posts.length> 0) { %>
                                <% posts.forEach(post=> { %>
                                    <div class="post-card" onclick="viewPost('<%= post.post_id %>')">
                                        <% if (post.media_url) { %>
                                            <img src="<%= post.media_url %>" alt="Post"
                                                onerror="this.onerror=null;this.parentElement.innerHTML='<div style=&quot;display:flex;align-items:center;justify-content:center;height:100%;background:#fafafa;&quot;><i class=&quot;fas fa-image&quot; style=&quot;font-size:48px;color:#dbdbdb;&quot;></i></div>';">
                                            <% } else { %>
                                                <div class="text-post-placeholder">
                                                    <p>
                                                        <%= post.content.substring(0, 100) %>
                                                            <%= post.content.length> 100 ? '...' : '' %>
                                                    </p>
                                                </div>
                                                <% } %>
                                                    <div class="post-overlay">
                                                        <div><i class="fas fa-bolt"></i>
                                                            <%= post.sparks || 0 %>
                                                        </div>
                                                        <div><i class="fas fa-comment"></i>
                                                            <%= post.comments || 0 %>
                                                        </div>
                                                    </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="empty-state">
                                                <div class="empty-state-icon">
                                                    <i class="fas fa-camera"></i>
                                                </div>
                                                <h3>No Posts Yet</h3>
                                                <p>When <%= isOwnProfile ? 'you' : profile.username %> share<%=
                                                            isOwnProfile ? '' : 's' %> posts, they'll appear here.</p>
                                            </div>
                                            <% } %>
                    </div>
                </main>
        </div>

        <script id="mutualConnectionsData" type="application/json">
            <%- JSON.stringify(mutualConnections || []) %>
        </script>
        <script src="/js/dashboardAPI.js"></script>
        <script src="/js/script.js"></script>
        <script type="module" src="/js/dynamicPatch/index.js"></script>
        <script>
            // Follow/Unfollow functionality
            document.getElementById('followButton')?.addEventListener('click', async function () {
                const userId = this.dataset.userId;
                const isFollowing = this.innerText.trim() === 'Following';

                try {
                    const response = await fetch(`/api/users/follow/${userId}`, {
                        method: isFollowing ? 'DELETE' : 'POST',
                        headers: { 'Authorization': `Bearer ${getToken()}` }
                    });
                    const data = await response.json();

                    if (data.status === 'requested') {
                        this.innerText = 'Requested';
                        this.classList.replace('btn-primary', 'btn-secondary');
                        this.disabled = true;
                    } else if (data.status === 'following' || data.success) {
                        location.reload();
                    }
                } catch (error) {
                    console.error('Follow error:', error);
                    alert('Error updating follow status');
                }
            });

            function getToken() {
                const match = document.cookie.match(new RegExp('(^| )sparkleToken=([^;]+)'));
                return match ? match[2] : localStorage.getItem('sparkleToken');
            }

            async function toggleBlockUser(userId) {
                if (!confirm('Are you sure you want to block this user? They will not be able to see your profile or posts.')) return;
                try {
                    const response = await fetch(`/api/users/block/${userId}`, {
                        method: 'POST',
                        headers: {
                            'Authorization': `Bearer ${getToken()}`,
                            'Content-Type': 'application/json'
                        }
                    });
                    if (response.ok) {
                        alert('User blocked');
                        window.location.href = '/dashboard';
                    }
                } catch (error) {
                    console.error('Block error:', error);
                }
            }

            function updateFollowerCount(change) {
                const followersElement = document.getElementById('followersCount');
                if (followersElement) {
                    const currentCount = parseInt(followersElement.textContent) || 0;
                    followersElement.textContent = Math.max(0, currentCount + change);
                }
            }

            // Follow List Management
            async function showFollowList(type) {
                const modal = document.getElementById('followListModal');
                const title = document.getElementById('followListTitle');
                const body = document.getElementById('followListBody');
                const userId = '<%= profile.user_id %>';

                modal.style.display = 'flex';
                body.innerHTML = '<div style="padding: 20px; text-align: center;"><i class="fas fa-spinner fa-spin"></i></div>';

                if (type === 'followers') title.innerText = 'Followers';
                else if (type === 'following') title.innerText = 'Following';
                else title.innerText = 'Mutual Connections';

                try {
                    let users = [];
                    if (type === 'mutual') {
                        users = JSON.parse(document.getElementById('mutualConnectionsData').textContent);
                    } else {
                        const res = await fetch(`/api/users/${userId}/${type}`, {
                            headers: { 'Authorization': `Bearer ${getToken()}` }
                        });
                        users = await res.json();
                    }

                    if (users.length === 0) {
                        body.innerHTML = `<div style="padding: 40px; text-align: center; color: #64748b;">No ${type} yet.</div>`;
                        return;
                    }

                    body.innerHTML = users.map(user => `
                        <div class="user-item">
                            <div class="user-item-info" onclick="window.location.href='/profile/${user.username}'">
                                <img src="${user.avatar_url || '/uploads/avatars/default.png'}" class="user-item-avatar">
                                <div class="user-item-details">
                                    <h4>${user.username}</h4>
                                    <p>${user.name}</p>
                                </div>
                            </div>
                            ${user.user_id === '<%= user.userId || user.user_id %>' ? '' : `
                                <button class="btn ${user.is_followed_by_me ? 'btn-secondary' : 'btn-primary'}" 
                                        style="padding: 6px 12px; font-size: 12px;"
                                        onclick="handleListFollow(this, '${user.user_id}')">
                                    ${user.is_followed_by_me ? 'Following' : 'Follow'}
                                </button>
                            `}
                        </div>
                    `).join('');
                } catch (err) {
                    body.innerHTML = '<div style="padding: 20px; text-align: center; color: #ef4444;">Error loading list.</div>';
                }
            }

            function closeFollowModal() {
                document.getElementById('followListModal').style.display = 'none';
            }

            async function toggleFollow(userId, btn) {
                const isFollowing = btn.innerText.trim() === 'Following';
                try {
                    btn.disabled = true;
                    const res = await DashboardAPI.followUser(userId);
                    
                    if (res.status === 'unfollowed') {
                        btn.innerText = 'Follow';
                        btn.classList.replace('btn-secondary', 'btn-primary');
                    } else if (res.status === 'following') {
                        btn.innerText = 'Following';
                        btn.classList.replace('btn-primary', 'btn-secondary');
                    } else if (res.status === 'requested') {
                        btn.innerText = 'Requested';
                        btn.disabled = true;
                    }
                } catch (err) {
                    console.error('Follow error:', err);
                } finally {
                    btn.disabled = false;
                }
            }

            async function toggleBlockUser(userId) {
                if (!confirm('Are you sure you want to block this user?')) return;
                try {
                    await DashboardAPI.blockUser(userId);
                    alert('User blocked successfully.');
                    window.location.href = '/dashboard';
                } catch (err) {
                    alert('Failed to block user.');
                }
            }

            function openMessages(userId, username) {
                window.location.href = `/messages?chat=${userId}`;
            }

            async function handleListFollow(btn, userId) {
                const isFollowing = btn.innerText.trim() === 'Following';
                try {
                    if (isFollowing) {
                        await DashboardAPI.unfollowUser(userId);
                        btn.innerText = 'Follow';
                        btn.classList.replace('btn-secondary', 'btn-primary');
                    } else {
                        await DashboardAPI.followUser(userId);
                        btn.innerText = 'Following';
                        btn.classList.replace('btn-primary', 'btn-secondary');
                    }
                } catch (err) {
                    alert('Action failed');
                }
            }

            // Close modal on outside click
            window.onclick = function (event) {
                const modal = document.getElementById('followListModal');
                if (event.target == modal) {
                    closeFollowModal();
                }
            }

            function viewPost(postId) {
                // Point 7: Clicking a post must open the post viewer - now handled via navigation or viewer if we want
                // For now, let's keep it as navigation to /post/:id as per profile logic, 
                // but the user might want the modal viewer.
                // In dashboard, viewPost is used to open modal.
                if (window.openPostViewer) {
                    window.openPostViewer(postId);
                } else {
                    window.location.href = `/post/${postId}`;
                }
            }

            function openImageViewer(url) {
                const modal = document.getElementById('imageViewerModal');
                const img = document.getElementById('viewerImage');
                img.src = url;
                modal.style.display = 'flex';
            }

            function closeImageViewer() {
                document.getElementById('imageViewerModal').style.display = 'none';
            }

            async function openSimilarBirthdays() {
                const modal = document.getElementById('followListModal');
                const title = document.getElementById('followListTitle');
                const body = document.getElementById('followListBody');

                modal.style.display = 'flex';
                title.innerText = 'Similar Birthdays 🎂';
                body.innerHTML = '<div style="padding: 20px; text-align: center;"><i class="fas fa-spinner fa-spin"></i></div>';

                try {
                    const res = await fetch('/api/profile/similar-birthdays', {
                        headers: { 'Authorization': `Bearer ${getToken()}` }
                    });
                    const users = await res.json();

                    if (users.length === 0) {
                        body.innerHTML = '<div style="padding: 40px; text-align: center; color: #64748b;">No one else shares your birthday yet!</div>';
                        return;
                    }

                    body.innerHTML = users.map(user => `
                        <div class="birthday-list-item">
                            <div class="birthday-user-info" onclick="window.location.href='/profile/${user.username}'">
                                <img src="${user.avatar_url}" class="birthday-user-avatar">
                                <div>
                                    <h4 style="margin: 0; font-size: 14px;">${user.username}</h4>
                                    <p style="margin: 0; font-size: 12px; color: #64748b;">${user.campus || 'Sparkler'}</p>
                                </div>
                            </div>
                            <button class="wish-btn" onclick="wishHappyBirthday(this, '${user.user_id}', '${user.username}')">
                                <i class="fas fa-gift"></i> Wish happy birthday
                            </button>
                        </div>
                    `).join('');
                } catch (err) {
                    body.innerHTML = '<div style="padding: 20px; text-align: center; color: #ef4444;">Error loading list.</div>';
                }
            }

            async function wishHappyBirthday(btn, userId, username) {
                const originalText = btn.innerHTML;
                try {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                    
                    const response = await fetch('/api/posts', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${getToken()}`
                        },
                        body: JSON.stringify({
                            content: `Happy Birthday @${username}! 🎂🎉 Wishing you joy and success on your special day! #SparkleBirthday`,
                            post_type: 'public'
                        })
                    });

                    if (response.ok) {
                        btn.innerHTML = '<i class="fas fa-check"></i> Sent!';
                        btn.style.background = '#10b981';
                        setTimeout(() => {
                            btn.disabled = false;
                            btn.innerHTML = originalText;
                            btn.style.background = '';
                        }, 3000);
                    } else {
                        throw new Error('Failed to send');
                    }
                } catch (err) {
                    btn.innerHTML = '<i class="fas fa-times"></i> Error';
                    btn.style.background = '#ef4444';
                    setTimeout(() => {
                        btn.disabled = false;
                        btn.innerHTML = originalText;
                        btn.style.background = '';
                    }, 2000);
                }
            }

            const _isOwnProfile = <%= isOwnProfile ? 'true' : 'false' %>;

            async function switchTab(event, tabName) {
                // Update active state
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                event.currentTarget.classList.add('active');

                const postsGrid = document.getElementById('postsGrid');

                if (tabName === 'posts') {
                    if (window.originalPostsHTML) {
                        postsGrid.innerHTML = window.originalPostsHTML;
                    }
                    return;
                }

                // Guard: Liked/Saved are only accessible to the profile owner
                if (!_isOwnProfile && (tabName === 'sparks' || tabName === 'saved')) {
                    postsGrid.innerHTML = `<div class="empty-state"><div class="empty-state-icon"><i class="fas fa-lock"></i></div><h3>Private</h3><p>This content is only visible to the account owner.</p></div>`;
                    return;
                }

                // Save original HTML if not already saved
                if (!window.originalPostsHTML) {
                    window.originalPostsHTML = postsGrid.innerHTML;
                }

                // Show loading
                postsGrid.innerHTML = `<div class="empty-state"><i class="fas fa-spinner fa-spin"></i>
                    <p>Loading...</p>
                </div>`;

                try {
                    const endpoint = tabName === 'saved' ? '/api/profile/saved' : `/api/posts/liked`;
                    const response = await fetch(endpoint, {
                        headers: { 'Authorization': `Bearer ${getToken()}` }
                    });

                    if (!response.ok) {
                        throw new Error(`Server returned ${response.status}`);
                    }

                    const posts = await response.json();

                    if (!Array.isArray(posts)) {
                        throw new Error('API did not return a list of posts');
                    }

                    if (posts.length === 0) {
                        postsGrid.innerHTML = `
                        <div class="empty-state">
                            <div class="empty-state-icon">
                                <i class="fas fa-${tabName === 'sparks' ? 'heart' : 'bookmark'}"></i>
                            </div>
                            <h3>No ${tabName.charAt(0).toUpperCase() + tabName.slice(1)} Yet</h3>
                            <p>When you ${tabName === 'sparks' ? 'like' : 'save'} posts, they'll appear here.</p>
                        </div>
                        `;
                    } else {
                        postsGrid.innerHTML = posts.map(post => `
                        <div class="post-card" onclick="viewPost('${post.post_id}')">
                            ${post.media_url ?
                                `<img src="${post.media_url}" alt="Post"
                                onerror="this.onerror=null;this.parentElement.innerHTML='<div style=&quot;display:flex;align-items:center;justify-content:center;height:100%;background:#fafafa;&quot;><i class=&quot;fas fa-image&quot; style=&quot;font-size:48px;color:#dbdbdb;&quot;></i></div>';">`
                                :
                                `<div class="text-post-placeholder">
                                <p>${post.content.substring(0, 100)}${post.content.length > 100 ? '...' : ''}</p>
                            </div>`
                            }
                            <div class="post-overlay">
                                <div><i class="fas fa-bolt"></i> ${post.sparks || 0}</div>
                                <div><i class="fas fa-comment"></i> ${post.comments || 0}</div>
                            </div>
                        </div>
                        `).join('');
                    }
                } catch (error) {
                    console.error('Error fetching tab data:', error);
                    postsGrid.innerHTML = `<div class="empty-state">
                        <div class="empty-state-icon"><i class="fas fa-exclamation-circle"></i></div>
                        <p>Error loading ${tabName}. Please try again later.</p>
                        <p style="font-size: 12px; opacity: 0.7;">${error.message}</p>
                    </div>`;
                }
            }
        </script>
        </body>

        </html>